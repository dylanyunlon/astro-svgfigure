# ============================================================================
# astro-svgfigure Environment Configuration
# ============================================================================
# Copy to .env and fill in your API keys.
# At least ONE AI provider key is required.
#
# 推荐使用 tryallai.com 代理 (无需翻墙):
#   GEMINI_API_KEY=sk-xxx        (tryallai key)
#   GEMINI_API_BASE=https://api.tryallai.com/v1
#   OPENAI_API_KEY=sk-xxx        (tryallai key, for grok-4)
#   OPENAI_API_BASE=https://api.tryallai.com/v1

# ── Google Gemini (for NanoBanana SVG + Image generation) ────────────────
GEMINI_API_KEY=
GEMINI_API_BASE=                  # Empty = direct Google; or https://api.tryallai.com/v1
GEMINI_DEFAULT_MODEL=gemini-3-pro-image-preview

# ── OpenAI-Compatible (for Grok 4 prompt engineering) ────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.tryallai.com/v1
OPENAI_DEFAULT_MODEL=grok-4

# ── Anthropic Claude (native SDK) ───────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.tryallai.com
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-6

# ── Claude-Compatible (third-party /v1/messages endpoint) ───────────────
CLAUDE_COMPATIBLE_API_KEY=
CLAUDE_COMPATIBLE_API_BASE=https://api.tryallai.com

# ── Pipeline Defaults (Steps 1-4) ───────────────────────────────────────
DEFAULT_AI_MODEL=claude-opus-4-6
DEFAULT_TOPOLOGY_MODEL=claude-opus-4-6
DEFAULT_BEAUTIFY_MODEL=grok-4
DEFAULT_VALIDATOR_MODEL=claude-opus-4-6

# ── Step 5: Image Generation ────────────────────────────────────────────
# Grok 4 generates detailed prompt → Gemini 3 Pro Image generates figure
DEFAULT_PROMPT_MODEL=grok-4
DEFAULT_IMAGE_MODEL=gemini-3-pro-image-preview

# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=["http://localhost:4321","http://localhost:3000"]

# ── Python Backend URL (for Astro frontend to call) ─────────────────────
PYTHON_BACKEND_URL=http://127.0.0.1:8000
