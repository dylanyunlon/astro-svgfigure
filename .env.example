# ============================================================================
# astro-svgfigure Environment Configuration
# ============================================================================
# Copy to .env and fill in your API keys.
# At least ONE AI provider key is required.

# ── Google Gemini (recommended for NanoBanana SVG generation) ────────────
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# ── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# ── Anthropic Claude (native SDK) ───────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# ── Claude-Compatible (third-party /v1/messages endpoint) ───────────────
# For providers like TryAllAI, Bianxie, OpenRouter that expose Claude via /v1/messages
# Example: api.tryallai.com supports Claude native format at /v1/messages
# Docs: https://apifox.newapi.ai/383826476e0
CLAUDE_COMPATIBLE_API_KEY=
CLAUDE_COMPATIBLE_API_BASE=https://api.tryallai.com

# ── Pipeline Defaults ────────────────────────────────────────────────────
# Use the strongest models for each pipeline step:
#   - topology: needs strong reasoning → gemini-2.5-pro / claude-sonnet-4-20250514
#   - beautify: needs creative SVG → gemini-2.5-flash (NanoBanana native)
#   - validator: needs code understanding → gemini-2.5-pro
DEFAULT_AI_MODEL=gemini-2.5-flash
DEFAULT_TOPOLOGY_MODEL=gemini-2.5-pro
DEFAULT_BEAUTIFY_MODEL=gemini-2.5-flash
DEFAULT_VALIDATOR_MODEL=gemini-2.5-pro

# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=["http://localhost:4321","http://localhost:3000"]

# ── Python Backend URL (for Astro frontend to call) ─────────────────────
PYTHON_BACKEND_URL=http://localhost:8000
