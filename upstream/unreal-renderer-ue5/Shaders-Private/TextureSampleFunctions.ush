#if FEATURE_LEVEL >= FEATURE_LEVEL_SM5 // Cubemap arrays are not supported in SM4 feature level
TS_VECTOR4 TS_FN(TextureCubeArraySample)(TextureCubeArray Tex, SamplerState Sampler, float4 UV)
{
	return Tex.Sample(Sampler, UV);
}

TS_VECTOR4 TS_FN(TextureCubeArraySampleLevel)(TextureCubeArray Tex, SamplerState Sampler, float4 UV, MaterialFloat Mip)
{
	return Tex.SampleLevel(Sampler, UV, Mip);
}

TS_VECTOR4 TS_FN(TextureCubeArraySampleBias)(TextureCubeArray Tex, SamplerState Sampler, float4 UV, MaterialFloat MipBias)
{
