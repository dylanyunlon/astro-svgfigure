#else
	return TS_FN(TextureCubeSample)(Tex, Sampler, UV);
#endif
}
TS_VECTOR4 TS_FN(TextureExternalSample_Decal)(TextureExternal Tex, SamplerState Sampler, float2 UV)
{
#if METAL_ES3_1_PROFILE || COMPILER_GLSL_ES3_1
	return TS_FN(TextureExternalSampleLevel)(Tex, Sampler, UV, 0);
#else
	return TS_FN(TextureExternalSample)(Tex, Sampler, UV);
#endif
}

TS_VECTOR4 TS_FN(Texture2DArraySampleBias)(Texture2DArray Tex, SamplerState Sampler, float3 UV, MaterialFloat MipBias)
{
#if USE_FORCE_TEXTURE_MIP
	return Tex.SampleLevel(Sampler, UV, 0);
#else
	return Tex.SampleBias(Sampler, UV, MipBias);
