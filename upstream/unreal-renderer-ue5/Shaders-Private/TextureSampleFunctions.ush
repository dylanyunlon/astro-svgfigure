// Re-routed texture sampling for decals
// On iOS and Android MALI devices decal UVs has issues with deriavatives on polygon edges resulting in 'wireframe' rendering artifacts (UE-50971)
// to workaround we always sample top mip level
TS_VECTOR4 TS_FN(Texture1DSample_Decal)(Texture1D Tex, SamplerState Sampler, float UV)
{
#if METAL_ES3_1_PROFILE || COMPILER_GLSL_ES3_1
	return TS_FN(Texture1DSampleLevel)(Tex, Sampler, UV, 0);
#else
	return TS_FN(Texture1DSample)(Tex, Sampler, UV);
#endif
}
TS_VECTOR4 TS_FN(Texture2DSample_Decal)(Texture2D Tex, SamplerState Sampler, float2 UV)
{
#if METAL_ES3_1_PROFILE || COMPILER_GLSL_ES3_1
	return TS_FN(Texture2DSampleLevel)(Tex, Sampler, UV, 0);
#else
	return TS_FN(Texture2DSample)(Tex, Sampler, UV);
#endif
}
TS_VECTOR4 TS_FN(Texture3DSample_Decal)(Texture3D Tex, SamplerState Sampler, float3 UV)
{
#if METAL_ES3_1_PROFILE || COMPILER_GLSL_ES3_1
	return TS_FN(Texture3DSampleLevel)(Tex, Sampler, UV, 0);
#else
	return TS_FN(Texture3DSample)(Tex, Sampler, UV);
#endif
}
TS_VECTOR4 TS_FN(Texture2DArraySample_Decal)(Texture2DArray Tex, SamplerState Sampler, float3 UV)
{
#if METAL_ES3_1_PROFILE || COMPILER_GLSL_ES3_1
	return TS_FN(Texture2DArraySampleLevel)(Tex, Sampler, UV, 0);
#else
	return TS_FN(Texture2DArraySample)(Tex, Sampler, UV);
#endif
}
