TS_VECTOR4 TS_FN(TextureCubeArraySampleGrad)(TextureCubeArray Tex, SamplerState Sampler, float4 UV, MaterialFloat3 DDX, MaterialFloat3 DDY)
{
	return Tex.SampleGrad(Sampler, UV, DDX, DDY);
}

// Overload with explicit array parameter, used by some non-material shader code
TS_VECTOR4 TS_FN(TextureCubeArraySampleLevel)(TextureCubeArray Tex, SamplerState Sampler, float3 UV, float ArrayIndex, MaterialFloat Mip)
{
	return TS_FN(TextureCubeArraySampleLevel)(Tex, Sampler, float4(UV, ArrayIndex), Mip);
}

