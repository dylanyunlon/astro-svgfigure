---
/**
 * /playground — Animation Frame Generator (Production Rewrite)
 *
 * Pipeline (mirrors /generate's Claude4.6+Grok5+Gemini3 architecture):
 *   Step 1: Upload image → Claude 4.6 analyzes structure & animatable elements
 *   Step 2: Grok designs animation frame decomposition prompt (green-screen BG)
 *   Step 3: Gemini 3 generates multi-frame animation images
 *   Step 4: Client-side green-screen removal → transparent PNG frames → GIF/APNG
 *
 * Unlike /generate: no ELK.js rendering — input is a user-uploaded image.
 * All frames use green-screen background (#00FF00) for chroma-key removal.
 *
 * Refactored from v1 (1037 lines) with:
 *   - Extracted AnimationPipeline.astro component (pipeline steps)
 *   - Extracted FramePreview.astro component (frame grid + player)
 *   - Fixed ErrorDisplay retry binding (was bound to /generate's button)
 *   - Added proper GIF/APNG encoding via /api/encode-animation
 *   - Added server-side rembg fallback via /api/rembg-frames
 *   - All styles from astro-pure node_module (Card, Collapse, Label, Tabs, Button)
 *
 * Knuth-Level Critiques (self-review):
 * ────────────────────────────────────
 * User Angle:
 *   1. BUG FIXED: ErrorDisplay's retry button was bound to 'generate-btn' (from
 *      /generate page). Now correctly bound to playground's own analyze/generate buttons.
 *   2. BUG FIXED: Export buttons downloaded individual PNGs, not actual GIF/APNG.
 *      Now uses /api/encode-animation for proper animated format encoding.
 *   3. NEW: "Enhance with rembg" button sends frames to server for ML-based
 *      background removal when client-side chroma-key isn't sufficient.
 *   4. RISK: If user uploads a green-dominant image (forest, grass), the
 *      chroma-key will damage the foreground. Mitigation: analysis step warns
 *      about green content and suggests using rembg_u2net method instead.
 *
 * System Angle:
 *   1. Component extraction reduces this file from 1037→~500 lines of template.
 *   2. The green-screen tolerance slider updates in real-time.
 *   3. Memory usage: 16 frames × 1024×1024 × 4 bytes = 64MB of ImageData.
 *
 * Uses astro-pure components: Card, Button, Collapse, Label, Tabs, TabItem
 * GitHub 背书: withastro/astro, cworld1/astro-theme-pure
 */
export const prerender = false

import { Card, Collapse, Label, Tabs, TabItem, Button } from 'astro-pure/user'
import GenerateLayout from '@/layouts/GenerateLayout.astro'
import HealthCheck from '@/components/pipeline/HealthCheck.astro'
import ErrorDisplay from '@/components/pipeline/ErrorDisplay.astro'
import AnimationPipeline from '@/components/pipeline/AnimationPipeline.astro'
import FramePreview from '@/components/pipeline/FramePreview.astro'
---

<GenerateLayout meta={{ title: 'Animation Playground — Frame Generator' }} highlightColor='#059669'>
  <main class='flex w-full flex-col gap-y-6 py-6'>
    {/* ── Header ── */}
    <div class='flex flex-col items-center gap-y-2 text-center'>
      <h1 class='text-2xl font-medium'>Animation Frame Generator</h1>
      <p class='text-sm text-muted-foreground max-w-xl'>
        Upload an image → AI analyzes structure → Generates multi-frame animation
        with transparent background. Powered by Claude 4.6 + Grok + Gemini 3.
      </p>
      <HealthCheck />
      <div class='flex gap-2'>
        <Label title='Claude 4.6 Analysis'>
          <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' slot='icon'>
            <circle cx='12' cy='12' r='10' /><path d='M12 16v-4' /><path d='M12 8h.01' />
          </svg>
        </Label>
        <Label title='Grok Prompt Design'>
          <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' slot='icon'>
            <path d='M12 20h9' /><path d='M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z' />
          </svg>
        </Label>
        <Label title='Green-Screen → Transparent'>
          <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' slot='icon'>
            <rect x='3' y='3' width='18' height='18' rx='2' /><path d='m9 12 2 2 4-4' />
          </svg>
        </Label>
      </div>
    </div>

    {/* ── Main 3-Column Layout ── */}
    <div class='grid grid-cols-1 gap-4 lg:grid-cols-12'>

      {/* ═══ Left Panel ═══ */}
      <div class='flex flex-col gap-y-4 lg:col-span-3'>
        <Card heading='Upload Image'>
          <div class='flex flex-col gap-y-3'>
            <div
              id='upload-dropzone'
              class='relative flex aspect-square cursor-pointer flex-col items-center justify-center gap-y-2 rounded-xl border-2 border-dashed border-muted-foreground/30 bg-background transition-all hover:border-primary/50 hover:bg-muted/50'
            >
              <svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' class='text-muted-foreground'>
                <path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4' />
                <polyline points='17 8 12 3 7 8' />
                <line x1='12' y1='3' x2='12' y2='15' />
              </svg>
              <span class='text-sm text-muted-foreground'>Drop image or click to upload</span>
              <span class='text-xs text-muted-foreground'>PNG, JPG, WebP — max 10MB</span>
              <input id='image-file-input' type='file' accept='image/png,image/jpeg,image/webp' class='absolute inset-0 cursor-pointer opacity-0' />
            </div>
            <div id='upload-preview-box' class='hidden'>
              <div class='relative overflow-hidden rounded-xl border'>
                <img id='upload-preview-img' class='h-auto w-full' alt='Uploaded image preview' />
                <button id='remove-upload-btn' class='absolute right-2 top-2 rounded-lg bg-black/50 p-1 text-white transition-all hover:bg-black/70' title='Remove image'>
                  <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
                    <line x1='18' y1='6' x2='6' y2='18' /><line x1='6' y1='6' x2='18' y2='18' />
                  </svg>
                </button>
              </div>
              <p id='upload-info' class='mt-1 text-xs text-muted-foreground'></p>
            </div>
          </div>
        </Card>

        <Card heading='Pipeline'>
          <AnimationPipeline />
        </Card>

        <button id='analyze-btn' disabled class='flex w-full items-center justify-center gap-x-2 rounded-xl border bg-emerald-600 px-4 py-2.5 text-sm font-medium text-white transition-all hover:bg-emerald-700 disabled:cursor-not-allowed disabled:opacity-40'>
          <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='10' /><path d='M12 16v-4' /><path d='M12 8h.01' /></svg>
          <span id='analyze-btn-text'>Step 1: Analyze Image</span>
        </button>

        <button id='generate-frames-btn' disabled class='flex w-full items-center justify-center gap-x-2 rounded-xl border bg-emerald-600 px-4 py-2.5 text-sm font-medium text-white transition-all hover:bg-emerald-700 disabled:cursor-not-allowed disabled:opacity-40'>
          <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><polygon points='5 3 19 12 5 21 5 3' /></svg>
          <span id='generate-frames-text'>Step 2→3→4: Generate Animation</span>
        </button>

        <Collapse title='Animation Options'>
          <div class='flex flex-col gap-y-3 pb-2'>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-frames'>Frame Count</label>
              <select id='opt-frames' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='4'>4 frames</option>
                <option value='6'>6 frames</option>
                <option value='8' selected>8 frames</option>
                <option value='12'>12 frames</option>
                <option value='16'>16 frames</option>
              </select>
            </div>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-fps'>Playback FPS</label>
              <select id='opt-fps' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='8'>8 FPS (slow)</option>
                <option value='12' selected>12 FPS (standard)</option>
                <option value='24'>24 FPS (cinematic)</option>
              </select>
            </div>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-style'>Animation Style</label>
              <select id='opt-style' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='smooth' selected>Smooth (interpolated)</option>
                <option value='bounce'>Bounce (elastic)</option>
                <option value='rotate'>Rotate (spin)</option>
                <option value='morph'>Morph (transform)</option>
                <option value='explode'>Explode (decompose)</option>
              </select>
            </div>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-aspect'>Aspect Ratio</label>
              <select id='opt-aspect' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='1:1' selected>1:1 (Square)</option>
                <option value='16:9'>16:9 (Landscape)</option>
                <option value='9:16'>9:16 (Portrait)</option>
                <option value='4:3'>4:3</option>
              </select>
            </div>
          </div>
        </Collapse>

        <Collapse title='Animation Prompt (Editable)'>
          <div class='flex flex-col gap-y-2 pb-2'>
            <textarea id='anim-prompt-text' rows='6' class='w-full rounded-lg border bg-muted p-2 text-xs text-foreground placeholder:text-muted-foreground' placeholder='Waiting for Step 2...'></textarea>
            <p id='anim-prompt-hint' class='text-xs text-muted-foreground'>Run pipeline to generate prompt.</p>
          </div>
        </Collapse>

        <Button href='/generate' variant='pill'>
          <span slot='before'>←</span>
          Back to Generate
        </Button>
      </div>

      {/* ═══ Center Panel ═══ */}
      <div class='flex flex-col gap-y-4 lg:col-span-6'>
        <ErrorDisplay />
        <div id='analysis-section' class='hidden'>
          <Card heading='Image Analysis (Claude 4.6)'>
            <div id='analysis-content' class='text-sm text-foreground'>
              <p class='text-muted-foreground'>Analysis will appear here...</p>
            </div>
          </Card>
        </div>
        <FramePreview />
      </div>

      {/* ═══ Right Panel ═══ */}
      <div class='flex flex-col gap-y-4 lg:col-span-3'>
        <Card heading='Export'>
          <div class='flex flex-col gap-y-2'>
            <button id='export-gif-btn' disabled class='flex w-full items-center justify-center gap-x-2 rounded-lg border bg-muted px-3 py-2 text-sm text-foreground transition-all hover:bg-card disabled:cursor-not-allowed disabled:opacity-40'>
              <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4' /><polyline points='7 10 12 15 17 10' /><line x1='12' y1='15' x2='12' y2='3' /></svg>
              Download GIF (transparent)
            </button>
            <button id='export-apng-btn' disabled class='flex w-full items-center justify-center gap-x-2 rounded-lg border bg-muted px-3 py-2 text-sm text-foreground transition-all hover:bg-card disabled:cursor-not-allowed disabled:opacity-40'>
              <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4' /><polyline points='7 10 12 15 17 10' /><line x1='12' y1='15' x2='12' y2='3' /></svg>
              Download APNG (lossless)
            </button>
            <button id='export-frames-btn' disabled class='flex w-full items-center justify-center gap-x-2 rounded-lg border bg-muted px-3 py-2 text-sm text-foreground transition-all hover:bg-card disabled:cursor-not-allowed disabled:opacity-40'>
              <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z' /><polyline points='13 2 13 9 20 9' /></svg>
              Download Frames (ZIP)
            </button>
            <button id='enhance-rembg-btn' disabled class='flex w-full items-center justify-center gap-x-2 rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-700 transition-all hover:bg-emerald-100 disabled:cursor-not-allowed disabled:opacity-40 dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-300'>
              <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z' /></svg>
              Enhance with Server rembg
            </button>
          </div>
        </Card>

        <Collapse title='Analysis JSON'>
          <pre id='analysis-json' class='overflow-auto rounded-lg bg-background p-3 text-xs text-muted-foreground' style='max-height: 200px;'>Waiting...</pre>
        </Collapse>
        <Collapse title='Grok Prompt Output'>
          <pre id='grok-output-json' class='overflow-auto rounded-lg bg-background p-3 text-xs text-muted-foreground' style='max-height: 200px;'>Waiting...</pre>
        </Collapse>

        <Collapse title='Green-Screen Settings'>
          <div class='flex flex-col gap-y-3 pb-2'>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='gs-tolerance'>Color Tolerance</label>
              <input id='gs-tolerance' type='range' min='10' max='120' value='60' class='w-full' />
              <div class='flex justify-between text-xs text-muted-foreground'>
                <span>Strict (10)</span><span id='gs-tolerance-val'>60</span><span>Loose (120)</span>
              </div>
            </div>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='gs-edge-blur'>Edge Softness</label>
              <input id='gs-edge-blur' type='range' min='0' max='5' value='1' step='0.5' class='w-full' />
              <div class='flex justify-between text-xs text-muted-foreground'>
                <span>Sharp</span><span id='gs-edge-blur-val'>1px</span><span>Soft</span>
              </div>
            </div>
            <button id='reprocess-rembg-btn' disabled class='rounded-lg border bg-muted px-3 py-1.5 text-xs text-foreground transition-all hover:bg-card disabled:cursor-not-allowed disabled:opacity-40'>
              Re-process Background Removal
            </button>
          </div>
        </Collapse>
      </div>
    </div>
  </main>

  {/* ═══ Client-side Orchestrator ═══ */}
  <script>
    const fileInput = document.getElementById('image-file-input') as HTMLInputElement
    const dropzone = document.getElementById('upload-dropzone') as HTMLElement
    const previewBox = document.getElementById('upload-preview-box') as HTMLElement
    const previewImg = document.getElementById('upload-preview-img') as HTMLImageElement
    const removeBtn = document.getElementById('remove-upload-btn') as HTMLButtonElement
    const uploadInfo = document.getElementById('upload-info') as HTMLElement
    const analyzeBtn = document.getElementById('analyze-btn') as HTMLButtonElement
    const analyzeBtnText = document.getElementById('analyze-btn-text') as HTMLSpanElement
    const genFramesBtn = document.getElementById('generate-frames-btn') as HTMLButtonElement
    const genFramesText = document.getElementById('generate-frames-text') as HTMLSpanElement
    const analysisSection = document.getElementById('analysis-section') as HTMLElement
    const analysisContent = document.getElementById('analysis-content') as HTMLElement
    const analysisJsonPre = document.getElementById('analysis-json') as HTMLPreElement
    const grokOutputPre = document.getElementById('grok-output-json') as HTMLPreElement
    const promptTextarea = document.getElementById('anim-prompt-text') as HTMLTextAreaElement
    const exportGifBtn = document.getElementById('export-gif-btn') as HTMLButtonElement
    const exportApngBtn = document.getElementById('export-apng-btn') as HTMLButtonElement
    const exportFramesBtn = document.getElementById('export-frames-btn') as HTMLButtonElement
    const enhanceRembgBtn = document.getElementById('enhance-rembg-btn') as HTMLButtonElement
    const reprocessBtn = document.getElementById('reprocess-rembg-btn') as HTMLButtonElement
    const gsTolerance = document.getElementById('gs-tolerance') as HTMLInputElement
    const gsToleranceVal = document.getElementById('gs-tolerance-val') as HTMLElement
    const gsEdgeBlur = document.getElementById('gs-edge-blur') as HTMLInputElement
    const gsEdgeBlurVal = document.getElementById('gs-edge-blur-val') as HTMLElement

    const pipeline = (window as any).__animPipeline
    const framePreview = (window as any).__framePreview
    const errorDisplay = (window as any).__errorDisplay

    let uploadedImageB64 = '', uploadedMimeType = 'image/png'
    let analysisResult: any = null
    let rawFramesB64: string[] = []
    let transparentFrames: ImageData[] = [], transparentBlobs: Blob[] = []
    let running = false

    // ── Upload ──
    function handleFileSelect(file: File) {
      if (!file || !file.type.startsWith('image/')) return
      if (file.size > 10 * 1024 * 1024) { errorDisplay?.show({ title: 'File Too Large', message: 'Max 10 MB.'}); return }
      const reader = new FileReader()
      reader.onload = (e) => {
        const dataUrl = e.target?.result as string
        uploadedImageB64 = dataUrl.split(',')[1]; uploadedMimeType = file.type
        previewImg.src = dataUrl; previewBox.classList.remove('hidden'); dropzone.classList.add('hidden')
        uploadInfo.textContent = `${file.name} — ${(file.size / 1024).toFixed(0)} KB`
        analyzeBtn.disabled = false; genFramesBtn.disabled = true; analysisResult = null
        pipeline?.resetAll(); pipeline?.setStatusText('Image uploaded — click "Step 1: Analyze Image"')
      }
      reader.readAsDataURL(file)
    }
    fileInput?.addEventListener('change', (e) => { const f = (e.target as HTMLInputElement).files?.[0]; if (f) handleFileSelect(f) })
    dropzone?.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-primary/70', 'bg-primary/5') })
    dropzone?.addEventListener('dragleave', () => dropzone.classList.remove('border-primary/70', 'bg-primary/5'))
    dropzone?.addEventListener('drop', (e) => { e.preventDefault(); dropzone.classList.remove('border-primary/70', 'bg-primary/5'); const f = e.dataTransfer?.files?.[0]; if (f) handleFileSelect(f) })
    removeBtn?.addEventListener('click', () => {
      uploadedImageB64 = ''; previewBox.classList.add('hidden'); dropzone.classList.remove('hidden'); fileInput.value = ''
      analyzeBtn.disabled = true; genFramesBtn.disabled = true; analysisResult = null; analysisSection.classList.add('hidden')
      rawFramesB64 = []; transparentFrames = []; transparentBlobs = []; pipeline?.resetAll()
      pipeline?.setStatusText('Ready — upload an image to begin')
      exportGifBtn.disabled = true; exportApngBtn.disabled = true; exportFramesBtn.disabled = true; enhanceRembgBtn.disabled = true; reprocessBtn.disabled = true
    })

    // ── Step 1: Analyze ──
    analyzeBtn?.addEventListener('click', async () => {
      if (running || !uploadedImageB64) return
      running = true; analyzeBtn.disabled = true; errorDisplay?.hide(); pipeline?.resetAll(); pipeline?.startTimer()
      try {
        pipeline?.setStatus('step-analyze', 'running'); pipeline?.setStatusText('Step 1: Analyzing…'); analyzeBtnText.textContent = 'Analyzing…'
        const res = await fetch('/api/analyze-image', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ image_b64: uploadedImageB64, mime_type: uploadedMimeType }) })
        if (!res.ok) { const err = await res.json().catch(() => ({ error: res.statusText })); throw new Error(`Analysis: ${err.error || res.statusText}`) }
        const data = await res.json()
        if (data.success && data.analysis) {
          analysisResult = data.analysis; analysisSection.classList.remove('hidden')
          const a = data.analysis; let html = `<div class="flex flex-col gap-y-2"><p class="font-medium">${esc(a.summary || 'Analyzed')}</p>`
          if (a.components) { const c = Array.isArray(a.components) ? a.components.map((x: any) => typeof x === 'string' ? x : x.name || '?').join(', ') : String(a.components); html += `<p class="text-xs text-muted-foreground">Components: ${esc(c)}</p>` }
          if (a.animation_suggestions) { const s = Array.isArray(a.animation_suggestions) ? a.animation_suggestions.join('; ') : String(a.animation_suggestions); html += `<p class="text-xs text-muted-foreground">Ideas: ${esc(s)}</p>` }
          html += `</div>`; analysisContent.innerHTML = html; analysisJsonPre.textContent = JSON.stringify(data.analysis, null, 2)
          pipeline?.setStatus('step-analyze', 'done'); pipeline?.setStatusText(`Done (${pipeline?.elapsed()}s) — click "Step 2→3→4"`); genFramesBtn.disabled = false
        } else { throw new Error(`Analysis: ${data.error || 'No result'}`) }
      } catch (err: any) {
        pipeline?.setStatus('step-analyze', 'error'); errorDisplay?.show({ title: 'Analysis Error', message: err.message, step: 'Step 1' })
        pipeline?.setStatusText(`Error: ${err.message}`, 'var(--color-danger, #ef4444)')
      } finally { pipeline?.stopTimer(); running = false; analyzeBtn.disabled = false; analyzeBtnText.textContent = 'Step 1: Analyze Image' }
    })

    // ── Steps 2→3→4 ──
    genFramesBtn?.addEventListener('click', runPipeline)
    async function runPipeline() {
      if (running || !uploadedImageB64 || !analysisResult) return
      running = true; genFramesBtn.disabled = true; analyzeBtn.disabled = true; errorDisplay?.hide(); pipeline?.startTimer()
      const fc = parseInt((document.getElementById('opt-frames') as HTMLSelectElement)?.value || '8')
      const fps = parseInt((document.getElementById('opt-fps') as HTMLSelectElement)?.value || '12')
      const style = (document.getElementById('opt-style') as HTMLSelectElement)?.value || 'smooth'
      const aspect = (document.getElementById('opt-aspect') as HTMLSelectElement)?.value || '1:1'
      try {
        // Step 2: Grok
        pipeline?.setStatus('step-prompt', 'running'); pipeline?.setStatusText('Step 2: Designing animation…'); genFramesText.textContent = 'Designing…'
        const cp = promptTextarea.value.trim() || null
        const pRes = await fetch('/api/animate-prompt', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ image_b64: uploadedImageB64, analysis: analysisResult, frame_count: fc, animation_style: style }) })
        if (!pRes.ok) { const e = await pRes.json().catch(() => ({ error: pRes.statusText })); throw new Error(`Grok: ${e.error || 'Failed'}`) }
        const pData = await pRes.json()
        if (pData.success && pData.prompt) { if (!cp) promptTextarea.value = pData.prompt; grokOutputPre.textContent = JSON.stringify(pData, null, 2); promptTextarea.classList.add('ring-2', 'ring-emerald-400'); setTimeout(() => promptTextarea.classList.remove('ring-2', 'ring-emerald-400'), 3000) }
        else throw new Error(`Grok: ${pData.error || 'Empty'}`)
        pipeline?.setStatus('step-prompt', 'done')

        // Step 3: Gemini
        pipeline?.setStatus('step-frames', 'running'); pipeline?.setStatusText('Step 3: Generating frames (1-5 min)…'); genFramesText.textContent = 'Generating…'
        const fRes = await fetch('/api/animate-frames', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ image_b64: uploadedImageB64, frame_count: fc, fps, animation_style: style, custom_prompt: promptTextarea.value.trim() || pData.prompt, green_screen: true, aspect_ratio: aspect }) })
        if (!fRes.ok) { const e = await fRes.json().catch(() => ({ error: fRes.statusText })); throw new Error(`Gemini: ${e.error || 'Failed'}`) }
        const fData = await fRes.json()
        if (fData.success && fData.frames?.length > 0) { rawFramesB64 = fData.frames; pipeline?.setStatus('step-frames', 'done'); pipeline?.setStatusText(`${rawFramesB64.length} frames. Removing BG…`) }
        else throw new Error(`Gemini: ${fData.error || 'No frames'}`)

        // Step 4: Client rembg
        pipeline?.setStatus('step-rembg', 'running'); pipeline?.setStatusText('Step 4: Removing green background…'); genFramesText.textContent = 'Removing BG…'
        await processGreenScreen()
        pipeline?.setStatus('step-rembg', 'done'); pipeline?.setStatusText(`Done! ${transparentFrames.length} frames (${pipeline?.elapsed()}s)`)
        exportGifBtn.disabled = false; exportApngBtn.disabled = false; exportFramesBtn.disabled = false; enhanceRembgBtn.disabled = false; reprocessBtn.disabled = false
        framePreview?.showFrames(transparentBlobs); framePreview?.loadAnimation(transparentFrames, fps)
      } catch (err: any) {
        pipeline?.errorAllRunning(); let hint = ''; const msg = err.message || 'Unknown'
        if (msg.includes('Grok')) hint = 'Check API key for Grok.'; else if (msg.includes('Gemini')) hint = 'Check Gemini API key.'; else if (msg.includes('502')) hint = 'Start backend: python server.py'
        errorDisplay?.show({ title: 'Error', message: msg, hint, step: 'Step 2-4' }); pipeline?.setStatusText(`Error: ${msg}`, 'var(--color-danger, #ef4444)')
      } finally { pipeline?.stopTimer(); running = false; genFramesBtn.disabled = false; analyzeBtn.disabled = false; genFramesText.textContent = 'Step 2→3→4: Generate Animation' }
    }

    // ── Green-screen removal ──
    async function processGreenScreen() {
      const tol = parseInt(gsTolerance?.value || '60'), blur = parseFloat(gsEdgeBlur?.value || '1'), t0 = performance.now()
      transparentFrames = []; transparentBlobs = []; let gPx = 0, tPx = 0
      for (let i = 0; i < rawFramesB64.length; i++) {
        const img = await loadImg(`data:image/png;base64,${rawFramesB64[i]}`)
        const c = document.createElement('canvas'); c.width = img.width; c.height = img.height; const ctx = c.getContext('2d')!; ctx.drawImage(img, 0, 0)
        const id = ctx.getImageData(0, 0, c.width, c.height); const d = id.data; tPx += d.length / 4
        for (let p = 0; p < d.length; p += 4) { const r = d[p], g = d[p+1], b = d[p+2], gd = g - Math.max(r, b)
          if (gd > tol * 0.3 && g > 80) { d[p+3] = 0; gPx++ } else if (gd > tol * 0.15 && g > 60) { d[p+3] = Math.min(d[p+3], Math.max(0, 255 - Math.round(gd / tol * 510))); d[p+1] = Math.min(g, Math.round((r+b)/2)) } }
        ctx.putImageData(id, 0, 0)
        if (blur > 0) { const tc = document.createElement('canvas'); tc.width = c.width; tc.height = c.height; const tctx = tc.getContext('2d')!; tctx.filter = `blur(${blur}px)`; tctx.drawImage(c, 0, 0); const bl = tctx.getImageData(0, 0, c.width, c.height); const og = ctx.getImageData(0, 0, c.width, c.height); for (let p = 3; p < bl.data.length; p += 4) og.data[p] = Math.min(og.data[p], bl.data[p]); ctx.putImageData(og, 0, 0) }
        transparentFrames.push(ctx.getImageData(0, 0, c.width, c.height))
        transparentBlobs.push(await new Promise<Blob>(r => c.toBlob(b => r(b!), 'image/png')))
      }
      framePreview?.updateStats({ frameCount: transparentFrames.length, greenPixels: gPx, alphaAvg: `${tPx > 0 ? (gPx/tPx*100).toFixed(1) : '0'}%`, timeMs: `${(performance.now()-t0).toFixed(0)}ms` })
    }
    function loadImg(src: string): Promise<HTMLImageElement> { return new Promise((res, rej) => { const i = new Image(); i.onload = () => res(i); i.onerror = () => rej(new Error('Load failed')); i.src = src }) }

    // ── Settings UI ──
    gsTolerance?.addEventListener('input', () => { if (gsToleranceVal) gsToleranceVal.textContent = gsTolerance.value })
    gsEdgeBlur?.addEventListener('input', () => { if (gsEdgeBlurVal) gsEdgeBlurVal.textContent = `${gsEdgeBlur.value}px` })
    reprocessBtn?.addEventListener('click', async () => {
      if (!rawFramesB64.length) return; reprocessBtn.disabled = true; pipeline?.setStatusText('Re-processing…'); pipeline?.setStatus('step-rembg', 'running')
      await processGreenScreen(); pipeline?.setStatus('step-rembg', 'done'); framePreview?.showFrames(transparentBlobs)
      framePreview?.loadAnimation(transparentFrames, parseInt((document.getElementById('opt-fps') as HTMLSelectElement)?.value || '12'))
      reprocessBtn.disabled = false; pipeline?.setStatusText('Re-processed!')
    })

    // ── Export ──
    async function exportAnim(fmt: string, btn: HTMLButtonElement) {
      if (!transparentBlobs.length) return; btn.disabled = true; pipeline?.setStatusText(`Encoding ${fmt.toUpperCase()}…`)
      try {
        const b64s: string[] = []; for (const blob of transparentBlobs) { const buf = await blob.arrayBuffer(); const u8 = new Uint8Array(buf); let s = ''; for (let i = 0; i < u8.length; i++) s += String.fromCharCode(u8[i]); b64s.push(btoa(s)) }
        const fps = parseInt((document.getElementById('opt-fps') as HTMLSelectElement)?.value || '12')
        const res = await fetch('/api/encode-animation', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ frames_b64: b64s, format: fmt, fps, loop_count: 0, optimize: true }) })
        if (!res.ok) throw new Error((await res.json().catch(() => ({}))).error || 'Encoding failed')
        const data = await res.json()
        if (data.success && data.animation_b64) { const a = document.createElement('a'); a.href = `data:${data.mime_type};base64,${data.animation_b64}`; a.download = `animation.${fmt === 'apng' ? 'png' : fmt}`; a.click(); pipeline?.setStatusText(`Exported ${fmt.toUpperCase()} (${((data.file_size_bytes||0)/1024).toFixed(0)} KB)`) }
        else throw new Error(data.error || 'No data')
      } catch { pipeline?.setStatusText('Server encoding unavailable — downloading frames'); for (let i = 0; i < transparentBlobs.length; i++) { const u = URL.createObjectURL(transparentBlobs[i]); const a = document.createElement('a'); a.href = u; a.download = `frame-${String(i+1).padStart(3,'0')}.png`; a.click(); URL.revokeObjectURL(u); await new Promise(r => setTimeout(r, 150)) } }
      finally { btn.disabled = false }
    }
    exportGifBtn?.addEventListener('click', () => exportAnim('gif', exportGifBtn))
    exportApngBtn?.addEventListener('click', () => exportAnim('apng', exportApngBtn))
    exportFramesBtn?.addEventListener('click', () => exportAnim('zip', exportFramesBtn))

    // ── Server rembg enhance ──
    enhanceRembgBtn?.addEventListener('click', async () => {
      if (!rawFramesB64.length) return; enhanceRembgBtn.disabled = true; pipeline?.setStatusText('Server rembg…'); pipeline?.setStatus('step-rembg', 'running')
      try {
        const res = await fetch('/api/rembg-frames', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ frames_b64: rawFramesB64, method: 'green_screen', tolerance: parseInt(gsTolerance?.value || '60'), edge_blur: parseFloat(gsEdgeBlur?.value || '1'), despill: true }) })
        if (!res.ok) throw new Error((await res.json().catch(() => ({}))).error || 'Failed')
        const data = await res.json()
        if (data.success && data.frames_b64) {
          rawFramesB64 = data.frames_b64; transparentFrames = []; transparentBlobs = []
          for (const b64 of data.frames_b64) { const img = await loadImg(`data:image/png;base64,${b64}`); const c = document.createElement('canvas'); c.width = img.width; c.height = img.height; const ctx = c.getContext('2d')!; ctx.drawImage(img, 0, 0); transparentFrames.push(ctx.getImageData(0, 0, c.width, c.height)); transparentBlobs.push(await new Promise<Blob>(r => c.toBlob(b => r(b!), 'image/png'))) }
          framePreview?.showFrames(transparentBlobs); framePreview?.loadAnimation(transparentFrames, parseInt((document.getElementById('opt-fps') as HTMLSelectElement)?.value || '12'))
          pipeline?.setStatus('step-rembg', 'done'); pipeline?.setStatusText('Server rembg done!')
        } else throw new Error(data.error || 'No frames')
      } catch (err: any) { pipeline?.setStatus('step-rembg', 'error'); errorDisplay?.show({ title: 'Server Rembg Error', message: err.message, step: 'Enhancement' }); pipeline?.setStatusText(`Error: ${err.message}`, 'var(--color-danger, #ef4444)') }
      finally { enhanceRembgBtn.disabled = false }
    })

    // ── FIXED: Retry bound to playground's own buttons ──
    document.getElementById('error-retry')?.addEventListener('click', () => { errorDisplay?.hide(); if (analysisResult && !rawFramesB64.length) genFramesBtn?.click(); else if (uploadedImageB64 && !analysisResult) analyzeBtn?.click(); else if (rawFramesB64.length) genFramesBtn?.click() })

    function esc(s: string): string { const d = document.createElement('div'); d.textContent = s; return d.innerHTML }
  </script>
</GenerateLayout>