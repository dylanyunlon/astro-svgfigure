---
/**
 * /gallery — SVG Figure Gallery
 *
 * Showcases example SVGs generated by the pipeline.
 * Uses astro-pure Card, Tabs, TabItem, Button, Label components.
 *
 * GitHub 背书: cworld1/astro-theme-pure, withastro/astro
 */
import { Card, Tabs, TabItem, Button, Label } from 'astro-pure/user'
import GenerateLayout from '@/layouts/GenerateLayout.astro'

const examples = [
  {
    id: 'transformer',
    title: 'Transformer Architecture',
    description: 'Self-attention based encoder-decoder architecture for sequence transduction.',
    tags: ['NLP', 'Architecture', 'Encoder-Decoder'],
    algorithm: 'layered',
    svg: '/examples/transformer.svg',
  },
  {
    id: 'diffusion',
    title: 'Diffusion Model',
    description: 'Forward noising and reverse denoising process for generative modeling.',
    tags: ['Generative', 'Probabilistic', 'Denoising'],
    algorithm: 'layered',
    svg: '/examples/diffusion.svg',
  },
  {
    id: 'gan',
    title: 'GAN Architecture',
    description: 'Generator-Discriminator adversarial training framework.',
    tags: ['Generative', 'Adversarial', 'Two-Player'],
    algorithm: 'layered',
    svg: '/examples/gan.svg',
  },
]

const categories = ['All', 'Architecture', 'Generative', 'NLP', 'Vision']
---

<GenerateLayout meta={{ title: 'Gallery — SVG Figure Examples' }} highlightColor='#8B5CF6'>
  <main class='flex w-full flex-col gap-y-6 py-6 max-w-6xl mx-auto'>
    {/* Header */}
    <div class='flex flex-col items-center gap-y-2 text-center'>
      <h1 class='text-2xl font-medium'>Figure Gallery</h1>
      <p class='text-sm text-muted-foreground max-w-xl'>
        Browse example academic figures generated by the Planner-Visualizer pipeline.
        Click any figure to view details or use it as a template.
      </p>
    </div>

    {/* Category filter */}
    <div class='flex flex-wrap items-center justify-center gap-2'>
      {categories.map((cat) => (
        <button
          class:list={[
            'rounded-xl border px-3 py-1 text-xs transition-all hover:bg-muted',
            cat === 'All' ? 'bg-primary text-white border-primary' : 'bg-background text-muted-foreground',
          ]}
          data-filter={cat.toLowerCase()}
        >
          {cat}
        </button>
      ))}
    </div>

    {/* Grid */}
    <div class='grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3' id='gallery-grid'>
      {examples.map((ex) => (
        <Card heading={ex.title} subheading={ex.description}>
          {/* SVG preview area */}
          <div class='mt-3 flex aspect-[4/3] items-center justify-center rounded-lg border bg-white dark:bg-zinc-900 overflow-hidden'>
            <div class='flex flex-col items-center gap-y-2 text-muted-foreground'>
              <svg xmlns='http://www.w3.org/2000/svg' width='40' height='40' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'>
                <rect x='3' y='3' width='18' height='18' rx='2' />
                <circle cx='8.5' cy='8.5' r='1.5' />
                <path d='M21 15l-5-5L5 21' />
              </svg>
              <span class='text-xs'>{ex.title}</span>
            </div>
          </div>

          {/* Tags */}
          <div class='mt-3 flex flex-wrap gap-1.5'>
            {ex.tags.map((tag) => (
              <Label>{tag}</Label>
            ))}
            <Label>{ex.algorithm}</Label>
          </div>

          {/* Actions */}
          <div class='mt-3 flex gap-2'>
            <Button href={`/generate?template=${ex.id}`} variant='pill'>
              Use as Template
            </Button>
            <Button href={ex.svg} variant='pill' target='_blank'>
              View SVG
            </Button>
          </div>
        </Card>
      ))}
    </div>

    {/* CTA */}
    <div class='flex flex-col items-center gap-y-3 rounded-2xl border bg-muted px-8 py-6 text-center'>
      <h2 class='text-lg font-medium'>Create Your Own</h2>
      <p class='text-sm text-muted-foreground max-w-md'>
        Describe your paper's method in plain text and generate a publication-quality
        SVG figure in seconds.
      </p>
      <Button href='/generate' variant='pill'>
        <span slot='before'>→</span>
        Start Generating
      </Button>
    </div>
  </main>
</GenerateLayout>
