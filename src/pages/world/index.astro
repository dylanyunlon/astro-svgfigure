---
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout meta={{ title: 'SPH World', description: 'Cyber-physical world renderer' }}>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #000;
      overflow: hidden;
      font-family: 'Courier New', Courier, monospace;
    }

    #world-root {
      position: relative;
      width: 100vw;
      height: 100vh;
    }

    #sph-canvas {
      display: block;
      width: 100%;
      height: 100%;
      background: #000;
    }

    /* ── HUD overlay ──────────────────────────────────────────────────────── */
    #hud {
      position: absolute;
      top: 16px;
      left: 16px;
      color: #00ff88;
      font-size: 13px;
      line-height: 1.8;
      pointer-events: none;
      text-shadow: 0 0 8px #00ff88;
      z-index: 10;
    }

    #hud .hud-row {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    #hud .hud-label {
      color: #888;
    }

    #hud .hud-value {
      color: #00ff88;
      min-width: 64px;
    }

    /* ── QoS controls ─────────────────────────────────────────────────────── */
    #qos-panel {
      position: absolute;
      top: 16px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      z-index: 10;
    }

    #qos-panel .qos-label {
      color: #888;
      font-size: 11px;
      text-align: right;
      font-family: 'Courier New', Courier, monospace;
    }

    #qos-panel .qos-btn-group {
      display: flex;
      gap: 6px;
    }

    .qos-btn {
      padding: 6px 12px;
      border: 1px solid #333;
      background: rgba(0, 0, 0, 0.6);
      color: #888;
      font-size: 12px;
      font-family: 'Courier New', Courier, monospace;
      cursor: pointer;
      border-radius: 3px;
      transition: all 0.15s ease;
    }

    .qos-btn:hover {
      border-color: #00ff88;
      color: #00ff88;
    }

    .qos-btn.active {
      border-color: #00ff88;
      color: #00ff88;
      background: rgba(0, 255, 136, 0.1);
      box-shadow: 0 0 6px rgba(0, 255, 136, 0.3);
    }

    /* ── Render mode toggle panel ─────────────────────────────────────────── */
    #render-mode-panel {
      position: absolute;
      top: 64px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      z-index: 10;
    }

    /* ── Preset scene selector ────────────────────────────────────────────── */
    #preset-panel {
      position: absolute;
      top: 112px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      z-index: 10;
    }

    #preset-panel select {
      padding: 6px 10px;
      border: 1px solid #333;
      background: rgba(0, 0, 0, 0.6);
      color: #00ff88;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      cursor: pointer;
      border-radius: 3px;
      outline: none;
      transition: border-color 0.15s ease;
    }

    #preset-panel select:hover,
    #preset-panel select:focus {
      border-color: #00ff88;
    }

    /* ── SSE status dot ───────────────────────────────────────────────────── */
    #sse-status {
      position: absolute;
      bottom: 16px;
      left: 16px;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      color: #555;
      z-index: 10;
      pointer-events: none;
    }

    #sse-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #333;
      transition: background 0.3s ease;
    }

    #sse-status.connected #sse-dot  { background: #00ff88; box-shadow: 0 0 5px #00ff8888; }
    #sse-status.offline   #sse-dot  { background: #ffa000; }
    #sse-status.error     #sse-dot  { background: #ff4444; }

    /* ── WebGPU fallback banner ────────────────────────────────────────────── */
    #webgpu-fallback {
      display: none;
      position: absolute;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(255, 160, 0, 0.15);
      border: 1px solid #ffa000;
      color: #ffa000;
      padding: 10px 20px;
      border-radius: 4px;
      font-size: 13px;
      font-family: 'Courier New', Courier, monospace;
      text-align: center;
      z-index: 20;
      pointer-events: none;
    }

    #webgpu-fallback.visible {
      display: block;
    }

    /* ── Init overlay ─────────────────────────────────────────────────────── */
    #init-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000;
      color: #00ff88;
      font-size: 15px;
      font-family: 'Courier New', Courier, monospace;
      z-index: 30;
      transition: opacity 0.5s ease;
    }

    #init-overlay.hidden {
      opacity: 0;
      pointer-events: none;
    }

    .spinner {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 2px solid #00ff8844;
      border-top-color: #00ff88;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-right: 10px;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* ── Debug overlay panel ──────────────────────────────────────────────── */
    #debug-panel {
      position: absolute;
      top: 168px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      z-index: 10;
      background: rgba(0, 0, 0, 0.55);
      border: 1px solid #222;
      border-radius: 4px;
      padding: 8px 12px;
      min-width: 148px;
    }

    #debug-panel .debug-label {
      color: #888;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      text-align: right;
      margin-bottom: 2px;
      letter-spacing: 0.05em;
    }

    .debug-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      cursor: pointer;
    }

    .debug-row label {
      color: #888;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      cursor: pointer;
      user-select: none;
      transition: color 0.15s ease;
    }

    .debug-row input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 14px;
      height: 14px;
      border: 1px solid #444;
      border-radius: 2px;
      background: rgba(0, 0, 0, 0.6);
      cursor: pointer;
      flex-shrink: 0;
      position: relative;
      transition: all 0.15s ease;
    }

    .debug-row input[type="checkbox"]:checked {
      background: rgba(0, 255, 136, 0.15);
      border-color: #00ff88;
    }

    .debug-row input[type="checkbox"]:checked::after {
      content: '';
      position: absolute;
      left: 3px;
      top: 1px;
      width: 5px;
      height: 8px;
      border: 1.5px solid #00ff88;
      border-top: none;
      border-left: none;
      transform: rotate(45deg);
    }

    .debug-row:hover label {
      color: #00ff88;
    }

    .debug-row input[type="checkbox"]:hover {
      border-color: #00ff88;
    }
  </style>

  <div id="world-root">
    <canvas id="sph-canvas"></canvas>
    <!-- GPU render loop canvas (M885: GPURenderLoop integration) -->
    <canvas id="gpu-world" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:1;"></canvas>
    <!-- M1060: AT WebGL2 render pipeline canvas (compiled.vs → bloom → present) -->
    <canvas id="at-canvas" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:2;display:none;"></canvas>

    <!-- HUD -->
    <div id="hud">
      <div class="hud-row">
        <span class="hud-label">PARTICLES</span>
        <span class="hud-value" id="hud-particles">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">FPS</span>
        <span class="hud-value" id="hud-fps">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">COLLISIONS</span>
        <span class="hud-value" id="hud-collisions">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">COL DEPTH</span>
        <span class="hud-value" id="hud-col-depth">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">COL PAIRS</span>
        <span class="hud-value" id="hud-col-pairs">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">PRESSURE IT.</span>
        <span class="hud-value" id="hud-pressure-iters">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">MEM</span>
        <span class="hud-value" id="hud-memory">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">BACKEND</span>
        <span class="hud-value" id="hud-backend">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">QoS</span>
        <span class="hud-value" id="hud-qos">HIGH</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">SIM</span>
        <span class="hud-value" id="hud-sim-time">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">RENDER</span>
        <span class="hud-value" id="hud-render-mode">SIMPLE</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">SPLINE FLOW</span>
        <span class="hud-value" id="hud-spline-flow">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">PERF TIER</span>
        <span class="hud-value" id="hud-perf-tier">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">LOD</span>
        <span class="hud-value" id="hud-lod">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">EPOCH</span>
        <span class="hud-value" id="hud-epoch">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">CONVERGENCE</span>
        <span class="hud-value" id="hud-convergence">—</span>
      </div>
    </div>

    <!-- QoS panel -->
    <div id="qos-panel">
      <div class="qos-label">QUALITY</div>
      <div class="qos-btn-group">
        <button class="qos-btn" data-qos="low">LOW</button>
        <button class="qos-btn" data-qos="mid">MID</button>
        <button class="qos-btn active" data-qos="high">HIGH</button>
      </div>
    </div>

    <!-- Render mode toggle -->
    <div id="render-mode-panel">
      <div class="qos-label">RENDER MODE</div>
      <div class="qos-btn-group">
        <button class="qos-btn active" id="mode-simple">SIMPLE</button>
        <button class="qos-btn" id="mode-at">AT</button>
      </div>
    </div>

    <!-- Preset scene selector -->
    <div id="preset-panel">
      <div class="qos-label">PRESET SCENE</div>
      <select id="preset-select">
        <option value="">— none —</option>
        <option value="transformer_encoder">Transformer Encoder</option>
        <option value="attention_focus">Attention Focus</option>
        <option value="data_river">Data River</option>
        <option value="collision_test">Collision Test</option>
      </select>
    </div>

    <!-- Debug overlay panel -->
    <div id="debug-panel">
      <div class="debug-label">DEBUG</div>
      <div class="debug-row">
        <label for="dbg-aabbs">Show AABBs</label>
        <input type="checkbox" id="dbg-aabbs" />
      </div>
      <div class="debug-row">
        <label for="dbg-contacts">Show Contacts</label>
        <input type="checkbox" id="dbg-contacts" />
      </div>
      <div class="debug-row">
        <label for="dbg-bvh">Show BVH</label>
        <input type="checkbox" id="dbg-bvh" />
      </div>
      <div class="debug-row">
        <label for="dbg-emitters">Show Emitters</label>
        <input type="checkbox" id="dbg-emitters" />
      </div>
    </div>

    <!-- SSE connection status -->
    <div id="sse-status">
      <span id="sse-dot"></span>
      <span id="sse-label">SSE —</span>
    </div>

    <!-- WebGPU fallback notice -->
    <div id="webgpu-fallback">
      ⚠ WebGPU unavailable — running on Canvas2D fallback. Performance may be reduced.
    </div>

    <!-- Init overlay -->
    <div id="init-overlay">
      <span class="spinner"></span>
      Initializing SPH World…
    </div>
  </div>
</BaseLayout>

<script>
  // ═══════════════════════════════════════════════════════════════════════════
  //  world/index.astro — M979: World Page — 58 cells + SSE + full GPU pipeline
  //
  //  M979 changes:
  //    1. composite_params.json expanded to 58 cells (7 transformer layers × 8 blocks
  //       + input_embed + pos_encode).  loadGPUScene() reads all of them.
  //    2. SSE physics bridge reconnects dynamically when session cookie changes
  //       (startCookieWatcher / buildSSEUrl).
  //    3. GPURenderLoop initialises full 7-pass chain:
  //       geometry → flowerParticle → splineParticle → waterSurface
  //       → volumetricLight → bloom → lut
  //    4. AT shaders loaded via applyATShaders() which replaces PBR
  //       metallic/roughness from AT_MATERIAL_PBR map, called immediately
  //       and again after a 500 ms shader-compile fence.
  //    5. Cookie watcher polls document.cookie every 2 s; on session change
  //       it closes the current EventSource and reopens with the new sid.
  //
  //  Canonical integration of all SPH subsystems through WorldOrchestrator
  //  (M759) as the single owner of WebGPU, physics, rendering, and audio.
  //
  //  Subsystem wiring:
  //    WorldOrchestrator ← owns WebGPU device, rAF loop, all physics + render
  //    ├─ ATRenderPipeline     (PBR → Particles → Water → VL → Bloom → LUT)
  //    ├─ ATSceneCompositor    (full AT mode: NS fluid, per-cell materials)
  //    ├─ CollisionWorld       (broad-phase BVH + narrow-phase SAT)
  //    ├─ SplineParticleLife   (CPU Catmull-Rom spline particles)
  //    ├─ PerformanceBudget    (4-tier adaptive quality: ULTRA/HIGH/MED/LOW)
  //    ├─ AdaptiveLOD          (per-cell distance/coverage/budget LOD tiers)
  //    └─ EnvironmentFx        (background atmosphere)
  //
  //  M904 additions:
  //    AstroPipeline ← WebGL2 cell render loop (FXScene → Nuke → BloomPass)
  //    ├─ AstroRenderer   (WebGL2 context owner)
  //    ├─ FXScene         (offscreen cell render-to-texture)
  //    ├─ Nuke            (post-process pipeline)
  //    ├─ BloomPass       (luminosity-threshold bloom)
  //    └─ CellInstanceManager (instanced per-species meshes)
  //
  //    physics-bridge ← WebWorker force/collision compute via comlink
  //    ├─ computeForces()      (async ForceField per cell bbox)
  //    ├─ detectCollisions()   (sweep-line overlap pairs)
  //    ├─ checkConvergence()   (|force| < eps gate)
  //    └─ terminatePhysicsWorker() (cleanup on unload)
  //
  //    composite_params ← per-scene composite config extracted from SSE params
  //    ├─ extractCompositeParams()  (parse lighting + post buckets)
  //    └─ CompositeParams           (contrast / rgbStrength / volumetric / DOF)
  //
  //  Epoch synchronisation:
  //    EpochVisualSync ← owns SSE connection, bridges backend epochs to visuals
  //    ├─ Species transition (Oklab lerp + SDF morph)
  //    ├─ Bbox morph (exponential easing)
  //    ├─ Convergence quality gate (draft → final ramp)
  //    ├─ Epoch timeline [0, 1] progress
  //    └─ Snapshot rollback
  //
  //  Entrance animation:
  //    OrganicGrowthAnimator ← scale bloom + fractal unfold + vein spread
  //
  //  Edge energy visualisation:
  //    EdgeEnergyFlow ← continuous particle fluid coating topology edges
  //
  //  Audio reactivity:
  //    AudioReactiveVisuals ← FFT → cell breath / particle speed / bloom
  // ═══════════════════════════════════════════════════════════════════════════

  import type { DebugRenderOptions } from '@/lib/sph/debug-renderer';
  import { renderDebugOverlay }      from '@/lib/sph/debug-renderer';
  import {
    ATRenderPipeline,
    type ATRenderPipelineConfig,
    type ATPassFlags,
  } from '@/lib/sph/at-render-pipeline';
  import {
    ATSceneCompositor,
    type ATSceneCompositorConfig,
  } from '@/lib/sph/at-scene-compositor';
  import type { FlowerEdgeSpline }   from '@/lib/sph/at-flower-particle';
  import type { EdgeSpline }         from '@/lib/sph/at-spline-particle';
  import { CollisionWorld }          from '@/lib/sph/collision/CollisionWorld';
  import {
    SplineParticleLife,
    type EdgeSplineData,
  } from '@/lib/sph/spline-particle-life';
  import {
    WorldOrchestrator,
    type WorldOrchestratorConfig,
    type OrchestratorStats,
  } from '@/lib/sph/world-orchestrator';
  import {
    PerformanceBudget,
    type Tier,
  } from '@/lib/sph/performance-budget';
  import {
    AdaptiveLOD,
    setGlobalLOD,
  } from '@/lib/sph/adaptive-lod';
  import {
    EpochVisualSync,
    type QualityState,
    type TimelineState,
  } from '@/lib/sph/epoch-visual-sync';
  import {
    OrganicGrowthAnimator,
    type GrowthConfig,
  } from '@/lib/sph/organic-growth-animator';
  import {
    PRESET_SCENES,
    type PresetScene,
  } from '@/lib/sph/world-preset-scenes';
  import {
    AstroPipeline,
    type AstroPipelineConfig,
  } from '@/lib/AstroPipeline';
  import {
    computeForces,
    detectCollisions,
    checkConvergence,
    terminatePhysicsWorker,
    type CellBBox,
    type ForceField,
    type OverlapPair,
  } from '@/lib/physics-bridge';
  import {
    extractCompositeParams,
    type CompositeParams,
  } from '@/lib/renderers/at-uil-bridge';
  import {
    GPURenderLoop,
    type CellData,
    type EdgeData,
  } from '@/lib/sph/gpu-render-loop';
  import { WorldRenderer } from '@/lib/sph/world-renderer';

  // ── QoS profiles ──────────────────────────────────────────────────────────
  const QOS_PROFILES = {
    low: {
      renderScale: 0.5,
      lutStrength: 0.4,
      passes: {
        geometry: true, flowerParticle: true, splineParticle: false,
        waterSurface: false, volumetricLight: false, bloom: false, lut: true,
      } satisfies ATPassFlags,
    },
    mid: {
      renderScale: 0.75,
      lutStrength: 0.7,
      passes: {
        geometry: true, flowerParticle: true, splineParticle: true,
        waterSurface: true, volumetricLight: false, bloom: true, lut: true,
      } satisfies ATPassFlags,
    },
    high: {
      renderScale: 1.0,
      lutStrength: 0.85,
      passes: {
        geometry: true, flowerParticle: true, splineParticle: true,
        waterSurface: true, volumetricLight: true, bloom: true, lut: true,
      } satisfies ATPassFlags,
    },
  };

  type QoSLevel = keyof typeof QOS_PROFILES;

  // ── M1272: Mouse interaction → physics bridge ───────────────────────────────
  // Wires pointer events on the #gpu-world canvas into the GPURenderLoop's
  // CellInteractionPhysics engine:
  //   • mousedown  → hit-test cell, dragStart
  //   • mousemove  → dragMove (while dragging)
  //   • mouseup    → dragEnd (releases with throw velocity)
  //   • dblclick   → inject (radial blast / shockwave)
  // Canvas-pixel coords are inverted into cell-pixel space via the loop's
  // auto-fit camera transform (scale/offX/offY) — the inverse of the
  // toNdc/fit transform used during rendering.
  function wireMouseInteraction(loop: GPURenderLoop, cvs: HTMLCanvasElement): () => void {
    // The render canvas is normally pointer-events:none (overlay); enable it so
    // it can receive pointer events for interaction.
    cvs.style.pointerEvents = 'auto';

    let dragging = false;

    // canvas client coords → cell-pixel space (inverse of auto-fit camera)
    function toCell(clientX: number, clientY: number): { x: number; y: number } {
      const rect = cvs.getBoundingClientRect();
      const canvasX = (clientX - rect.left) * (cvs.width / rect.width);
      const canvasY = (clientY - rect.top) * (cvs.height / rect.height);
      const { scale, offX, offY } = loop.cameraTransform;
      return {
        x: (canvasX - offX) / scale,
        y: (canvasY - offY) / scale,
      };
    }

    function onMouseDown(e: MouseEvent) {
      const physics = loop.interactionPhysics;
      if (!physics) return;
      const { x, y } = toCell(e.clientX, e.clientY);
      const hitId = physics.hitTest(x, y);
      if (hitId) {
        dragging = true;
        physics.dragStart(hitId, x, y);
        cvs.style.cursor = 'grabbing';
      }
    }

    function onMouseMove(e: MouseEvent) {
      if (!dragging) return;
      const physics = loop.interactionPhysics;
      if (!physics) return;
      const { x, y } = toCell(e.clientX, e.clientY);
      physics.dragMove(x, y);
    }

    function onMouseUp() {
      if (!dragging) return;
      dragging = false;
      cvs.style.cursor = 'default';
      loop.interactionPhysics?.dragEnd();
    }

    function onDblClick(e: MouseEvent) {
      const physics = loop.interactionPhysics;
      if (!physics) return;
      const { x, y } = toCell(e.clientX, e.clientY);
      physics.inject(x, y); // radial blast → explosion shockwave
    }

    cvs.addEventListener('mousedown', onMouseDown);
    // move/up bound on window so a drag continues even if the pointer leaves the canvas
    window.addEventListener('mousemove', onMouseMove);
    window.addEventListener('mouseup', onMouseUp);
    cvs.addEventListener('dblclick', onDblClick);

    // M1316: wheel zoom + right-click pan
    function onWheel(e: WheelEvent) {
      e.preventDefault();
      loop.applyZoom(e.deltaY, e.offsetX, e.offsetY);
    }
    let panning = false;
    let panLastX = 0, panLastY = 0;
    function onPanDown(e: MouseEvent) {
      if (e.button === 2 || e.button === 1) { // right or middle click
        panning = true;
        panLastX = e.clientX;
        panLastY = e.clientY;
        e.preventDefault();
      }
    }
    function onPanMove(e: MouseEvent) {
      if (!panning) return;
      loop.applyPan(e.clientX - panLastX, e.clientY - panLastY);
      panLastX = e.clientX;
      panLastY = e.clientY;
    }
    function onPanUp(e: MouseEvent) {
      if (e.button === 2 || e.button === 1) panning = false;
    }
    cvs.addEventListener('wheel', onWheel, { passive: false });
    cvs.addEventListener('mousedown', onPanDown);
    window.addEventListener('mousemove', onPanMove);
    window.addEventListener('mouseup', onPanUp);
    cvs.addEventListener('contextmenu', (e: Event) => e.preventDefault());

    console.info('[gpu-world] mouse interaction wired (drag / throw / inject)');

    return () => {
      cvs.removeEventListener('mousedown', onMouseDown);
      window.removeEventListener('mousemove', onMouseMove);
      window.removeEventListener('mouseup', onMouseUp);
      cvs.removeEventListener('dblclick', onDblClick);
      cvs.style.pointerEvents = 'none';
    };
