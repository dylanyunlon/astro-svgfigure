---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="SPH World">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #000;
      overflow: hidden;
      font-family: 'Courier New', Courier, monospace;
    }

    #world-root {
      position: relative;
      width: 100vw;
      height: 100vh;
    }

    #sph-canvas {
      display: block;
      width: 100%;
      height: 100%;
      background: #000;
    }

    /* HUD overlay */
    #hud {
      position: absolute;
      top: 16px;
      left: 16px;
      color: #00ff88;
      font-size: 13px;
      line-height: 1.8;
      pointer-events: none;
      text-shadow: 0 0 8px #00ff88;
      z-index: 10;
    }

    #hud .hud-row {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    #hud .hud-label {
      color: #888;
    }

    #hud .hud-value {
      color: #00ff88;
      min-width: 64px;
    }

    /* QoS controls */
    #qos-panel {
      position: absolute;
      top: 16px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      z-index: 10;
    }

    #qos-panel .qos-label {
      color: #888;
      font-size: 11px;
      text-align: right;
      font-family: 'Courier New', Courier, monospace;
    }

    #qos-panel .qos-btn-group {
      display: flex;
      gap: 6px;
    }

    .qos-btn {
      padding: 6px 12px;
      border: 1px solid #333;
      background: rgba(0, 0, 0, 0.6);
      color: #888;
      font-size: 12px;
      font-family: 'Courier New', Courier, monospace;
      cursor: pointer;
      border-radius: 3px;
      transition: all 0.15s ease;
    }

    .qos-btn:hover {
      border-color: #00ff88;
      color: #00ff88;
    }

    .qos-btn.active {
      border-color: #00ff88;
      color: #00ff88;
      background: rgba(0, 255, 136, 0.1);
      box-shadow: 0 0 6px rgba(0, 255, 136, 0.3);
    }

    /* Render mode toggle panel */
    #render-mode-panel {
      position: absolute;
      top: 64px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      z-index: 10;
    }

    /* SSE status dot */
    #sse-status {
      position: absolute;
      bottom: 16px;
      left: 16px;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      color: #555;
      z-index: 10;
      pointer-events: none;
    }

    #sse-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #333;
      transition: background 0.3s ease;
    }

    #sse-status.connected #sse-dot  { background: #00ff88; box-shadow: 0 0 5px #00ff8888; }
    #sse-status.offline   #sse-dot  { background: #ffa000; }
    #sse-status.error     #sse-dot  { background: #ff4444; }

    /* WebGPU fallback banner */
    #webgpu-fallback {
      display: none;
      position: absolute;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(255, 160, 0, 0.15);
      border: 1px solid #ffa000;
      color: #ffa000;
      padding: 10px 20px;
      border-radius: 4px;
      font-size: 13px;
      font-family: 'Courier New', Courier, monospace;
      text-align: center;
      z-index: 20;
      pointer-events: none;
    }

    #webgpu-fallback.visible {
      display: block;
    }

    /* Init overlay */
    #init-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000;
      color: #00ff88;
      font-size: 15px;
      font-family: 'Courier New', Courier, monospace;
      z-index: 30;
      transition: opacity 0.5s ease;
    }

    #init-overlay.hidden {
      opacity: 0;
      pointer-events: none;
    }

    .spinner {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 2px solid #00ff8844;
      border-top-color: #00ff88;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-right: 10px;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Debug overlay panel */
    #debug-panel {
      position: absolute;
      top: 140px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      z-index: 10;
      background: rgba(0, 0, 0, 0.55);
      border: 1px solid #222;
      border-radius: 4px;
      padding: 8px 12px;
      min-width: 148px;
    }

    #debug-panel .debug-label {
      color: #888;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      text-align: right;
      margin-bottom: 2px;
      letter-spacing: 0.05em;
    }

    .debug-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      cursor: pointer;
    }

    .debug-row label {
      color: #888;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      cursor: pointer;
      user-select: none;
      transition: color 0.15s ease;
    }

    .debug-row input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 14px;
      height: 14px;
      border: 1px solid #444;
      border-radius: 2px;
      background: rgba(0, 0, 0, 0.6);
      cursor: pointer;
      flex-shrink: 0;
      position: relative;
      transition: all 0.15s ease;
    }

    .debug-row input[type="checkbox"]:checked {
      background: rgba(0, 255, 136, 0.15);
      border-color: #00ff88;
    }

    .debug-row input[type="checkbox"]:checked::after {
      content: '';
      position: absolute;
      left: 3px;
      top: 1px;
      width: 5px;
      height: 8px;
      border: 1.5px solid #00ff88;
      border-top: none;
      border-left: none;
      transform: rotate(45deg);
    }

    .debug-row:hover label {
      color: #00ff88;
    }

    .debug-row input[type="checkbox"]:hover {
      border-color: #00ff88;
    }
  </style>

  <div id="world-root">
    <canvas id="sph-canvas"></canvas>

    <!-- HUD -->
    <div id="hud">
      <div class="hud-row">
        <span class="hud-label">PARTICLES</span>
        <span class="hud-value" id="hud-particles">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">FPS</span>
        <span class="hud-value" id="hud-fps">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">COLLISIONS</span>
        <span class="hud-value" id="hud-collisions">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">COL DEPTH</span>
        <span class="hud-value" id="hud-col-depth">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">COL PAIRS</span>
        <span class="hud-value" id="hud-col-pairs">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">PRESSURE IT.</span>
        <span class="hud-value" id="hud-pressure-iters">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">MEM</span>
        <span class="hud-value" id="hud-memory">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">BACKEND</span>
        <span class="hud-value" id="hud-backend">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">QoS</span>
        <span class="hud-value" id="hud-qos">HIGH</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">SIM</span>
        <span class="hud-value" id="hud-sim-time">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">RENDER</span>
        <span class="hud-value" id="hud-render-mode">SIMPLE</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">SPLINE FLOW</span>
        <span class="hud-value" id="hud-spline-flow">—</span>
      </div>
    </div>

    <!-- QoS panel -->
    <div id="qos-panel">
      <div class="qos-label">QUALITY</div>
      <div class="qos-btn-group">
        <button class="qos-btn" data-qos="low">LOW</button>
        <button class="qos-btn" data-qos="mid">MID</button>
        <button class="qos-btn active" data-qos="high">HIGH</button>
      </div>
    </div>

    <!-- Render mode toggle -->
    <div id="render-mode-panel">
      <div class="qos-label">RENDER MODE</div>
      <div class="qos-btn-group">
        <button class="qos-btn active" id="mode-simple">SIMPLE</button>
        <button class="qos-btn" id="mode-at">AT</button>
      </div>
    </div>

    <!-- Debug overlay panel -->
    <div id="debug-panel">
      <div class="debug-label">DEBUG</div>
      <div class="debug-row">
        <label for="dbg-aabbs">Show AABBs</label>
        <input type="checkbox" id="dbg-aabbs" />
      </div>
      <div class="debug-row">
        <label for="dbg-contacts">Show Contacts</label>
        <input type="checkbox" id="dbg-contacts" />
      </div>
      <div class="debug-row">
        <label for="dbg-bvh">Show BVH</label>
        <input type="checkbox" id="dbg-bvh" />
      </div>
      <div class="debug-row">
        <label for="dbg-emitters">Show Emitters</label>
        <input type="checkbox" id="dbg-emitters" />
      </div>
    </div>

    <!-- SSE connection status -->
    <div id="sse-status">
      <span id="sse-dot"></span>
      <span id="sse-label">SSE —</span>
    </div>

    <!-- WebGPU fallback notice -->
    <div id="webgpu-fallback">
      ⚠ WebGPU unavailable — running on Canvas2D fallback. Performance may be reduced.
    </div>

    <!-- Init overlay -->
    <div id="init-overlay">
      <span class="spinner"></span>
      Initializing SPH World…
    </div>
  </div>
</BaseLayout>

<script>
  import type { DebugRenderOptions } from '@/lib/sph/debug-renderer';
  import { renderDebugOverlay } from '@/lib/sph/debug-renderer';
  import {
    ATRenderPipeline,
    type ATRenderPipelineConfig,
    type ATPassFlags,
  } from '@/lib/sph/at-render-pipeline';
  import {
    ATSceneCompositor,
    type ATSceneCompositorConfig,
    type CellBBox,
    type SPHWorldView,
  } from '@/lib/sph/at-scene-compositor';
  import type { FlowerEdgeSpline } from '@/lib/sph/at-flower-particle';
  import type { EdgeSpline } from '@/lib/sph/at-spline-particle';
  import { CollisionWorld } from '@/lib/sph/collision/CollisionWorld';
  import {
    SplineParticleLife,
    type EdgeSplineData,
  } from '@/lib/sph/spline-particle-life';

  // ── QoS profiles ────────────────────────────────────────────────────────────
  // Maps QoS levels to AT pipeline configuration overrides.  The AT pipeline
  // itself is pass-based (PBR → Particles → Water → VolumetricLight → Bloom →
  // LUT), so QoS now controls which passes are enabled and LUT strength rather
  // than raw particle counts.
  const QOS_PROFILES = {
    low: {
      renderScale: 0.5,
      lutStrength: 0.4,
      passes: {
        geometry: true, flowerParticle: true, splineParticle: false,
        waterSurface: false, volumetricLight: false, bloom: false, lut: true,
      } satisfies ATPassFlags,
    },
    mid: {
      renderScale: 0.75,
      lutStrength: 0.7,
      passes: {
        geometry: true, flowerParticle: true, splineParticle: true,
        waterSurface: true, volumetricLight: false, bloom: true, lut: true,
      } satisfies ATPassFlags,
    },
    high: {
      renderScale: 1.0,
      lutStrength: 0.85,
      passes: {
        geometry: true, flowerParticle: true, splineParticle: true,
        waterSurface: true, volumetricLight: true, bloom: true, lut: true,
      } satisfies ATPassFlags,
    },
  };

  type QoSLevel = keyof typeof QOS_PROFILES;

  // ── DOM refs ─────────────────────────────────────────────────────────────────
  const canvas            = document.getElementById('sph-canvas')         as HTMLCanvasElement;
  const hudParticles      = document.getElementById('hud-particles')      as HTMLElement;
  const hudFps            = document.getElementById('hud-fps')            as HTMLElement;
  const hudCollisions     = document.getElementById('hud-collisions')     as HTMLElement;
  const hudColDepth       = document.getElementById('hud-col-depth')       as HTMLElement;
  const hudColPairs       = document.getElementById('hud-col-pairs')       as HTMLElement;
  const hudPressureIters  = document.getElementById('hud-pressure-iters') as HTMLElement;
  const hudMemory         = document.getElementById('hud-memory')         as HTMLElement;
  const hudBackend        = document.getElementById('hud-backend')        as HTMLElement;
  const hudQos            = document.getElementById('hud-qos')            as HTMLElement;
  const hudSimTime        = document.getElementById('hud-sim-time')       as HTMLElement;
  const hudRenderMode     = document.getElementById('hud-render-mode')    as HTMLElement;
  const hudSplineFlow     = document.getElementById('hud-spline-flow')    as HTMLElement;
  const fallbackBanner    = document.getElementById('webgpu-fallback')    as HTMLElement;
  const initOverlay       = document.getElementById('init-overlay')       as HTMLElement;
  const qosBtns           = document.querySelectorAll<HTMLButtonElement>('.qos-btn');
  const sseStatusEl       = document.getElementById('sse-status')         as HTMLElement;
  const sseLabelEl        = document.getElementById('sse-label')          as HTMLElement;
  const modeSimpleBtn     = document.getElementById('mode-simple')        as HTMLButtonElement;
  const modeATBtn         = document.getElementById('mode-at')            as HTMLButtonElement;

  // ── Debug overlay checkbox refs ───────────────────────────────────────────────
  const dbgAABBs    = document.getElementById('dbg-aabbs')    as HTMLInputElement;
  const dbgContacts = document.getElementById('dbg-contacts') as HTMLInputElement;
  const dbgBVH      = document.getElementById('dbg-bvh')      as HTMLInputElement;
  const dbgEmitters = document.getElementById('dbg-emitters') as HTMLInputElement;

  // ── Canvas sizing ────────────────────────────────────────────────────────────
  function resizeCanvas(renderScale: number) {
    canvas.width  = Math.floor(window.innerWidth  * renderScale * devicePixelRatio);
    canvas.height = Math.floor(window.innerHeight * renderScale * devicePixelRatio);
  }

  // ── WebGPU bootstrap ─────────────────────────────────────────────────────────
  // The AT render pipeline requires a raw GPUDevice + configured swap-chain.
  // Returns null when WebGPU is unavailable.

  async function initWebGPU(canvas: HTMLCanvasElement): Promise<{
    device:  GPUDevice;
    context: GPUCanvasContext;
    format:  GPUTextureFormat;
  } | null> {
    if (typeof navigator === 'undefined' || !('gpu' in navigator)) return null;
    try {
      const adapter = await (navigator as any).gpu.requestAdapter();
      if (!adapter) return null;
      const device: GPUDevice = await adapter.requestDevice();
      const context = canvas.getContext('webgpu') as GPUCanvasContext | null;
      if (!context) { device.destroy(); return null; }
      const format = navigator.gpu.getPreferredCanvasFormat();
      context.configure({ device, format, alphaMode: 'premultiplied' });
      return { device, context, format };
    } catch (_) {
      return null;
    }
  }

  // ── FPS meter ────────────────────────────────────────────────────────────────
  class FPSMeter {
    private samples: number[] = [];
    private last = performance.now();

    tick() {
      const now = performance.now();
      this.samples.push(1000 / (now - this.last));
      this.last = now;
      if (this.samples.length > 60) this.samples.shift();
    }

    get fps() {
      if (!this.samples.length) return 0;
      return this.samples.reduce((a, b) => a + b, 0) / this.samples.length;
    }
  }

  // ── SSE EventSource for /api/cell-events ────────────────────────────────────
  // Listens for `physics_step` events from the Python backend (proxied through
  // the Astro SSE route) and updates the HUD sim-time counter.

  const SSE_URL = '/api/cell-events';
  const SSE_BACKOFF_INITIAL_MS = 1_000;
  const SSE_BACKOFF_MAX_MS     = 30_000;
  const SSE_ERROR_THRESHOLD    = 3;

  let _es: EventSource | null = null;
  let _sseErrorCount  = 0;
  let _sseBackoffMs   = SSE_BACKOFF_INITIAL_MS;
  let _sseReconnTimer: ReturnType<typeof setTimeout> | null = null;

  function setSseStatus(state: 'connected' | 'offline' | 'error', label: string) {
    sseStatusEl.className = state;
    sseLabelEl.textContent = `SSE ${label}`;
  }

  function openSSE() {
    if (typeof EventSource === 'undefined') {
      setSseStatus('offline', 'unavailable');
      return;
    }

    const es = new EventSource(SSE_URL);
    _es = es;

    // ── physics_step: SPH backend tick telemetry ──────────────────────────
    es.addEventListener('physics_step', (ev: MessageEvent) => {
      try {
        const d = JSON.parse(ev.data) as {
          step?: number;
          particle_count?: number;
          kinetic_energy?: number;
          sim_time_ms?: number;
          qos?: string;
          offline?: boolean;
        };

        if (d.offline) {
          setSseStatus('offline', 'backend offline');
          return;
        }

        // Update HUD sim time
        if (d.sim_time_ms !== undefined) {
          hudSimTime.textContent = `${d.sim_time_ms.toFixed(1)} ms`;
        }

        // If backend reports a QoS level that differs from local, reflect it
        if (d.qos && d.qos !== currentQoS) {
          const normalized = d.qos.toLowerCase() as QoSLevel;
          if (normalized in QOS_PROFILES) {
            hudQos.textContent = normalized.toUpperCase();
            qosBtns.forEach(btn => {
              btn.classList.toggle('active', btn.dataset.qos === normalized);
            });
          }
        }
      } catch (e) {
        console.warn('[world SSE] physics_step parse error:', e);
      }
    });

    // ── cell_update: propagated from Apollo DataNotifier ─────────────────
    es.addEventListener('cell_update', (ev: MessageEvent) => {
      try {
        const d = JSON.parse(ev.data) as { cell_id: string; params: unknown };
        console.debug('[world SSE] cell_update', d.cell_id);
      } catch (e) {
        console.warn('[world SSE] cell_update parse error:', e);
      }
    });

    es.onopen = () => {
      _sseErrorCount = 0;
      _sseBackoffMs  = SSE_BACKOFF_INITIAL_MS;
      setSseStatus('connected', 'connected');
    };

    es.onerror = () => {
      _sseErrorCount++;
      setSseStatus('error', `error #${_sseErrorCount}`);

      if (_sseErrorCount >= SSE_ERROR_THRESHOLD) {
        es.close();
        _es = null;
        const delay = Math.min(_sseBackoffMs, SSE_BACKOFF_MAX_MS);
        console.warn(`[world SSE] reconnecting in ${delay}ms`);
        _sseReconnTimer = setTimeout(() => {
          _sseBackoffMs = Math.min(_sseBackoffMs * 2, SSE_BACKOFF_MAX_MS);
          openSSE();
        }, delay);
      }
    };
  }

  function closeSSE() {
    if (_sseReconnTimer) { clearTimeout(_sseReconnTimer); _sseReconnTimer = null; }
    if (_es) { _es.close(); _es = null; }
  }

  // ── QoS POST to /api/physics/qos ─────────────────────────────────────────────
  async function postQoSToBackend(level: QoSLevel): Promise<void> {
    try {
      const res = await fetch('/api/physics/qos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ level }),
      });
      const data = await res.json();
      if (data.offline) {
        console.info('[world QoS] backend offline — QoS applied client-side only.', data);
      } else if (!res.ok) {
        console.warn('[world QoS] backend rejected QoS change:', data);
      } else {
        console.info('[world QoS] backend acknowledged:', data);
      }
    } catch (err) {
      console.warn('[world QoS] POST /api/physics/qos failed (network):', err);
    }
  }

  // ── Topology edge fetcher ───────────────────────────────────────────────────
  // Fetches /api/cells, derives FlowerEdgeSpline[] and EdgeSpline[] for the AT
  // render pipeline's particle passes.  Errors are non-fatal: the world renders
  // without topology-driven particles (static PBR + water + post-process only).

  interface TopologyEdges {
    flowerEdges: FlowerEdgeSpline[];
    splineEdges: EdgeSpline[];
  }

  async function fetchTopologyEdges(): Promise<TopologyEdges> {
    const empty: TopologyEdges = { flowerEdges: [], splineEdges: [] };
    try {
      const res = await fetch('/api/cells');
      if (!res.ok) {
        console.warn('[world] /api/cells responded', res.status, '— skipping topology edges');
        return empty;
      }

      const data = await res.json();

      const rawCells: any[] = Array.isArray(data) ? data : (data.cells ?? []);
      const rawEdges: any[] = Array.isArray(data) ? [] : (data.edges ?? []);

      if (rawCells.length === 0 || rawEdges.length === 0) {
        console.info('[world] /api/cells returned no cells/edges — skipping topology');
        return empty;
      }

      // Build a lookup: cellId → normalised centre { x, y } in [0,1] domain
      const cellMap = new Map<string, { x: number; y: number }>();
      const cw = window.innerWidth  || 1280;
      const ch = window.innerHeight || 720;

      for (const c of rawCells) {
        const id = c.cell_id ?? c.id ?? String(c);
        let x = 0.5, y = 0.5;
        if (c.bbox) {
          if (typeof c.bbox.x === 'number' && typeof c.bbox.w === 'number') {
            x = (c.bbox.x + c.bbox.w / 2) / cw;
            y = (c.bbox.y + c.bbox.h / 2) / ch;
          } else if (Array.isArray(c.bbox.min) && Array.isArray(c.bbox.max)) {
            x = (c.bbox.min[0] + c.bbox.max[0]) / 2 / cw;
            y = (c.bbox.min[1] + c.bbox.max[1]) / 2 / ch;
          }
        }
        cellMap.set(id, { x, y });
      }

      // Convert raw edges to FlowerEdgeSpline[] + EdgeSpline[]
      // Each edge becomes a Catmull-Rom spline with 4 control points:
      //   [sourceExtend, source, target, targetExtend]
      // The extend points are extrapolated along the edge direction for smooth
      // Catmull-Rom tangent continuity at the endpoints.
      const flowerEdges: FlowerEdgeSpline[] = [];
      const splineEdges: EdgeSpline[] = [];

      for (const e of rawEdges) {
        const sourceId = e.sources?.[0] ?? e.source ?? '';
        const targetId = e.targets?.[0] ?? e.target ?? '';
        if (!sourceId || !targetId) continue;

        const src = cellMap.get(sourceId);
        const tgt = cellMap.get(targetId);
        if (!src || !tgt) continue;

        const edgeId = `${sourceId}->${targetId}`;
        const weight = e.weight ?? 1.0;
        const species = e.species ?? 0;

        // Direction vector source→target
        const dx = tgt.x - src.x;
        const dy = tgt.y - src.y;

        // Catmull-Rom phantom control points (extend ~25% beyond each end)
        const ext = 0.25;
        const points = [
          { x: src.x - dx * ext, y: src.y - dy * ext, z: 0 },
          { x: src.x,            y: src.y,             z: 0 },
          { x: tgt.x,            y: tgt.y,             z: 0 },
          { x: tgt.x + dx * ext, y: tgt.y + dy * ext,  z: 0 },
        ];

        flowerEdges.push({ edgeId, sourceId, targetId, points, weight, species });
        splineEdges.push({ edgeId, sourceId, targetId, points, weight, species });
      }

      console.info(`[world] topology edges: ${flowerEdges.length} flower + ${splineEdges.length} spline`);
      return { flowerEdges, splineEdges };
    } catch (err) {
      console.warn('[world] fetchTopologyEdges failed:', err);
      return empty;
    }
  }

  // ── Main ─────────────────────────────────────────────────────────────────────
  (async () => {
    let currentQoS: QoSLevel = 'high';
    let pipeline: ATRenderPipeline | null = null;
    let compositor: ATSceneCompositor | null = null;
    let renderMode: 'simple' | 'at' = 'simple';
    let gpuDevice:  GPUDevice | null = null;
    let gpuContext: GPUCanvasContext | null = null;
    let gpuFormat:  GPUTextureFormat = 'bgra8unorm';
    const meter = new FPSMeter();

    // ── WebGPU init ─────────────────────────────────────────────────────────
    const profile = QOS_PROFILES[currentQoS];
    resizeCanvas(profile.renderScale);

    const gpu = await initWebGPU(canvas);
    if (!gpu) {
      hudBackend.textContent = 'NONE';
      fallbackBanner.classList.add('visible');
      initOverlay.textContent = 'WebGPU unavailable — AT render pipeline requires WebGPU.';
      return;
    }

    gpuDevice  = gpu.device;
    gpuContext = gpu.context;
    gpuFormat  = gpu.format;
    hudBackend.textContent = 'WEBGPU';

    // Open SSE connection for physics_step + cell_update events
    setSseStatus('offline', 'connecting…');
    openSSE();

    // ── Fetch topology edges from /api/cells ────────────────────────────────
    const { flowerEdges, splineEdges } = await fetchTopologyEdges();

    // ── Initialise AT Render Pipeline (Simple mode) ─────────────────────────
    // The real AT pipeline chains 6 forward passes: PBR geometry → flower
    // particles → spline particles → water surface → volumetric light → bloom
    // → LUT colour-grade.  It replaces the old SPHWorld / ParticleRenderer.
    try {
      pipeline = await ATRenderPipeline.create(
        gpuDevice,
        canvas,
        flowerEdges,
        splineEdges,
        {
          format:      gpuFormat,
          lutStyle:    'DEEP_OCEAN',
          lutStrength: profile.lutStrength,
          passes:      profile.passes,
        },
      );
    } catch (err) {
      console.error('[world] ATRenderPipeline.create failed:', err);
      initOverlay.textContent = `Init error: ${(err as Error).message}`;
      return;
    }

    // ── Initialise ATSceneCompositor (AT mode) ──────────────────────────────
    // The ATSceneCompositor is the M730 full-pipeline compositor that wires
    // PBR materials, particles, water, Navier-Stokes fluid, volumetric light,
    // bloom, and particle depth-sort into a single per-frame tick.
    try {
      compositor = new ATSceneCompositor();
      await compositor.init(gpuDevice, canvas, {
        format:      gpuFormat,
        flowerEdges,
        splineEdges,
      } as ATSceneCompositorConfig);

      // Register demo cells so the compositor has something to render.
      // Use viewport-relative bounding boxes to place them across the scene.
      const vw = canvas.width;
      const vh = canvas.height;
      await compositor.addCell('cell-0', 'attention', { x: 0,        y: 0,        w: vw * 0.5, h: vh * 0.5 });
      await compositor.addCell('cell-1', 'ffn',       { x: vw * 0.5, y: 0,        w: vw * 0.5, h: vh * 0.5 });
      await compositor.addCell('cell-2', 'embedding',  { x: 0,        y: vh * 0.5, w: vw * 0.5, h: vh * 0.5 });
      await compositor.addCell('cell-3', 'softmax',    { x: vw * 0.5, y: vh * 0.5, w: vw * 0.5, h: vh * 0.5 });

      console.info('[world] ATSceneCompositor initialised with', compositor.cellCount, 'cells');
    } catch (err) {
      console.warn('[world] ATSceneCompositor init failed — AT mode unavailable:', err);
      compositor = null;
      // Disable AT mode button if compositor failed
      modeATBtn.style.opacity = '0.3';
      modeATBtn.style.pointerEvents = 'none';
      modeATBtn.title = 'ATSceneCompositor unavailable';
    }

    // Hide init overlay
    initOverlay.classList.add('hidden');

    // ── SplineParticleLife (CPU particle flow along topology edges) ────────────
    // Convert fetched splineEdges (EdgeSpline[]) to EdgeSplineData[] for the CPU
    // SplineParticleLife system.  Each edge spawns particles that flow along its
    // Catmull-Rom spline with curl-noise perturbation, modelling data-flow
    // between cells in the transformer topology.
    const edgeSplineData: EdgeSplineData[] = splineEdges.map(e => ({
      edgeId:   e.edgeId,
      sourceId: e.sourceId,
      targetId: e.targetId,
      points:   e.points,
      weight:   e.weight,
    }));

    const splineParticleLife = new SplineParticleLife(edgeSplineData, {
      uSplineSpeed:    [0.82, 1.21],
      uTimeMultiplier: 0.17,
      uCurlStrength:   0.04,
      uCurlNoiseScale: 2.0,
      uCurlNoiseSpeed: 5.0,
      uDecayRate:      0.6,
      particlesPerUnit: 24,
      onHandoff: (edgeId, targetId, x, y, vx, vy, species) => {
        console.debug(
          `[world SPL] handoff edge=${edgeId} → cell=${targetId}`,
          `pos=(${x.toFixed(3)},${y.toFixed(3)})`,
          `vel=(${vx.toFixed(3)},${vy.toFixed(3)})`,
          `species=${species}`,
        );
      },
    });

    console.info(
      `[world] SplineParticleLife created: ${edgeSplineData.length} edges,`,
      `${splineParticleLife.totalCount} particles`,
    );

    // ── Collision world (stepped per-frame for HUD telemetry) ──────────────────
    const collisionWorld = new CollisionWorld();

    // ── Render loop ────────────────────────────────────────────────────────────
    let rafId: number;
    let lastTime = performance.now();
    let frameCount = 0;

    function loop() {
      if (!gpuDevice || !gpuContext) return;

      const now = performance.now();
      const dt  = Math.min((now - lastTime) / 1000, 0.05); // cap dt at 50ms
      lastTime  = now;
      frameCount++;

      if (renderMode === 'at' && compositor && compositor.isInitialised) {
        // ── AT Scene Compositor path ──────────────────────────────────────
        // The compositor owns its own canvas context and swap-chain, so we
        // call tick() which handles everything: physics modulation, NS fluid,
        // particle compute, cell materials, water, volumetric light, bloom,
        // and final present to canvas.
        compositor.tick(dt, null);
      } else if (pipeline) {
        // ── Simple ATRenderPipeline path ──────────────────────────────────
        pipeline.tick(dt);

        const swapChainTexture = gpuContext.getCurrentTexture();
        const dstView = swapChainTexture.createView();
        const encoder = gpuDevice.createCommandEncoder({ label: 'world-frame' });

        pipeline.render(encoder, dstView);

        gpuDevice.queue.submit([encoder.finish()]);
      }

      meter.tick();

      // ── SplineParticleLife update (CPU particle flow along edges) ──────────
      splineParticleLife.update(dt);

      // ── Debug overlay (2D canvas drawn over WebGPU surface) ───────────────
      const anyDebugActive =
        dbgAABBs.checked || dbgContacts.checked || dbgBVH.checked || dbgEmitters.checked;

      if (anyDebugActive) {
        const dbgCanvas = document.createElement('canvas');
        dbgCanvas.width  = canvas.width;
        dbgCanvas.height = canvas.height;
        const ctx2d = dbgCanvas.getContext('2d');
        if (ctx2d) {
          const debugOptions: DebugRenderOptions = {
            showAABBs:          dbgAABBs.checked,
            showContacts:       dbgContacts.checked,
            showContactNormals: dbgContacts.checked,
            showPenetration:    false,
            showBVH:            dbgBVH.checked,
            showEmitters:       dbgEmitters.checked,
            showStats:          false,
          };
          const physicsWorld = { bodies: new Map(), emitters: [] };
          renderDebugOverlay(ctx2d, physicsWorld, [], [], [], debugOptions);
        }
      }

      // ── HUD updates ──────────────────────────────────────────────────────
      // Step collision world and export results for HUD
      collisionWorld.step(dt);
      const colData = collisionWorld.exportCollisions();

      hudParticles.textContent     = String(flowerEdges.length + splineEdges.length);
      hudFps.textContent           = meter.fps.toFixed(1);
      hudCollisions.textContent    = String(colData.count);
      hudPressureIters.textContent = String(frameCount % 1000);
      hudSplineFlow.textContent    = `${splineParticleLife.activeCount}/${splineParticleLife.totalCount}`;

      // Collision detail: max penetration depth + body pair summary
      if (colData.count > 0) {
        const maxDepth = colData.collisions.reduce((m, c) => Math.max(m, c.depth), 0);
        hudColDepth.textContent = maxDepth.toFixed(4);
        const pairStrs = colData.collisions
          .slice(0, 3)
          .map(c => `${c.bodyA}↔${c.bodyB}`);
        hudColPairs.textContent = pairStrs.join(' ') + (colData.count > 3 ? ' …' : '');
      } else {
        hudColDepth.textContent = '—';
        hudColPairs.textContent = '—';
      }

      // Memory (Chrome Performance Memory API)
      const perf = performance as any;
      if (perf.memory?.usedJSHeapSize !== undefined) {
        const mb = perf.memory.usedJSHeapSize / 1_048_576;
        hudMemory.textContent = `${mb.toFixed(1)} MB`;
      } else {
        hudMemory.textContent = '—';
      }

      rafId = requestAnimationFrame(loop);
    }
    rafId = requestAnimationFrame(loop);

    // ── Render mode switching ──────────────────────────────────────────────────
    function applyRenderMode(mode: 'simple' | 'at') {
      if (mode === renderMode) return;

      // AT mode requires a working compositor
      if (mode === 'at' && (!compositor || !compositor.isInitialised)) {
        console.warn('[world] Cannot switch to AT mode — compositor unavailable');
        return;
      }

      renderMode = mode;
      hudRenderMode.textContent = mode.toUpperCase();
      modeSimpleBtn.classList.toggle('active', mode === 'simple');
      modeATBtn.classList.toggle('active', mode === 'at');

      // When switching to AT mode, reconfigure the compositor's canvas context
      // since the simple pipeline may have left it in a different state.
      if (mode === 'at' && compositor) {
        compositor.resize(canvas.width, canvas.height);
      }

      console.info(`[world] render mode → ${mode.toUpperCase()}`);
    }

    modeSimpleBtn.addEventListener('click', () => applyRenderMode('simple'));
    modeATBtn.addEventListener('click', () => applyRenderMode('at'));

    // ── QoS switching ──────────────────────────────────────────────────────────
    function applyQoS(level: QoSLevel) {
      if (level === currentQoS || !pipeline) return;
      currentQoS = level;

      // Update button states and HUD immediately (optimistic UI)
      qosBtns.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.qos === level);
      });
      hudQos.textContent = level.toUpperCase();

      // POST the new level to the backend (fire-and-forget)
      postQoSToBackend(level);

      // Reconfigure the live pipeline — no teardown/rebuild needed; the AT
      // pipeline supports hot-swapping pass flags and LUT strength.
      const p = QOS_PROFILES[level];
      pipeline.setPassFlags(p.passes);
      pipeline.setLutStrength(p.lutStrength);

      // Resize canvas for the new render scale
      resizeCanvas(p.renderScale);
      pipeline.resize(canvas.width, canvas.height);

      // Also resize compositor if it exists
      if (compositor && compositor.isInitialised) {
        compositor.resize(canvas.width, canvas.height);
      }
    }

    qosBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        applyQoS(btn.dataset.qos as QoSLevel);
      });
    });

    // ── Resize observer ────────────────────────────────────────────────────────
    const resizeObserver = new ResizeObserver(() => {
      resizeCanvas(QOS_PROFILES[currentQoS].renderScale);
      pipeline?.resize(canvas.width, canvas.height);
      if (compositor && compositor.isInitialised) {
        compositor.resize(canvas.width, canvas.height);
      }
    });
    resizeObserver.observe(canvas);

    // ── Cleanup on page unload ─────────────────────────────────────────────────
    window.addEventListener('beforeunload', () => {
      closeSSE();
      cancelAnimationFrame(rafId);
      compositor?.destroy();
      pipeline?.destroy();
      gpuDevice?.destroy();
    });
  })();
</script>
