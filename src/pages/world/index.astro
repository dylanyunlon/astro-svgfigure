---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="SPH World">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #000;
      overflow: hidden;
      font-family: 'Courier New', Courier, monospace;
    }

    #world-root {
      position: relative;
      width: 100vw;
      height: 100vh;
    }

    #sph-canvas {
      display: block;
      width: 100%;
      height: 100%;
      background: #000;
    }

    /* HUD overlay */
    #hud {
      position: absolute;
      top: 16px;
      left: 16px;
      color: #00ff88;
      font-size: 13px;
      line-height: 1.8;
      pointer-events: none;
      text-shadow: 0 0 8px #00ff88;
      z-index: 10;
    }

    #hud .hud-row {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    #hud .hud-label {
      color: #888;
    }

    #hud .hud-value {
      color: #00ff88;
      min-width: 64px;
    }

    /* QoS controls */
    #qos-panel {
      position: absolute;
      top: 16px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      z-index: 10;
    }

    #qos-panel .qos-label {
      color: #888;
      font-size: 11px;
      text-align: right;
      font-family: 'Courier New', Courier, monospace;
    }

    #qos-panel .qos-btn-group {
      display: flex;
      gap: 6px;
    }

    .qos-btn {
      padding: 6px 12px;
      border: 1px solid #333;
      background: rgba(0, 0, 0, 0.6);
      color: #888;
      font-size: 12px;
      font-family: 'Courier New', Courier, monospace;
      cursor: pointer;
      border-radius: 3px;
      transition: all 0.15s ease;
    }

    .qos-btn:hover {
      border-color: #00ff88;
      color: #00ff88;
    }

    .qos-btn.active {
      border-color: #00ff88;
      color: #00ff88;
      background: rgba(0, 255, 136, 0.1);
      box-shadow: 0 0 6px rgba(0, 255, 136, 0.3);
    }

    /* SSE status dot */
    #sse-status {
      position: absolute;
      bottom: 16px;
      left: 16px;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      color: #555;
      z-index: 10;
      pointer-events: none;
    }

    #sse-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #333;
      transition: background 0.3s ease;
    }

    #sse-status.connected #sse-dot  { background: #00ff88; box-shadow: 0 0 5px #00ff8888; }
    #sse-status.offline   #sse-dot  { background: #ffa000; }
    #sse-status.error     #sse-dot  { background: #ff4444; }

    /* WebGPU fallback banner */
    #webgpu-fallback {
      display: none;
      position: absolute;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(255, 160, 0, 0.15);
      border: 1px solid #ffa000;
      color: #ffa000;
      padding: 10px 20px;
      border-radius: 4px;
      font-size: 13px;
      font-family: 'Courier New', Courier, monospace;
      text-align: center;
      z-index: 20;
      pointer-events: none;
    }

    #webgpu-fallback.visible {
      display: block;
    }

    /* Init overlay */
    #init-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000;
      color: #00ff88;
      font-size: 15px;
      font-family: 'Courier New', Courier, monospace;
      z-index: 30;
      transition: opacity 0.5s ease;
    }

    #init-overlay.hidden {
      opacity: 0;
      pointer-events: none;
    }

    .spinner {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 2px solid #00ff8844;
      border-top-color: #00ff88;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-right: 10px;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Debug overlay panel */
    #debug-panel {
      position: absolute;
      top: 90px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      z-index: 10;
      background: rgba(0, 0, 0, 0.55);
      border: 1px solid #222;
      border-radius: 4px;
      padding: 8px 12px;
      min-width: 148px;
    }

    #debug-panel .debug-label {
      color: #888;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      text-align: right;
      margin-bottom: 2px;
      letter-spacing: 0.05em;
    }

    .debug-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      cursor: pointer;
    }

    .debug-row label {
      color: #888;
      font-size: 11px;
      font-family: 'Courier New', Courier, monospace;
      cursor: pointer;
      user-select: none;
      transition: color 0.15s ease;
    }

    .debug-row input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 14px;
      height: 14px;
      border: 1px solid #444;
      border-radius: 2px;
      background: rgba(0, 0, 0, 0.6);
      cursor: pointer;
      flex-shrink: 0;
      position: relative;
      transition: all 0.15s ease;
    }

    .debug-row input[type="checkbox"]:checked {
      background: rgba(0, 255, 136, 0.15);
      border-color: #00ff88;
    }

    .debug-row input[type="checkbox"]:checked::after {
      content: '';
      position: absolute;
      left: 3px;
      top: 1px;
      width: 5px;
      height: 8px;
      border: 1.5px solid #00ff88;
      border-top: none;
      border-left: none;
      transform: rotate(45deg);
    }

    .debug-row:hover label {
      color: #00ff88;
    }

    .debug-row input[type="checkbox"]:hover {
      border-color: #00ff88;
    }
  </style>

  <div id="world-root">
    <canvas id="sph-canvas"></canvas>

    <!-- HUD -->
    <div id="hud">
      <div class="hud-row">
        <span class="hud-label">PARTICLES</span>
        <span class="hud-value" id="hud-particles">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">FPS</span>
        <span class="hud-value" id="hud-fps">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">BACKEND</span>
        <span class="hud-value" id="hud-backend">—</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">QoS</span>
        <span class="hud-value" id="hud-qos">HIGH</span>
      </div>
      <div class="hud-row">
        <span class="hud-label">SIM</span>
        <span class="hud-value" id="hud-sim-time">—</span>
      </div>
    </div>

    <!-- QoS panel -->
    <div id="qos-panel">
      <div class="qos-label">QUALITY</div>
      <div class="qos-btn-group">
        <button class="qos-btn" data-qos="low">LOW</button>
        <button class="qos-btn" data-qos="mid">MID</button>
        <button class="qos-btn active" data-qos="high">HIGH</button>
      </div>
    </div>

    <!-- Debug overlay panel -->
    <div id="debug-panel">
      <div class="debug-label">DEBUG</div>
      <div class="debug-row">
        <label for="dbg-aabbs">Show AABBs</label>
        <input type="checkbox" id="dbg-aabbs" />
      </div>
      <div class="debug-row">
        <label for="dbg-contacts">Show Contacts</label>
        <input type="checkbox" id="dbg-contacts" />
      </div>
      <div class="debug-row">
        <label for="dbg-bvh">Show BVH</label>
        <input type="checkbox" id="dbg-bvh" />
      </div>
      <div class="debug-row">
        <label for="dbg-emitters">Show Emitters</label>
        <input type="checkbox" id="dbg-emitters" />
      </div>
    </div>

    <!-- SSE connection status -->
    <div id="sse-status">
      <span id="sse-dot"></span>
      <span id="sse-label">SSE —</span>
    </div>

    <!-- WebGPU fallback notice -->
    <div id="webgpu-fallback">
      ⚠ WebGPU unavailable — running on WebGL2 fallback. Performance may be reduced.
    </div>

    <!-- Init overlay -->
    <div id="init-overlay">
      <span class="spinner"></span>
      Initializing SPH World…
    </div>
  </div>
</BaseLayout>

<script>
  import type { DebugRenderOptions } from '@/lib/sph/debug-renderer';
  import { renderDebugOverlay } from '@/lib/sph/debug-renderer';
  import { createEdgeEmitters } from '@/lib/sph/emitter-strategy';
  import type { EmitterConfig } from '@/lib/sph/emitter-strategy';

  // ── QoS profiles ────────────────────────────────────────────────────────────
  const QOS_PROFILES = {
    low:  { particleCount: 4_096,  substeps: 1, smoothingRadius: 0.08, renderScale: 0.5  },
    mid:  { particleCount: 16_384, substeps: 2, smoothingRadius: 0.05, renderScale: 0.75 },
    high: { particleCount: 65_536, substeps: 4, smoothingRadius: 0.03, renderScale: 1.0  },
  };

  type QoSLevel = keyof typeof QOS_PROFILES;

  // ── SPHWorld import ──────────────────────────────────────────────────────────
  // Dynamic import so the heavy GPU module is only loaded client-side.
  // Path is resolved via the @/lib/* alias defined in tsconfig.json.
  async function loadSPHWorld() {
    const mod = await import('@/lib/sph/SPHWorld');
    return mod.SPHWorld ?? mod.default;
  }

  // ── DOM refs ─────────────────────────────────────────────────────────────────
  const canvas        = document.getElementById('sph-canvas')     as HTMLCanvasElement;
  const hud           = document.getElementById('hud')            as HTMLElement;
  const hudParticles  = document.getElementById('hud-particles')  as HTMLElement;
  const hudFps        = document.getElementById('hud-fps')        as HTMLElement;
  const hudBackend    = document.getElementById('hud-backend')    as HTMLElement;
  const hudQos        = document.getElementById('hud-qos')        as HTMLElement;
  const hudSimTime    = document.getElementById('hud-sim-time')   as HTMLElement;
  const fallbackBanner= document.getElementById('webgpu-fallback')as HTMLElement;
  const initOverlay   = document.getElementById('init-overlay')   as HTMLElement;
  const qosBtns       = document.querySelectorAll<HTMLButtonElement>('.qos-btn');
  const sseStatusEl   = document.getElementById('sse-status')     as HTMLElement;
  const sseLabelEl    = document.getElementById('sse-label')      as HTMLElement;

  // ── Debug overlay checkbox refs ───────────────────────────────────────────────
  const dbgAABBs    = document.getElementById('dbg-aabbs')    as HTMLInputElement;
  const dbgContacts = document.getElementById('dbg-contacts') as HTMLInputElement;
  const dbgBVH      = document.getElementById('dbg-bvh')      as HTMLInputElement;
  const dbgEmitters = document.getElementById('dbg-emitters') as HTMLInputElement;

  // ── Canvas sizing ────────────────────────────────────────────────────────────
  function resizeCanvas(renderScale: number) {
    canvas.width  = Math.floor(window.innerWidth  * renderScale * devicePixelRatio);
    canvas.height = Math.floor(window.innerHeight * renderScale * devicePixelRatio);
  }

  // ── WebGPU detection ─────────────────────────────────────────────────────────
  async function detectBackend(): Promise<'webgpu' | 'webgl2'> {
    if (typeof navigator !== 'undefined' && 'gpu' in navigator) {
      try {
        const adapter = await (navigator as any).gpu.requestAdapter();
        if (adapter) return 'webgpu';
      } catch (_) { /* fall through */ }
    }
    return 'webgl2';
  }

  // ── FPS meter ────────────────────────────────────────────────────────────────
  class FPSMeter {
    private samples: number[] = [];
    private last = performance.now();

    tick() {
      const now = performance.now();
      this.samples.push(1000 / (now - this.last));
      this.last = now;
      if (this.samples.length > 60) this.samples.shift();
    }

    get fps() {
      if (!this.samples.length) return 0;
      return this.samples.reduce((a, b) => a + b, 0) / this.samples.length;
    }
  }

  // ── SSE EventSource for /api/cell-events ────────────────────────────────────
  // Listens for `physics_step` events from the Python backend (proxied through
  // the Astro SSE route) and updates the HUD sim-time counter.

  const SSE_URL = '/api/cell-events';
  const SSE_BACKOFF_INITIAL_MS = 1_000;
  const SSE_BACKOFF_MAX_MS     = 30_000;
  const SSE_ERROR_THRESHOLD    = 3;

  let _es: EventSource | null = null;
  let _sseErrorCount  = 0;
  let _sseBackoffMs   = SSE_BACKOFF_INITIAL_MS;
  let _sseReconnTimer: ReturnType<typeof setTimeout> | null = null;

  function setSseStatus(state: 'connected' | 'offline' | 'error', label: string) {
    sseStatusEl.className = state;
    sseLabelEl.textContent = `SSE ${label}`;
  }

  function openSSE() {
    if (typeof EventSource === 'undefined') {
      setSseStatus('offline', 'unavailable');
      return;
    }

    const es = new EventSource(SSE_URL);
    _es = es;

    // ── physics_step: SPH backend tick telemetry ──────────────────────────
    es.addEventListener('physics_step', (ev: MessageEvent) => {
      try {
        const d = JSON.parse(ev.data) as {
          step?: number;
          particle_count?: number;
          kinetic_energy?: number;
          sim_time_ms?: number;
          qos?: string;
          offline?: boolean;
        };

        if (d.offline) {
          setSseStatus('offline', 'backend offline');
          return;
        }

        // Update HUD sim time
        if (d.sim_time_ms !== undefined) {
          hudSimTime.textContent = `${d.sim_time_ms.toFixed(1)} ms`;
        }

        // If backend reports a QoS level that differs from local, reflect it
        if (d.qos && d.qos !== currentQoS) {
          const normalized = d.qos.toLowerCase() as QoSLevel;
          if (normalized in QOS_PROFILES) {
            hudQos.textContent = normalized.toUpperCase();
            qosBtns.forEach(btn => {
              btn.classList.toggle('active', btn.dataset.qos === normalized);
            });
          }
        }
      } catch (e) {
        console.warn('[world SSE] physics_step parse error:', e);
      }
    });

    // ── cell_update: propagated from Apollo DataNotifier ─────────────────
    es.addEventListener('cell_update', (ev: MessageEvent) => {
      try {
        const d = JSON.parse(ev.data) as { cell_id: string; params: unknown };
        console.debug('[world SSE] cell_update', d.cell_id);
      } catch (e) {
        console.warn('[world SSE] cell_update parse error:', e);
      }
    });

    es.onopen = () => {
      _sseErrorCount = 0;
      _sseBackoffMs  = SSE_BACKOFF_INITIAL_MS;
      setSseStatus('connected', 'connected');
    };

    es.onerror = () => {
      _sseErrorCount++;
      setSseStatus('error', `error #${_sseErrorCount}`);

      if (_sseErrorCount >= SSE_ERROR_THRESHOLD) {
        // Take over from the native reconnect loop to apply exponential backoff.
        es.close();
        _es = null;
        const delay = Math.min(_sseBackoffMs, SSE_BACKOFF_MAX_MS);
        console.warn(`[world SSE] reconnecting in ${delay}ms`);
        _sseReconnTimer = setTimeout(() => {
          _sseBackoffMs = Math.min(_sseBackoffMs * 2, SSE_BACKOFF_MAX_MS);
          openSSE();
        }, delay);
      }
    };
  }

  function closeSSE() {
    if (_sseReconnTimer) { clearTimeout(_sseReconnTimer); _sseReconnTimer = null; }
    if (_es) { _es.close(); _es = null; }
  }

  // ── QoS POST to /api/physics/qos ─────────────────────────────────────────────
  // Fire-and-forget: we update UI immediately and let the backend acknowledge
  // asynchronously.  The response is logged but not awaited in the hot path.

  async function postQoSToBackend(level: QoSLevel): Promise<void> {
    try {
      const res = await fetch('/api/physics/qos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ level }),
      });
      const data = await res.json();
      if (data.offline) {
        console.info('[world QoS] backend offline — QoS applied client-side only.', data);
      } else if (!res.ok) {
        console.warn('[world QoS] backend rejected QoS change:', data);
      } else {
        console.info('[world QoS] backend acknowledged:', data);
      }
    } catch (err) {
      console.warn('[world QoS] POST /api/physics/qos failed (network):', err);
    }
  }

  // ── Edge-emitter topology bootstrap ─────────────────────────────────────────
  // Fetches /api/cells, derives edge emitters via createEdgeEmitters(), and
  // registers them with the SPH world.  Called once after world.init().
  // Errors are non-fatal: the world continues without topology-driven emitters.

  async function fetchAndRegisterEdgeEmitters(world: any): Promise<EmitterConfig[]> {
    try {
      const res = await fetch('/api/cells');
      if (!res.ok) {
        console.warn('[world] /api/cells responded', res.status, '— skipping edge emitters');
        return [];
      }

      const data = await res.json();

      // /api/cells may return { cells, edges } or a bare cells array (legacy fallback).
      const rawCells: any[] = Array.isArray(data) ? data : (data.cells ?? []);
      const rawEdges: any[] = Array.isArray(data) ? [] : (data.edges ?? []);

      if (rawCells.length === 0) {
        console.info('[world] /api/cells returned no cells — skipping edge emitters');
        return [];
      }

      // Map API cells to the minimal shape createEdgeEmitters needs: { id, x, y }.
      // bbox from /api/cells is { x, y, w, h } (canvas-px); we use the centre.
      const cells = rawCells.map((c: any) => {
        const id = c.cell_id ?? c.id ?? String(c);
        let x = 0.5;
        let y = 0.5;
        if (c.bbox) {
          if (typeof c.bbox.x === 'number' && typeof c.bbox.w === 'number') {
            // { x, y, w, h } from composite_params
            x = (c.bbox.x + c.bbox.w / 2) / (window.innerWidth  || 1280);
            y = (c.bbox.y + c.bbox.h / 2) / (window.innerHeight || 720);
          } else if (Array.isArray(c.bbox.min) && Array.isArray(c.bbox.max)) {
            // { min: [x0,y0], max: [x1,y1] } from cell-body-bridge legacy
            x = (c.bbox.min[0] + c.bbox.max[0]) / 2 / (window.innerWidth  || 1280);
            y = (c.bbox.min[1] + c.bbox.max[1]) / 2 / (window.innerHeight || 720);
          }
        }
        return { id, x, y, w: 80, h: 40, species: c.species ?? 'cil-code',
                 mass: 75, friction: 0.5, restitution: 0.3, buoyancy: 0.5, pinned: false };
      });

      // Normalise edges to { source, target }
      const edges = rawEdges.map((e: any) => ({
        source: (e.sources?.[0] ?? e.source ?? ''),
        target: (e.targets?.[0] ?? e.target ?? ''),
      })).filter((e: any) => e.source && e.target);

      if (edges.length === 0) {
        console.info('[world] /api/cells returned no edges — skipping edge emitters');
        return [];
      }

      // Default QoS for emitter rate derivation (mid-tier: reliable, volatile, 10 mps)
      const defaultQos = {
        viscosity: 0.02, boundaryFriction: 0.30, trailLength: 9,
        emitterRate: 20, forceMultiplier: 1.5,
      };

      const emitters = createEdgeEmitters(cells as any, edges, defaultQos as any);

      // Register emitters with the world if it exposes addEmitter(); otherwise
      // they are still returned so the caller can store them for the debug overlay.
      for (const cfg of emitters) {
        if (typeof world.addEmitter === 'function') {
          world.addEmitter(cfg.x, cfg.y, cfg.dirX, cfg.dirY, cfg.rate, String(cfg.species));
        }
      }

      console.info(`[world] edge emitters registered: ${emitters.length} (from ${edges.length} edges)`);
      return emitters;
    } catch (err) {
      console.warn('[world] fetchAndRegisterEdgeEmitters failed:', err);
      return [];
    }
  }

  // ── Main ─────────────────────────────────────────────────────────────────────
  (async () => {
    if (!navigator.gpu) {
      hud.textContent = '你的浏览器不支持 WebGPU。请用 Chrome 113+ 或 Edge 113+';
      return;
    }

    let currentQoS: QoSLevel = 'high';
    let world: any = null;
    const meter = new FPSMeter();

    // Detect backend
    const backend = await detectBackend();
    hudBackend.textContent = backend.toUpperCase();
    if (backend === 'webgl2') {
      fallbackBanner.classList.add('visible');
    }

    // Open SSE connection for physics_step + cell_update events
    setSseStatus('offline', 'connecting…');
    openSSE();

    // Load SPHWorld module
    const SPHWorld = await loadSPHWorld();

    // Initial resize
    resizeCanvas(QOS_PROFILES[currentQoS].renderScale);

    // Instantiate world
    const profile = QOS_PROFILES[currentQoS];
    world = new SPHWorld(canvas, {
      backend,
      particleCount:   profile.particleCount,
      substeps:        profile.substeps,
      smoothingRadius: profile.smoothingRadius,
    });

    await world.init();

    // Fetch topology edges from /api/cells and seed the world with edge emitters.
    await fetchAndRegisterEdgeEmitters(world);

    // Initial scene: fluid block + obstacles
    world.addFluid(0.1, 0.05, 0.3, 0.3, 0.008);
    world.addObstacle(0.5, 0.5, 0.06);
    world.addObstacle(0.35, 0.65, 0.04);

    // Hide init overlay
    initOverlay.classList.add('hidden');

    // ── Render loop ────────────────────────────────────────────────────────────
    let rafId: number;
    function loop() {
      world.step();
      world.render();
      meter.tick();

      // ── Debug overlay ────────────────────────────────────────────────────────
      const anyDebugActive =
        dbgAABBs.checked || dbgContacts.checked || dbgBVH.checked || dbgEmitters.checked;

      if (anyDebugActive) {
        // Obtain a 2D context on the same canvas for the overlay.
        // SPHWorld renders to WebGPU/WebGL; we draw the debug layer on top via
        // a 2D context.  getContext is cached by the browser once obtained.
        const ctx2d = canvas.getContext('2d') as CanvasRenderingContext2D | null;
        if (ctx2d) {
          const debugOptions: DebugRenderOptions = {
            showAABBs:         dbgAABBs.checked,
            showContacts:      dbgContacts.checked,
            showContactNormals:dbgContacts.checked,
            showPenetration:   false,
            showBVH:           dbgBVH.checked,
            showEmitters:      dbgEmitters.checked,
            showStats:         false,
          };

          // Pull live data from the world if the API exposes it; otherwise
          // fall back to empty structures so the overlay is safe to call.
          const physicsWorld = world.getPhysicsWorld?.() ?? {
            bodies: new Map(),
            emitters: world.getEmitters?.() ?? [],
          };
          const manifolds   = world.getManifolds?.()  ?? [];
          const debugAABBs  = world.getDebugAABBs?.() ?? [];
          const bvhNodes    = world.getBVHRoots?.()   ?? [];

          renderDebugOverlay(ctx2d, physicsWorld, manifolds, debugAABBs, bvhNodes, debugOptions);
        }
      }

      // Update HUD
      hudParticles.textContent = world.particleCount?.toLocaleString() ?? profile.particleCount.toLocaleString();
      hudFps.textContent       = meter.fps.toFixed(1);

      rafId = requestAnimationFrame(loop);
    }
    rafId = requestAnimationFrame(loop);

    // ── QoS switching ──────────────────────────────────────────────────────────
    async function applyQoS(level: QoSLevel) {
      if (level === currentQoS) return;
      currentQoS = level;

      // Update button states and HUD immediately (optimistic UI)
      qosBtns.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.qos === level);
      });
      hudQos.textContent = level.toUpperCase();

      // POST the new level to the backend (fire-and-forget)
      postQoSToBackend(level);

      // Pause render loop while reconfiguring
      cancelAnimationFrame(rafId);

      const p = QOS_PROFILES[level];
      resizeCanvas(p.renderScale);

      // Reconfigure or recreate world
      if (typeof world.setQoS === 'function') {
        await world.setQoS({
          particleCount:   p.particleCount,
          substeps:        p.substeps,
          smoothingRadius: p.smoothingRadius,
        });
      } else {
        world.destroy?.();
        world = new SPHWorld(canvas, {
          backend,
          particleCount:   p.particleCount,
          substeps:        p.substeps,
          smoothingRadius: p.smoothingRadius,
        });
        await world.init();
      }

      // Resume loop
      rafId = requestAnimationFrame(loop);
    }

    qosBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        applyQoS(btn.dataset.qos as QoSLevel);
      });
    });

    // ── Resize observer ────────────────────────────────────────────────────────
    const resizeObserver = new ResizeObserver(() => {
      resizeCanvas(QOS_PROFILES[currentQoS].renderScale);
      world?.resize?.(canvas.width, canvas.height);
    });
    resizeObserver.observe(canvas);

    // ── Cleanup on page unload ─────────────────────────────────────────────────
    window.addEventListener('beforeunload', () => {
      closeSSE();
      cancelAnimationFrame(rafId);
      world?.destroy?.();
    });
  })();
</script>
