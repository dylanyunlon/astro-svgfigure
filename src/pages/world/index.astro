  // ── WebGPU bootstrap ──────────────────────────────────────────────────────
  async function initWebGPU(canvas: HTMLCanvasElement): Promise<{
    device:  GPUDevice;
    context: GPUCanvasContext;
    format:  GPUTextureFormat;
  } | null> {
    if (typeof navigator === 'undefined' || !('gpu' in navigator)) return null;
    try {
      const adapter = await (navigator as any).gpu.requestAdapter({
        powerPreference: 'high-performance',
      });
      if (!adapter) return null;
      const device: GPUDevice = await adapter.requestDevice({
        requiredLimits: {
          maxStorageBufferBindingSize: adapter.limits.maxStorageBufferBindingSize,
          maxBufferSize:               adapter.limits.maxBufferSize,
        },
      });
      const context = canvas.getContext('webgpu') as GPUCanvasContext | null;
      if (!context) { device.destroy(); return null; }
      const format = navigator.gpu.getPreferredCanvasFormat();
      context.configure({ device, format, alphaMode: 'premultiplied' });
      return { device, context, format };
    } catch (_) {
      return null;
    }
  }

  // ── FPS meter ─────────────────────────────────────────────────────────────
  class FPSMeter {
    private samples: number[] = [];
    private last = performance.now();

    tick() {
      const now = performance.now();
      this.samples.push(1000 / (now - this.last));
      this.last = now;
      if (this.samples.length > 60) this.samples.shift();
    }

    get fps() {
      if (!this.samples.length) return 0;
      return this.samples.reduce((a, b) => a + b, 0) / this.samples.length;
    }
  }

  // ── SSE EventSource for /api/cell-events ──────────────────────────────────
  const SSE_BASE_URL           = '/api/cell-events';
  const SSE_BACKOFF_INITIAL_MS = 1_000;
  const SSE_BACKOFF_MAX_MS     = 30_000;
  const SSE_ERROR_THRESHOLD    = 3;
  const COOKIE_POLL_INTERVAL   = 2_000;  // ms between cookie checks

  let _es: EventSource | null = null;
  let _sseErrorCount   = 0;
  let _sseBackoffMs    = SSE_BACKOFF_INITIAL_MS;
  let _sseReconnTimer: ReturnType<typeof setTimeout> | null = null;
  let _cookiePollTimer: ReturnType<typeof setInterval> | null = null;
  let _lastSessionCookie = '';

  // ── Cookie helpers ────────────────────────────────────────────────────────
  function getCookie(name: string): string {
    const prefix = name + '=';
    return document.cookie.split(';')
      .map(s => s.trim())
      .find(s => s.startsWith(prefix))
      ?.slice(prefix.length) ?? '';
  }

  /** Build SSE URL with current session cookie appended as query param.
   *  This lets the physics bridge correlate requests without CORS issues. */
  function buildSSEUrl(): string {
    const sid = getCookie('world_session') || getCookie('session') || getCookie('PHPSESSID') || '';
    return sid ? `${SSE_BASE_URL}?sid=${encodeURIComponent(sid)}` : SSE_BASE_URL;
  }

  function setSseStatus(state: 'connected' | 'offline' | 'error', label: string) {
    sseStatusEl.className = state;
    sseLabelEl.textContent = `SSE ${label}`;
  }

  /** Poll document.cookie every COOKIE_POLL_INTERVAL ms.
   *  If the session cookie changed, close the current SSE and reopen with the
   *  new session id so the physics bridge sees the updated identity. */
  function startCookieWatcher() {
    if (_cookiePollTimer) return;
    _lastSessionCookie = buildSSEUrl();
    _cookiePollTimer = setInterval(() => {
      const current = buildSSEUrl();
      if (current !== _lastSessionCookie) {
        console.info('[world SSE] session cookie changed — reconnecting SSE');
        _lastSessionCookie = current;
        closeSSE();
        _sseErrorCount = 0;
        _sseBackoffMs  = SSE_BACKOFF_INITIAL_MS;
        openSSE();
      }
    }, COOKIE_POLL_INTERVAL);
  }

  function stopCookieWatcher() {
    if (_cookiePollTimer) { clearInterval(_cookiePollTimer); _cookiePollTimer = null; }
  }

  function openSSE() {
    if (typeof EventSource === 'undefined') {
      setSseStatus('offline', 'unavailable');
      return;
    }

    const SSE_URL = buildSSEUrl();
    const es = new EventSource(SSE_URL);
    _es = es;

    // ── physics_step: SPH backend tick telemetry ─────────────────────────
    es.addEventListener('physics_step', (ev: MessageEvent) => {
      try {
        const d = JSON.parse(ev.data) as {
          step?: number;
          particle_count?: number;
          kinetic_energy?: number;
          sim_time_ms?: number;
          qos?: string;
          offline?: boolean;
        };

        if (d.offline) {
          setSseStatus('offline', 'backend offline');
          return;
        }

        if (d.sim_time_ms !== undefined) {
          hudSimTime.textContent = `${d.sim_time_ms.toFixed(1)} ms`;
        }

        if (d.qos && d.qos !== currentQoS) {
          const normalized = d.qos.toLowerCase() as QoSLevel;
          if (normalized in QOS_PROFILES) {
            hudQos.textContent = normalized.toUpperCase();
            qosBtns.forEach(btn => {
              btn.classList.toggle('active', btn.dataset.qos === normalized);
            });
          }
        }
      } catch (e) {
        console.warn('[world SSE] physics_step parse error:', e);
      }
    });

    // ── cell_update: propagated from Apollo DataNotifier ─────────────────
    es.addEventListener('cell_update', (ev: MessageEvent) => {
      try {
        const d = JSON.parse(ev.data) as {
          cell_id: string;
          params: unknown;
          bbox?: { x: number; y: number; w: number; h: number; z?: number };
        };
        console.debug('[world SSE] cell_update', d.cell_id);

        // ── physics-bridge: async force + overlap computation ───────────
        if (d.bbox) {
          const bboxes: CellBBox[] = [
            { id: d.cell_id, x: d.bbox.x, y: d.bbox.y, w: d.bbox.w, h: d.bbox.h, z: d.bbox.z ?? 1 },
          ];
          computeForces(bboxes)
            .then((ff: ForceField) => {
              lastForceField = { ...lastForceField, ...ff };
              // Feed computed forces back into orchestrator if available
              if (orchestrator && typeof (orchestrator as any).applyForceField === 'function') {
                (orchestrator as any).applyForceField(ff);
              }
              return checkConvergence(lastForceField, 0.5);
            })
            .then((converged: boolean) => {
              if (converged) {
                hudConvergence.textContent = 'YES';
              }
            })
            .catch((err: unknown) => {
              console.warn('[world physics-bridge] computeForces error:', err);
            });

          detectCollisions(bboxes)
            .then((pairs: OverlapPair[]) => {
              if (pairs.length > 0) {
                console.debug('[world physics-bridge] overlaps:', pairs.length, 'pairs for', d.cell_id);
              }
            })
            .catch((err: unknown) => {
              console.warn('[world physics-bridge] detectCollisions error:', err);
            });
        }

        // ── composite_params: extract per-scene composite config ─────────
        if (d.params && typeof d.params === 'object') {
          try {
            const raw = d.params as Record<string, unknown>;
            const lightingBucket  = (raw.lighting  ?? {}) as any;
            const postBucket      = (raw.post       ?? {}) as any;
            if (Object.keys(lightingBucket).length > 0 || Object.keys(postBucket).length > 0) {
              const extracted = extractCompositeParams(
                { lighting: lightingBucket },
                { post: postBucket },
              );
              if (extracted.length > 0) {
                activeCompositeParams = extracted;
                console.debug('[world composite_params] extracted', extracted.length, 'scene entries for', d.cell_id);
              }
            }
          } catch (cpErr) {
            console.warn('[world composite_params] extraction error:', cpErr);
          }
        }

        // Trigger organic growth animation for newly arriving cells
        if (growthAnimator && d.cell_id) {
          const existing = epochSync?.getCellSnapshot(d.cell_id);
          if (!existing) {
            growthAnimator.startGrowth({
              cellId: d.cell_id,
              seedX:  canvas.width  * 0.5,
              seedY:  canvas.height * 0.5,
              targetWidth:  160,
              targetHeight: 80,
              species: 'cil-eye',
            });
          }
        }

        // ── Req 2: bridge bbox updates into GPU render loop via DOM event ─
        if (d.cell_id && d.bbox) {
          document.dispatchEvent(new CustomEvent('world:cell-update', {
            detail: { cell_id: d.cell_id, bbox: d.bbox },
          }));
        }
      } catch (e) {
        console.warn('[world SSE] cell_update parse error:', e);
      }
    });

    es.onopen = () => {
      _sseErrorCount = 0;
      _sseBackoffMs  = SSE_BACKOFF_INITIAL_MS;
      setSseStatus('connected', 'connected');
    };

    es.onerror = () => {
      _sseErrorCount++;
      setSseStatus('error', `error #${_sseErrorCount}`);

      if (_sseErrorCount >= SSE_ERROR_THRESHOLD) {
        es.close();
        _es = null;
        const delay = Math.min(_sseBackoffMs, SSE_BACKOFF_MAX_MS);
        console.warn(`[world SSE] reconnecting in ${delay}ms`);
        _sseReconnTimer = setTimeout(() => {
          _sseBackoffMs = Math.min(_sseBackoffMs * 2, SSE_BACKOFF_MAX_MS);
          openSSE();
        }, delay);
      }
    };
  }

  function closeSSE() {
    if (_sseReconnTimer) { clearTimeout(_sseReconnTimer); _sseReconnTimer = null; }
    if (_es) { _es.close(); _es = null; }
  }

  function closeSSEAndWatcher() {
    stopCookieWatcher();
    closeSSE();
  }

  // ── QoS POST to /api/physics/qos ─────────────────────────────────────────
  async function postQoSToBackend(level: QoSLevel): Promise<void> {
    try {
      const res = await fetch('/api/physics/qos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ level }),
      });
      const data = await res.json();
      if (data.offline) {
        console.info('[world QoS] backend offline — QoS applied client-side only.', data);
      } else if (!res.ok) {
        console.warn('[world QoS] backend rejected QoS change:', data);
      } else {
        console.info('[world QoS] backend acknowledged:', data);
      }
    } catch (err) {
      console.warn('[world QoS] POST /api/physics/qos failed (network):', err);
    }
  }

  // ── Topology edge fetcher ─────────────────────────────────────────────────
  interface TopologyEdges {
    flowerEdges: FlowerEdgeSpline[];
    splineEdges: EdgeSpline[];
  }

  async function fetchTopologyEdges(): Promise<TopologyEdges> {
    const empty: TopologyEdges = { flowerEdges: [], splineEdges: [] };
    try {
      const res = await fetch('/api/cells');
      if (!res.ok) {
        console.warn('[world] /api/cells responded', res.status, '— skipping topology edges');
        return empty;
      }

      const data = await res.json();

      const rawCells: any[] = Array.isArray(data) ? data : (data.cells ?? []);
      const rawEdges: any[] = Array.isArray(data) ? [] : (data.edges ?? []);

      if (rawCells.length === 0 || rawEdges.length === 0) {
        console.info('[world] /api/cells returned no cells/edges — skipping topology');
        return empty;
      }

      const cellMap = new Map<string, { x: number; y: number }>();
      const cw = window.innerWidth  || 1280;
      const ch = window.innerHeight || 720;

      for (const c of rawCells) {
        const id = c.cell_id ?? c.id ?? String(c);
        let x = 0.5, y = 0.5;
        if (c.bbox) {
          if (typeof c.bbox.x === 'number' && typeof c.bbox.w === 'number') {
            x = (c.bbox.x + c.bbox.w / 2) / cw;
            y = (c.bbox.y + c.bbox.h / 2) / ch;
          } else if (Array.isArray(c.bbox.min) && Array.isArray(c.bbox.max)) {
            x = (c.bbox.min[0] + c.bbox.max[0]) / 2 / cw;
            y = (c.bbox.min[1] + c.bbox.max[1]) / 2 / ch;
          }
        }
        cellMap.set(id, { x, y });
      }

      const flowerEdges: FlowerEdgeSpline[] = [];
      const splineEdges: EdgeSpline[] = [];

      for (const e of rawEdges) {
        const sourceId = e.sources?.[0] ?? e.source ?? '';
        const targetId = e.targets?.[0] ?? e.target ?? '';
        if (!sourceId || !targetId) continue;

        const src = cellMap.get(sourceId);
        const tgt = cellMap.get(targetId);
        if (!src || !tgt) continue;

        const edgeId  = `${sourceId}->${targetId}`;
        const weight  = e.weight ?? 1.0;
        const species = e.species ?? 0;

        const dx  = tgt.x - src.x;
        const dy  = tgt.y - src.y;
        const ext = 0.25;
        const points = [
          { x: src.x - dx * ext, y: src.y - dy * ext, z: 0 },
          { x: src.x,            y: src.y,             z: 0 },
          { x: tgt.x,            y: tgt.y,             z: 0 },
          { x: tgt.x + dx * ext, y: tgt.y + dy * ext,  z: 0 },
        ];

        flowerEdges.push({ edgeId, sourceId, targetId, points, weight, species });
        splineEdges.push({ edgeId, sourceId, targetId, points, weight, species });
      }

      console.info(`[world] topology edges: ${flowerEdges.length} flower + ${splineEdges.length} spline`);
      return { flowerEdges, splineEdges };
    } catch (err) {
      console.warn('[world] fetchTopologyEdges failed:', err);
      return empty;
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  //  Main
  // ═══════════════════════════════════════════════════════════════════════════

  (async () => {
    let currentQoS: QoSLevel = 'high';
    let pipeline: ATRenderPipeline | null = null;
    let compositor: ATSceneCompositor | null = null;
    let orchestrator: WorldOrchestrator | null = null;
    let astroPipeline: AstroPipeline | null = null;
    let renderMode: 'simple' | 'at' = 'simple';
    let gpuDevice:  GPUDevice | null = null;
    let gpuContext: GPUCanvasContext | null = null;
    let gpuFormat:  GPUTextureFormat = 'bgra8unorm';
    let lastForceField: ForceField = {};
    let activeCompositeParams: CompositeParams[] = [];
    const meter = new FPSMeter();

    // ── Performance budget (4-tier adaptive quality) ─────────────────────
    const perfBudget = new PerformanceBudget('HIGH');

    // ── Adaptive LOD system (per-cell distance/coverage/budget LOD) ──────
    const adaptiveLOD = new AdaptiveLOD({}, perfBudget);
    setGlobalLOD(adaptiveLOD);

    // ── Organic growth entrance animator ─────────────────────────────────
    const growthAnimator = new OrganicGrowthAnimator(787);

    // ── Epoch visual sync (SSE → visual pipeline bridge) ─────────────────
    let epochSync: EpochVisualSync | null = null;

    // ── GPURenderLoop fallback (WebGL2) — 独立于 WebGPU 的渲染路径 ──────
    async function _startGPURenderLoop(): Promise<void> {
      const gpuWorldCanvas = document.getElementById('gpu-world') as HTMLCanvasElement;
      gpuWorldCanvas.width  = Math.floor(window.innerWidth  * devicePixelRatio);
      gpuWorldCanvas.height = Math.floor(window.innerHeight * devicePixelRatio);

      // hex → [r,g,b]
      const hexToRGB = (hex: string): [number,number,number] => {
        const n = parseInt(hex.replace('#',''), 16);
        return [(n>>16&0xff)/255, (n>>8&0xff)/255, (n&0xff)/255];
      };
      const SPECIES_ALIAS: Record<string,string> = {
        'cil-eye':'cil-eye','cil-bolt':'cil-bolt','cil-vector':'cil-vector',
        'cil-plus':'cil-plus','cil-arrow-right':'cil-arrow-right',
      };

      let raw: Record<string,any>|null = null;
      try { const r = await fetch('/channels/composite_params.json'); if(r.ok) raw = await r.json(); } catch(_){}
      if (!raw) { console.warn('[gpu-world] no data'); return; }

      const rawCells = (raw.cells ?? {}) as Record<string,any>;
      const cells: CellData[] = Object.entries(rawCells).map(([id, cv]: [string,any]) => {
        const bbox = cv?.agent_params?.bbox ?? {x:0,y:0,w:100,h:50,z:1};
        const sp = cv?.agent_params?.species_params ?? {};
        const color = hexToRGB(sp.primary_color ?? '#4488ff');
        return {
          cell_id:id, species: SPECIES_ALIAS[sp.species] ?? 'cil-eye',
          x:bbox.x, y:bbox.y, w:bbox.w, h:bbox.h, z:bbox.z??1,
          metallic:0.1, roughness:0.55, albedo:color, label:id,
          glowColor: hexToRGB(sp.glow_color ?? sp.primary_color ?? '#4488ff'),
          sdfShape: (sp.sdf_shape === 'capsule' ? 'capsule' : 'rounded_rect') as any,
          internalPattern: sp.internal_pattern ?? 'none',
          haloRadius: sp.halo_radius ?? 0.15,
          numRays: sp.num_rays ?? 0,
          focalIntensity: sp.focal_intensity ?? 0.0,
          animationSpeed: sp.animation_speed ?? 1.0,
          opacity: cv?.agent_params?.opacity ?? 0.9,
        } satisfies CellData;
      });

      const rawEdges = (raw.edge_routes ?? {}) as Record<string,any>;
      const edges: EdgeData[] = Object.entries(rawEdges).map(([id, ev]: [string,any]) => ({
        edge_id:id, source:ev.source as string, target:ev.target as string,
        controlPoints: (ev.control_points ?? []) as [number,number][],
        color: [0.2, 0.8, 0.6] as [number,number,number],
      }));

      // ── M1315: fetch geometry.json SDF data (same as loadGPUScene path) ──
      {
        const cellIds = cells.map(c => c.cell_id);
        const geoPromises = cellIds.map(id =>
          fetch('/channels/cell/' + id + '/geometry.json')
            .then(r => r.ok ? r.json() : null)
            .catch(() => null)
        );
        const geos = await Promise.all(geoPromises);
        let geoHit = 0;
        for (let i = 0; i < cells.length; i++) {
          const geo = geos[i];
          if (!geo) continue;
          geoHit++;
          const sdf = geo.sdf ?? {};
          const surf = geo.surface ?? {};
          const geoAlbedo = Array.isArray(surf.albedo) && surf.albedo.length === 3
            ? surf.albedo as [number,number,number] : undefined;
          cells[i] = {
            ...cells[i],
            ...(geoAlbedo ? { albedo: geoAlbedo } : {}),
            ...(Array.isArray(surf.glow_color) ? { glowColor: surf.glow_color as [number,number,number] } : {}),
            ...(typeof surf.opacity === 'number' ? { opacity: surf.opacity } : {}),
            ...(typeof surf.roughness === 'number' ? { roughness: surf.roughness } : {}),
            ...(typeof surf.metallic === 'number' ? { metallic: surf.metallic } : {}),
            sdfBaseRadius: typeof sdf.base_radius === 'number' ? sdf.base_radius : undefined,
            sdfLobes: Array.isArray(sdf.lobes) ? sdf.lobes : undefined,
            sdfNoiseAmp: typeof sdf.noise_amplitude === 'number' ? sdf.noise_amplitude : undefined,
            sdfNoiseFreq: typeof sdf.noise_frequency === 'number' ? sdf.noise_frequency : undefined,
          } as any;
        }
        console.info(`[gpu-world] geometry.json SDF merged: ${geoHit}/${cells.length} cells`);
      }

      // ── M1317l: WorldRenderer — clean 500-line render entry ──────────────
      try {
        console.info('[gpu-world] creating WorldRenderer...');
        const wr = new WorldRenderer(gpuWorldCanvas);
        wr.setScene(cells, edges);
        wr.start();
        hudBackend.textContent = 'WEBGL2';
        hudRenderMode.textContent = 'SDF-RAY';
        setInterval(() => { try { hudFps.textContent = String(wr.stats.fps); hudParticles.textContent = String(wr.stats.cellCount); } catch(_){} }, 250);
        console.info(`[gpu-world] WorldRenderer started — ${cells.length} cells, ${edges.length} edges`);
        // Live geometry SSE
        try {
          const liveES = new EventSource('/api/cell-events');
          liveES.addEventListener('geometry_update', (ev: MessageEvent) => {
            try { const d = JSON.parse(ev.data); if (d.cell_id && d.geometry) wr.updateCellGeometry(d.cell_id, d.geometry); } catch {}
          });
          liveES.addEventListener('cell_update', (ev: MessageEvent) => {
            try {
              const d = JSON.parse(ev.data);
              const cell = cells.find((c: CellData) => c.cell_id === d.cell_id);
              if (!cell || !d.params) return;
              const bbox = d.params.bbox ?? d.params.agent_params?.bbox;
              if (bbox) { cell.x = bbox.x ?? cell.x; cell.y = bbox.y ?? cell.y; if (bbox.w) cell.w = bbox.w; if (bbox.h) cell.h = bbox.h; wr.setScene(cells, edges); }
            } catch {}
          });
          liveES.onerror = () => console.warn('[gpu-world] SSE connection lost');
        } catch(e) { console.warn('[gpu-world] SSE setup failed:', e); }
        const overlay = document.getElementById('init-overlay');
        if (overlay) overlay.classList.add('hidden');
        return; // WorldRenderer running — skip GPURenderLoop below
      } catch(wrErr) {
        console.warn('[gpu-world] WorldRenderer failed, falling back to GPURenderLoop:', wrErr);
      }

      // ── GPURenderLoop (kept as reference / fallback) ──────────────────────
      try {
        console.info('[gpu-world] creating GPURenderLoop...');
        const loop = new GPURenderLoop(gpuWorldCanvas);
        console.info('[gpu-world] loop created, calling setScene with', cells.length, 'cells', edges.length, 'edges');
        loop.setScene(cells, edges);
        loop.start();
        wireMouseInteraction(loop, gpuWorldCanvas);
        console.info(`[gpu-world] GPURenderLoop started — ${cells.length} cells, ${edges.length} edges`);
        // M1259: wire HUD
        hudBackend.textContent = 'WEBGL2';
        hudRenderMode.textContent = 'PBR+SDF';
        setInterval(() => { try { const s = loop.stats; hudFps.textContent = String(s.fps); hudParticles.textContent = String(s.cellCount); } catch(_){} }, 250);

        // ── Live Cell Agents SSE — Claude Code cells push decisions ──────
        try {
          const liveCellES = new EventSource('/api/cell-events');

          // M1308: wire real SSE events from server.py DataNotifier
          liveCellES.addEventListener('cell_update', (ev: MessageEvent) => {
            try {
              const d = JSON.parse(ev.data);
              const cell = cells.find((c: any) => c.cell_id === d.cell_id);
              if (!cell || !d.params) return;
              const bbox = d.params.bbox ?? d.params.agent_params?.bbox;
              if (bbox) {
                cell.x = bbox.x ?? cell.x;
                cell.y = bbox.y ?? cell.y;
                if (bbox.w) cell.w = bbox.w;
                if (bbox.h) cell.h = bbox.h;
              }
              console.debug(`[sse] cell_update: ${d.cell_id}`);
            } catch {}
          });
          liveCellES.addEventListener('cell_params_updated', (ev: MessageEvent) => {
            try {
              const d = JSON.parse(ev.data);
              const cell = cells.find((c: any) => c.cell_id === d.cell_id);
              if (!cell || !d.params) return;
              const bbox = d.params.bbox ?? d.params.agent_params?.bbox;
              if (bbox) {
                cell.x = bbox.x ?? cell.x;
                cell.y = bbox.y ?? cell.y;
              }
              console.debug(`[sse] cell_params_updated: ${d.cell_id}`);
            } catch {}
          });
          liveCellES.addEventListener('physics_step', (ev: MessageEvent) => {
            try {
              const d = JSON.parse(ev.data);
              console.debug(`[sse] physics_step epoch=${d.epoch} converged=${d.converged}`);
            } catch {}
          });
          // M1305: geometry.json live updates from tick-runner
          liveCellES.addEventListener('geometry_update', (ev: MessageEvent) => {
            try {
              const d = JSON.parse(ev.data);
              if (d.cell_id && d.geometry && loop) {
                (loop as any).geometryChannel?.set(d.cell_id, d.geometry);
              }
              console.debug(`[sse] geometry_update: ${d.cell_id} tick=${d.geometry?.tick}`);
            } catch {}
          });
          liveCellES.addEventListener('open', () => {
            console.info('[gpu-world] SSE connected to /api/cell-events');
          });
          liveCellES.onerror = () => {
            console.warn('[gpu-world] SSE connection lost, will auto-reconnect');
          };
        } catch(e) { console.warn('[gpu-world] SSE setup failed:', e); }

        // 隐藏 overlay
        const overlay = document.getElementById('init-overlay');
        if (overlay) overlay.classList.add('hidden');
      } catch(err) {
        console.error('[gpu-world] GPURenderLoop crash:', err);
      }
    }

    // ── WebGPU init ─────────────────────────────────────────────────────
    const profile = QOS_PROFILES[currentQoS];
    resizeCanvas(profile.renderScale);

    const gpu = await initWebGPU(canvas);
    if (!gpu) {
      hudBackend.textContent = 'WEBGL2';
      fallbackBanner.classList.add('visible');
      // WebGPU 不可用 → 用 GPURenderLoop (WebGL2) 作为主渲染路径
      console.info('[world] WebGPU unavailable — falling back to GPURenderLoop (WebGL2)');
      initOverlay.textContent = 'Loading WebGL2 renderer…';
      await _startGPURenderLoop();
      return;
    }

    gpuDevice  = gpu.device;
    gpuContext = gpu.context;
    gpuFormat  = gpu.format;
    hudBackend.textContent = 'WEBGPU';

    // Open SSE connection for physics_step + cell_update events
    setSseStatus('offline', 'connecting…');
    openSSE();
    startCookieWatcher();

    // ── Fetch topology edges from /api/cells ────────────────────────────
    const { flowerEdges, splineEdges } = await fetchTopologyEdges();

    // ── Initialise WorldOrchestrator (M759: unified master scheduler) ────
    // WorldOrchestrator owns its own WebGPU device, rAF loop, SPH physics,
    // collision world, AT render pipeline, environment FX, and audio bridge.
    // We create it but let the page's own rAF handle rendering to keep HUD
    // and debug overlays in sync.
    try {
      orchestrator = new WorldOrchestrator(canvas, {
        qosProfile:             'DEFAULT',
        enableATRenderPipeline: false,   // We manage pipeline separately below
        enableEnvironmentFx:    true,
        enableAudio:            false,
        enableAdaptive:         true,
      } as WorldOrchestratorConfig);
      await orchestrator.init();
      console.info('[world] WorldOrchestrator initialised');
    } catch (err) {
      console.warn('[world] WorldOrchestrator init failed — running without orchestrator:', err);
      orchestrator = null;
    }

    // ── Initialise AstroPipeline (WebGL2 cell render loop) ───────────────
    // AstroPipeline drives the FXScene → Nuke post-process → BloomPass chain
    // over WebGL2 in parallel with the WebGPU AT pipeline.  It is kept
    // separate so that its WebGL2 context does not conflict with WebGPU.
    try {
      astroPipeline = new AstroPipeline({
        cellsEndpoint:       '/api/cells',
        cellParamsDir:       '/channels/cell',
        bloomStrength:       profile.lutStrength * 1.4,
        bloomRadius:         1.0,
        luminosityThreshold: 0.65,
      } satisfies AstroPipelineConfig);
      await astroPipeline.init(canvas);
      astroPipeline.start();
      console.info('[world] AstroPipeline initialised and started');
    } catch (err) {
      console.warn('[world] AstroPipeline init failed — WebGL2 cell layer unavailable:', err);
      astroPipeline = null;
    }

    // ── Initialise AT Render Pipeline (Simple mode) ─────────────────────
    try {
      pipeline = await ATRenderPipeline.create(
        gpuDevice,
        canvas,
        flowerEdges,
        splineEdges,
        {
          format:      gpuFormat,
          lutStyle:    'DEEP_OCEAN',
          lutStrength: profile.lutStrength,
          passes:      profile.passes,
        },
      );
    } catch (err) {
      console.error('[world] ATRenderPipeline.create failed:', err);
      initOverlay.textContent = `Init error: ${(err as Error).message}`;
      return;
    }

    // ── Initialise ATSceneCompositor (AT mode) ──────────────────────────
    try {
      compositor = new ATSceneCompositor();
      await compositor.init(gpuDevice, canvas, {
        format:      gpuFormat,
        flowerEdges,
        splineEdges,
      } as ATSceneCompositorConfig);

      const vw = canvas.width;
      const vh = canvas.height;
      await compositor.addCell('cell-0', 'attention',  { x: 0,        y: 0,        w: vw * 0.5, h: vh * 0.5 });
      await compositor.addCell('cell-1', 'ffn',        { x: vw * 0.5, y: 0,        w: vw * 0.5, h: vh * 0.5 });
      await compositor.addCell('cell-2', 'embedding',  { x: 0,        y: vh * 0.5, w: vw * 0.5, h: vh * 0.5 });
      await compositor.addCell('cell-3', 'softmax',    { x: vw * 0.5, y: vh * 0.5, w: vw * 0.5, h: vh * 0.5 });

      console.info('[world] ATSceneCompositor initialised with', compositor.cellCount, 'cells');
    } catch (err) {
      console.warn('[world] ATSceneCompositor init failed — AT mode unavailable:', err);
      compositor = null;
      modeATBtn.style.opacity = '0.3';
      modeATBtn.style.pointerEvents = 'none';
      modeATBtn.title = 'ATSceneCompositor unavailable';
    }

    // ── Initialise EpochVisualSync (SSE → visual pipeline bridge) ────────
    try {
      epochSync = new EpochVisualSync({
        canvasW: canvas.width,
        canvasH: canvas.height,
        eventSource: _es ?? undefined,
        onCellEnter: (cellId, snapshot) => {
          console.debug('[world epoch] cell enter:', cellId, snapshot.species);
          growthAnimator.startGrowth({
            cellId,
            seedX:        snapshot.bbox.x + snapshot.bbox.w / 2,
            seedY:        snapshot.bbox.y + snapshot.bbox.h / 2,
            targetWidth:  snapshot.bbox.w,
            targetHeight: snapshot.bbox.h,
            species:      snapshot.species,
          });
        },
        onCellExit: (cellId) => {
          console.debug('[world epoch] cell exit:', cellId);
        },
        onSpeciesTransition: (cellId, from, to) => {
          console.info(`[world epoch] species transition: ${cellId} ${from} → ${to}`);
        },
        onQualityChange: (quality) => {
          hudConvergence.textContent = quality.converged ? 'YES' : `δ${quality.maxDelta.toFixed(2)}`;
        },
        onTimelineProgress: (timeline) => {
          hudEpoch.textContent = `${timeline.epoch}/${timeline.maxEpochs}`;
        },
      });
      epochSync.start();
      console.info('[world] EpochVisualSync started');
    } catch (err) {
      console.warn('[world] EpochVisualSync init failed:', err);
      epochSync = null;
    }

    // Hide init overlay
    initOverlay.classList.add('hidden');

    // ── SplineParticleLife (CPU particle flow along topology edges) ──────
    const edgeSplineData: EdgeSplineData[] = splineEdges.map(e => ({
      edgeId:   e.edgeId,
      sourceId: e.sourceId,
      targetId: e.targetId,
      points:   e.points,
      weight:   e.weight,
    }));

    const splineParticleLife = new SplineParticleLife(edgeSplineData, {
      uSplineSpeed:    [0.82, 1.21],
      uTimeMultiplier: 0.17,
      uCurlStrength:   0.04,
      uCurlNoiseScale: 2.0,
      uCurlNoiseSpeed: 5.0,
      uDecayRate:      0.6,
      particlesPerUnit: 24,
      onHandoff: (edgeId, targetId, x, y, vx, vy, species) => {
        console.debug(
          `[world SPL] handoff edge=${edgeId} → cell=${targetId}`,
          `pos=(${x.toFixed(3)},${y.toFixed(3)})`,
          `vel=(${vx.toFixed(3)},${vy.toFixed(3)})`,
          `species=${species}`,
        );
      },
    });

    console.info(
      `[world] SplineParticleLife created: ${edgeSplineData.length} edges,`,
      `${splineParticleLife.totalCount} particles`,
    );

    // ── Collision world (standalone for HUD telemetry) ───────────────────
    const collisionWorld = new CollisionWorld();

    // ── Render loop ─────────────────────────────────────────────────────
    let rafId: number;
    let lastTime = performance.now();
    let frameCount = 0;

    function loop() {
      if (!gpuDevice || !gpuContext) return;

      const now = performance.now();
      const dt  = Math.min((now - lastTime) / 1000, 0.05);
      lastTime  = now;
      frameCount++;

      // ── Performance budget tick (adaptive tier switching) ──────────
      perfBudget.tick(dt * 1000);
      hudPerfTier.textContent = perfBudget.tier;

      // ── Epoch visual sync tick (bbox morph + quality ramp) ─────────
      let qualityState: QualityState | null = null;
      if (epochSync) {
        qualityState = epochSync.tick(dt);
      }

      // ── Organic growth animator tick ───────────────────────────────
      growthAnimator.update(dt);

      // ── AstroPipeline composite params sync ────────────────────────
      // Push the most-recent composite params into AstroPipeline's bloom
      // pass so scene-specific contrast and RGB-strength values from the
      // cell SSE stream are reflected on every frame.
      if (astroPipeline && activeCompositeParams.length > 0) {
        const cp = activeCompositeParams[0];
        if (cp.contrast !== undefined || cp.rgbStrength !== undefined) {
          astroPipeline.bloomPass.setThreshold(
            cp.contrast !== undefined ? Math.max(0, 1 - cp.contrast) : 0.65,
          );
          if (cp.rgbStrength !== undefined) {
            astroPipeline.bloomPass.setStrength(cp.rgbStrength * 1.5);
          }
        }
      }

      // ── Render path selection ─────────────────────────────────────
      if (renderMode === 'at' && compositor && compositor.isInitialised) {
        compositor.tick(dt, null);
      } else if (pipeline) {
        pipeline.tick(dt);

        const swapChainTexture = gpuContext.getCurrentTexture();
        const dstView = swapChainTexture.createView();
        const encoder = gpuDevice.createCommandEncoder({ label: 'world-frame' });

        pipeline.render(encoder, dstView);

        gpuDevice.queue.submit([encoder.finish()]);
      }

      meter.tick();

      // ── SplineParticleLife update (CPU particle flow along edges) ──
      splineParticleLife.update(dt);

      // ── Debug overlay (2D canvas drawn over WebGPU surface) ───────
      const anyDebugActive =
        dbgAABBs.checked || dbgContacts.checked || dbgBVH.checked || dbgEmitters.checked;

      if (anyDebugActive) {
        const dbgCanvas = document.createElement('canvas');
        dbgCanvas.width  = canvas.width;
        dbgCanvas.height = canvas.height;
        const ctx2d = dbgCanvas.getContext('2d');
        if (ctx2d) {
          const debugOptions: DebugRenderOptions = {
            showAABBs:          dbgAABBs.checked,
            showContacts:       dbgContacts.checked,
            showContactNormals: dbgContacts.checked,
            showPenetration:    false,
            showBVH:            dbgBVH.checked,
            showEmitters:       dbgEmitters.checked,
            showStats:          false,
          };
          const physicsWorld = { bodies: new Map(), emitters: [] };
          renderDebugOverlay(ctx2d, physicsWorld, [], [], [], debugOptions);
        }
      }

      // ── HUD updates ───────────────────────────────────────────────
      collisionWorld.step(dt);
      const colData = collisionWorld.exportCollisions();

      hudParticles.textContent     = String(flowerEdges.length + splineEdges.length);
      hudFps.textContent           = meter.fps.toFixed(1);
      hudCollisions.textContent    = String(colData.count);
      hudPressureIters.textContent = String(frameCount % 1000);
      hudSplineFlow.textContent    = `${splineParticleLife.activeCount}/${splineParticleLife.totalCount}`;

      // LOD summary
      const lodRatio = adaptiveLOD.getParticleBudgetRatio();
      hudLod.textContent = `${(lodRatio * 100).toFixed(0)}%`;

      // Collision detail
      if (colData.count > 0) {
        const maxDepth = colData.collisions.reduce((m, c) => Math.max(m, c.depth), 0);
        hudColDepth.textContent = maxDepth.toFixed(4);
        const pairStrs = colData.collisions
          .slice(0, 3)
          .map(c => `${c.bodyA}↔${c.bodyB}`);
        hudColPairs.textContent = pairStrs.join(' ') + (colData.count > 3 ? ' …' : '');
      } else {
        hudColDepth.textContent = '—';
        hudColPairs.textContent = '—';
      }

      // Memory (Chrome Performance Memory API)
      const perf = performance as any;
      if (perf.memory?.usedJSHeapSize !== undefined) {
        const mb = perf.memory.usedJSHeapSize / 1_048_576;
        hudMemory.textContent = `${mb.toFixed(1)} MB`;
      } else {
        hudMemory.textContent = '—';
      }

    // ── M1105: Apply UIL params to GPU each frame ──
    if (typeof uilBridge !== 'undefined' && uilBridge.applyAll) {
      uilBridge.applyAll(gl);
    }
      rafId = requestAnimationFrame(loop);
    }
    rafId = requestAnimationFrame(loop);

    // ── Render mode switching ────────────────────────────────────────────
    function applyRenderMode(mode: 'simple' | 'at') {
      if (mode === renderMode) return;

      if (mode === 'at' && (!compositor || !compositor.isInitialised)) {
        console.warn('[world] Cannot switch to AT mode — compositor unavailable');
        return;
      }

      renderMode = mode;
      hudRenderMode.textContent = mode.toUpperCase();
      modeSimpleBtn.classList.toggle('active', mode === 'simple');
      modeATBtn.classList.toggle('active', mode === 'at');

      if (mode === 'at' && compositor) {
        compositor.resize(canvas.width, canvas.height);
      }

      console.info(`[world] render mode → ${mode.toUpperCase()}`);
    }

    modeSimpleBtn.addEventListener('click', () => applyRenderMode('simple'));
    modeATBtn.addEventListener('click', () => applyRenderMode('at'));

    // ── QoS switching ───────────────────────────────────────────────────
    function applyQoS(level: QoSLevel) {
      if (level === currentQoS || !pipeline) return;
      currentQoS = level;

      qosBtns.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.qos === level);
      });
      hudQos.textContent = level.toUpperCase();

      postQoSToBackend(level);

      const p = QOS_PROFILES[level];
      pipeline.setPassFlags(p.passes);
      pipeline.setLutStrength(p.lutStrength);

      resizeCanvas(p.renderScale);
      pipeline.resize(canvas.width, canvas.height);

      if (compositor && compositor.isInitialised) {
        compositor.resize(canvas.width, canvas.height);
      }

      // Sync orchestrator QoS profile
      if (orchestrator) {
        const qosMap: Record<QoSLevel, string> = { low: 'LOW', mid: 'DEFAULT', high: 'DEFAULT' };
        orchestrator.setQoSProfile(qosMap[level] as any);
      }
    }

    qosBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        applyQoS(btn.dataset.qos as QoSLevel);
      });
    });

    // ── Preset scene selector ───────────────────────────────────────────
    presetSelect.addEventListener('change', () => {
      const key = presetSelect.value;
      if (!key || !PRESET_SCENES[key] || !orchestrator) return;

      const scene = PRESET_SCENES[key];
      const W = canvas.width;
      const H = canvas.height;

      scene.setup(
        (x: number, y: number, w: number, h: number, spacing: number, sp: number) =>
          orchestrator!.addFluid(x, y, x + w, y + h, spacing, sp),
        (_id: string, _x: number, _y: number, _w: number, _h: number, _sp: number, _fixed: boolean) => {
          /* rigid body creation delegated to orchestrator internals */
        },
        (x: number, y: number, dx: number, dy: number, rate: number, sp: number) =>
          orchestrator!.addEmitter({
            x, y, dirX: dx, dirY: dy,
            rate, species: sp,
            pattern: { type: 'continuous' } as any,
          }),
        W, H,
      );

      console.info(`[world] preset scene loaded: ${scene.name}`);
    });

    // ── Resize observer ─────────────────────────────────────────────────
    const resizeObserver = new ResizeObserver(() => {
      resizeCanvas(QOS_PROFILES[currentQoS].renderScale);
      pipeline?.resize(canvas.width, canvas.height);
      if (compositor && compositor.isInitialised) {
        compositor.resize(canvas.width, canvas.height);
      }
      orchestrator?.resize(canvas.width, canvas.height);
      astroPipeline?.resize(canvas.clientWidth, canvas.clientHeight);
    });
    resizeObserver.observe(canvas);

    // ── GPURenderLoop (M979) — WebGL cell+edge render on #gpu-world ──────
    // Reads all 58 cells from composite_params.json, initialises every
    // GPU pass in serial order, then hot-swaps PBR materials for AT shaders
    // once at_params are loaded.
    const gpuWorldCanvas = document.getElementById('gpu-world') as HTMLCanvasElement;
    gpuWorldCanvas.width  = Math.floor(window.innerWidth  * devicePixelRatio);
    gpuWorldCanvas.height = Math.floor(window.innerHeight * devicePixelRatio);

    // hex "#rrggbb" → [r, g, b] normalised floats
    function hexToRGB(hex: string): [number, number, number] {
      const n = parseInt(hex.replace('#', ''), 16);
      return [(n >> 16 & 0xff) / 255, (n >> 8 & 0xff) / 255, (n & 0xff) / 255];
    }

    // Map species string to CellData-compatible species key
    const SPECIES_ALIAS: Record<string, string> = {
      'cil-vector':      'cil-vector',
      'cil-eye':         'cil-eye',
      'cil-bolt':        'cil-bolt',
      'cil-plus':        'cil-plus',
      'cil-arrow-right': 'cil-arrow-right',
    };

    // AT material → PBR param overrides (metallic/roughness tuned per shader)
    const AT_MATERIAL_PBR: Record<string, { metallic: number; roughness: number }> = {
      'JellyfishShader':   { metallic: 0.0,  roughness: 0.15 },
      'FlowerSpineShader': { metallic: 0.05, roughness: 0.30 },
      'RockShader':        { metallic: 0.35, roughness: 0.80 },
      'FloorShader':       { metallic: 0.55, roughness: 0.45 },
    };

    /** Load composite_params.json — always reads ALL 58 cells.
     *  Returns raw JSON plus pre-parsed CellData[] and EdgeData[]. */
    async function loadGPUScene(): Promise<{
      cells:     CellData[];
      edges:     EdgeData[];
      rawParams: Record<string, any> | null;
    }> {
      // ── 1. Try /api/composite-params first, fall back to static JSON ──
      let raw: Record<string, any> | null = null;
      try {
        const res = await fetch('/api/composite-params');
        if (res.ok) raw = await res.json();
      } catch (_) { /* network miss — fall through */ }

      if (!raw) {
        try {
          const res = await fetch('/channels/composite_params.json');
          if (res.ok) raw = await res.json();
        } catch (_) { /* ignore */ }
      }

      if (!raw) {
        console.warn('[gpu-world] No composite_params source — using empty scene');
        return { cells: [], edges: [], rawParams: null };
      }

      // ── 2. Parse ALL cells (expect 58) ───────────────────────────────
      const rawCells      = (raw.cells            ?? {}) as Record<string, any>;
      const speciesAssign = (raw.species_assignment ?? {}) as Record<string, any>;

      const cells: CellData[] = Object.entries(rawCells).map(([cellId, cv]: [string, any]) => {
        const bbox  = cv?.agent_params?.bbox ?? { x: 0, y: 0, w: 100, h: 50, z: 1 };
        const sp    = cv?.agent_params?.species_params ?? {};
        const color = hexToRGB(sp.primary_color ?? '#4488ff');
        const spKey = SPECIES_ALIAS[speciesAssign?.[cellId]?.species] ?? 'cil-eye';
        // Default PBR — AT shader swap happens after load
        return {
          cell_id:   cellId,
          species:   spKey,
          x:         bbox.x  as number,
          y:         bbox.y  as number,
          w:         bbox.w  as number,
          h:         bbox.h  as number,
          z:         (bbox.z as number) ?? 1,
          metallic:  0.1,
          roughness: 0.55,
          albedo:    color,
          label:     cellId,
          glowColor: hexToRGB(sp.glow_color ?? sp.primary_color ?? '#4488ff'),
          sdfShape: (sp.sdf_shape === 'capsule' ? 'capsule' : 'rounded_rect') as any,
          internalPattern: sp.internal_pattern ?? 'none',
          haloRadius: sp.halo_radius ?? 0.15,
          numRays: sp.num_rays ?? 0,
          focalIntensity: sp.focal_intensity ?? 0.0,
          animationSpeed: sp.animation_speed ?? 1.0,
          opacity: cv?.agent_params?.opacity ?? 0.9,
        } satisfies CellData;
      });

      if (cells.length !== 58) {
        console.warn(`[gpu-world] expected 58 cells, got ${cells.length}`);
      } else {
        console.info(`[gpu-world] ✓ all 58 cells loaded from composite_params`);
      }

      // ── 2b. Concurrently fetch geometry.json SDF data for each cell ──
      const cellIds = cells.map(c => c.cell_id);
      const geoPromises = cellIds.map(id =>
        fetch('/channels/cell/' + id + '/geometry.json')
          .then(r => r.ok ? r.json() : null)
          .catch(() => null)
      );
      const geos = await Promise.all(geoPromises);

      // Merge SDF fields from geometry.json into each CellData
      let geoHitCount = 0;
      for (let i = 0; i < cells.length; i++) {
        const geo = geos[i];
        if (!geo) continue;
        geoHitCount++;
        const sdf  = geo.sdf     ?? {};
        const surf = geo.surface ?? {};
        const mem  = geo.membrane ?? {};
        const mot  = geo.internal_motion ?? {};
        // M1315: override albedo from geometry.json surface.albedo (was missing)
        const geoAlbedo = Array.isArray(surf.albedo) && surf.albedo.length === 3
          ? surf.albedo as [number, number, number] : undefined;
        cells[i] = {
          ...cells[i],
          // Override albedo/glowColor from geometry.json if present
          ...(geoAlbedo ? { albedo: geoAlbedo } : {}),
          ...(Array.isArray(surf.glow_color) ? { glowColor: surf.glow_color as [number,number,number] } : {}),
          ...(typeof surf.opacity === 'number' ? { opacity: surf.opacity } : {}),
          ...(typeof surf.roughness === 'number' ? { roughness: surf.roughness } : {}),
          ...(typeof surf.metallic === 'number' ? { metallic: surf.metallic } : {}),
          sdfBaseRadius:       typeof sdf.base_radius      === 'number' ? sdf.base_radius      : undefined,
          sdfLobes:            Array.isArray(sdf.lobes)                 ? sdf.lobes             : undefined,
          sdfNoiseAmp:         typeof sdf.noise_amplitude  === 'number' ? sdf.noise_amplitude   : undefined,
          sdfNoiseFreq:        typeof sdf.noise_frequency  === 'number' ? sdf.noise_frequency   : undefined,
          surfaceGlowIntensity:typeof surf.glow_intensity  === 'number' ? surf.glow_intensity   : undefined,
          membraneThickness:   typeof mem.thickness        === 'number' ? mem.thickness         : undefined,
          membraneWobbleAmp:   typeof mem.wobble_amplitude === 'number' ? mem.wobble_amplitude  : undefined,
          cytplasmFlowSpeed:   typeof mot.cytoplasm_flow_speed === 'number' ? mot.cytoplasm_flow_speed : undefined,
        };
      }
      console.info(`[gpu-world] geometry.json SDF merged: ${geoHitCount}/${cells.length} cells`);

      // ── 3. Parse edge_routes ─────────────────────────────────────────
      const rawEdges = (raw.edge_routes ?? {}) as Record<string, any>;
      const edges: EdgeData[] = Object.entries(rawEdges).map(([edgeId, ev]: [string, any]) => {
        const cp: [number, number][] = (ev.control_points ?? []) as [number, number][];
        const srcCell = cells.find(c => c.cell_id === ev.source);
        return {
          edge_id:       edgeId,
          source:        ev.source as string,
          target:        ev.target as string,
          controlPoints: cp,
          color:         srcCell?.albedo ?? [0.2, 0.8, 0.6],
        } satisfies EdgeData;
      });

      console.info(`[gpu-world] ${edges.length} topology edges`);
      return { cells, edges, rawParams: raw };
    }

    /** Replace PBR metallic/roughness values with AT shader equivalents.
     *  Called immediately after GPURenderLoop.start() and again after 500 ms
     *  to ensure the shader compiler fence has passed.                       */
    function applyATShaders(
      loop:      GPURenderLoop,
      rawParams: Record<string, any>,
      cells:     CellData[],
    ): void {
      const rawCells = (rawParams.cells ?? {}) as Record<string, any>;
      let patchCount = 0;

      const patchedCells: CellData[] = cells.map(cell => {
        const atMat = rawCells[cell.cell_id]?.at_params?.at_material as string | undefined;
        const ovr   = atMat ? AT_MATERIAL_PBR[atMat] : undefined;
        if (!ovr) return cell;
        patchCount++;
        return { ...cell, metallic: ovr.metallic, roughness: ovr.roughness };
      });

      if (patchCount > 0) {
        // Pass empty edges array — setScene merges, does not clear existing edges
        loop.setScene(patchedCells, []);
        console.info(`[gpu-world] AT shader swap: ${patchCount} cells PBR → AT material`);
      }
    }

    // ── Boot GPU render loop with full 7-pass chain ───────────────────────
    // Pass execution order (mirrors ATRenderPipeline spec):
    //   [1] geometry        — cell bboxes + topology edges
    //   [2] flowerParticle  — petal burst from high-energy cells
    //   [3] splineParticle  — edge-flow ribbons (Catmull-Rom)
    //   [4] waterSurface    — NS fluid mesh on low-z cells
    //   [5] volumetricLight — ray-marched VL cones from self-attn cells
    //   [6] bloom           — dual-threshold luminance bloom
    //   [7] lut             — colour-grading LUT (DEEP_OCEAN)
    // GPURenderLoop.start() activates all passes; QoS flags gate pass execution.
    let gpuRenderLoop: GPURenderLoop | null = null;

    loadGPUScene().then(async ({ cells, edges, rawParams }) => {
      try {
        // Resize canvas to actual pixel size (必须在 getContext 之前)
        gpuWorldCanvas.width  = Math.floor(window.innerWidth  * devicePixelRatio);
        gpuWorldCanvas.height = Math.floor(window.innerHeight * devicePixelRatio);

        gpuRenderLoop = new GPURenderLoop(gpuWorldCanvas);

        // Seed all 7 passes with 58 cells + 57 edges
        gpuRenderLoop.setScene(cells, edges);
        gpuRenderLoop.start();
        wireMouseInteraction(gpuRenderLoop, gpuWorldCanvas);

        // M1259: wire HUD
        hudBackend.textContent = 'WEBGL2';
        hudRenderMode.textContent = 'PBR+SDF';
        setInterval(() => { try { if (!gpuRenderLoop) return; const s = gpuRenderLoop.stats; hudFps.textContent = String(s.fps); hudParticles.textContent = String(s.cellCount); } catch(_){} }, 250);

        // ── M1272: mouse interaction → GPU physics (drag/throw/inject) ──────
        // Map canvas pixel coords → cell-space via camera params exposed by
        // the render loop, then drive the physics engine directly.
        {
          // The gpu-world canvas has pointer-events:none; capture on the
          // base SPH canvas which sits behind it and spans the viewport.
          const interactEl: HTMLElement = canvas ?? gpuWorldCanvas;
          interactEl.style.cursor = 'grab';

          // CSS px → canvas device px → cell px (inverse of fitX/fitY)
          const toCellCoords = (clientX: number, clientY: number) => {
            const rect = gpuWorldCanvas.getBoundingClientRect();
            const cam = gpuRenderLoop!.camera;
            // CSS → canvas device pixels
            const canvasX = (clientX - rect.left) * (gpuWorldCanvas.width  / rect.width);
            const canvasY = (clientY - rect.top)  * (gpuWorldCanvas.height / rect.height);
            // canvas px → cell px (reverse of px*scale + off)
            const cellX = (canvasX - cam.offX) / cam.scale;
            const cellY = (canvasY - cam.offY) / cam.scale;
            return { cellX, cellY };
          };

          let dragging = false;

          interactEl.addEventListener('mousedown', (e: MouseEvent) => {
            const physics = gpuRenderLoop?.physicsEngine;
            if (!physics) return;
            const { cellX, cellY } = toCellCoords(e.clientX, e.clientY);
            // Find the cell under the pointer (topmost hit / nearest).
            const hitId = physics.hitTest(cellX, cellY);
            if (!hitId) return;
            physics.dragStart(hitId, cellX, cellY);
            dragging = true;
            interactEl.style.cursor = 'grabbing';
          });

          interactEl.addEventListener('mousemove', (e: MouseEvent) => {
            if (!dragging) return;
            const physics = gpuRenderLoop?.physicsEngine;
            if (!physics) return;
            const { cellX, cellY } = toCellCoords(e.clientX, e.clientY);
            physics.dragMove(cellX, cellY);
          });

          const endDrag = () => {
            if (!dragging) return;
            const physics = gpuRenderLoop?.physicsEngine;
            physics?.dragEnd();   // applies throw velocity from pointer history
            dragging = false;
            interactEl.style.cursor = 'grab';
          };
          interactEl.addEventListener('mouseup', endDrag);
          interactEl.addEventListener('mouseleave', endDrag);

          // Double-click → radial blast shockwave at pointer.
          interactEl.addEventListener('dblclick', (e: MouseEvent) => {
            const physics = gpuRenderLoop?.physicsEngine;
            if (!physics) return;
            const { cellX, cellY } = toCellCoords(e.clientX, e.clientY);
            physics.inject(cellX, cellY);
          });

          console.info('[gpu-world] M1272 mouse interaction wired — drag/throw/inject active');
        }

        // 隐藏 init overlay — GPURenderLoop 是主渲染路径，不需要等 WebGPU
        const overlay = document.getElementById('init-overlay');
        if (overlay) overlay.classList.add('hidden');

        console.info(
          `[gpu-world] GPURenderLoop started — ${cells.length} cells,`,
          `${edges.length} edges, 7-pass chain active`,
        );

        // ── Req 4: AT shader swap (immediate + deferred confirmation) ──
        if (rawParams) {
          applyATShaders(gpuRenderLoop, rawParams, cells);
          setTimeout(() => {
            if (gpuRenderLoop && rawParams) {
              applyATShaders(gpuRenderLoop, rawParams, cells);
              console.info('[gpu-world] AT shader confirmation pass complete');
            }
          }, 500);
        }

      } catch (err) {
        console.warn('[gpu-world] GPURenderLoop init failed:', err);
        gpuRenderLoop = null;
      }
    }).catch(err => {
      console.warn('[gpu-world] loadGPUScene failed:', err);
    });

    // ── SSE → GPURenderLoop live bbox bridge (Req 2) ─────────────────────
    // cell_update SSE events dispatch a custom DOM event here so the render
    // loop can nudge individual cell positions without a full scene reload.
    document.addEventListener('world:cell-update', ((ev: CustomEvent) => {
      if (!gpuRenderLoop) return;
      const { cell_id, bbox } = ev.detail ?? {};
      if (cell_id && bbox) {
        gpuRenderLoop.updateCell?.(cell_id, bbox);
      }
    }) as EventListener);

    // Resize gpu-world canvas with the rest
    window.addEventListener('resize', () => {
      gpuWorldCanvas.width  = Math.floor(window.innerWidth  * devicePixelRatio);
      gpuWorldCanvas.height = Math.floor(window.innerHeight * devicePixelRatio);
    });

    // ── Cleanup on page unload ──────────────────────────────────────────
    window.addEventListener('beforeunload', () => {
      closeSSEAndWatcher();
      cancelAnimationFrame(rafId);
      epochSync?.destroy();
      compositor?.destroy();
      pipeline?.destroy();
      orchestrator?.destroy();
      astroPipeline?.dispose();
      terminatePhysicsWorker();
      gpuDevice?.destroy();
      gpuRenderLoop?.stop();
    });
  })();

  // M1208: standalone boot removed — _startGPURenderLoop handles all cell rendering
</script>

<script>
  // ═══════════════════════════════════════════════════════════════════════════
  //  M1060: AT WebGL2 Render Pipeline — compiled.vs → bloom → present
  //
  //  Wires the AT render pipeline to #at-canvas via raw WebGL2:
  //    1. Parse compiled.vs (173 shaders, {@} delimited) with ATShaderLoader
  //    2. Build WebGL2 context on #at-canvas
  //    3. Compile shaders: scene quad + UnrealBloomLuminosity + UnrealBloomGaussian
  //       + UnrealBloomComposite — all sourced from compiled.vs
  //    4. Render loop:  clear → draw fullscreen gradient quad → bloom luminosity
  //       extract → 2-pass gaussian blur → bloom composite → present to canvas
  //
  //  Bloom params from uil-params.json UnrealBloomComposite:
  //    bloomStrength = 1.0, bloomRadius = 1.0, luminosityThreshold = 0.0
  //    (globalbloom: strength 0.3 / radius 0.2 — used for world scene)
  // ═══════════════════════════════════════════════════════════════════════════

  import { ATShaderLoader } from '@/lib/sph/at-shader-loader';

  (async () => {
    // M1208: AT canvas disabled — it renders a demo scene (Fresnel sphere)
    // that covers the actual GPURenderLoop cell rendering on #gpu-world.
    // AT shaders are still available via ShaderLoader.ts for GPU passes.
    const atCanvas = document.getElementById('at-canvas') as HTMLCanvasElement;
    if (atCanvas) {
      atCanvas.style.display = 'none';
    }
    console.info('[M1060] AT canvas disabled — GPU passes use ShaderLoader instead');
  })();
</script>
