---
/**
 * index.astro — 产品着陆页 + Generate 入口
 *
 * 解决问题: 用户访问 :4321 看到博客首页, Generate 功能不可见
 * 方案: Hero 展示 SVGFigure + Pipeline四步特性 + Generate CTA
 *       博客列表降级到底部 section
 *
 * 保留所有 astro-pure 导入, 不自创样式
 * GitHub 背书: cworld1/astro-theme-pure, withastro/astro
 */
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import config from '@/site-config'

const MAX_POSTS = 5
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#4F46E5'>
  <main class='flex w-full flex-col items-center'>
    {/* ===== Hero: SVGFigure Product ===== */}
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'SVGFigure'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>SVGFigure</h1>
        <p class='max-w-lg text-center text-muted-foreground'>
          Generate publication-quality academic figures from text descriptions.
          Powered by ELK.js constraint layout + Gemini NanoBanana.
        </p>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='ELK.js Layout'>
            <Icon name='grid' class='size-5' slot='icon' />
          </Label>
          <Label title='NanoBanana SVG'>
            <Icon name='heart' class='size-5' slot='icon' />
          </Label>
          <Label
            title='GitHub'
            as='a'
            href='https://github.com/dylanyunlon/astro-svgfigure'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

      {/* CTA: Go to Generate page */}
      <a
        href='/generate'
        class='flex flex-row items-center gap-x-3 rounded-full border bg-background px-6 py-2.5 text-sm shadow-sm transition-shadow hover:shadow-md'
      >
        <span class='relative flex items-center justify-center'>
          <span
            class='absolute size-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'
          ></span>
          <span class='size-2 rounded-full bg-green-400'></span>
        </span>
        <p class='font-medium text-foreground'>Start Generating</p>
      </a>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      {/* ===== Pipeline Overview ===== */}
      <Section title='Pipeline'>
        <p class='text-muted-foreground'>
          A four-step forward pipeline that transforms paper method descriptions into
          beautiful SVG figures. Unlike the reverse approach (image → SAM3 → SVG),
          we go forward: text → topology → layout → SVG.
        </p>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <Card
            heading='1. LLM Topology'
            subheading='Gemini analyzes your text and extracts the computational flow as structured ELK JSON with zero coordinates.'
          />
          <Card
            heading='2. ELK.js Layout'
            subheading='The constraint solver computes precise pixel positions (x, y, width, height) for every node and edge routing.'
          />
          <Card
            heading='3. NanoBanana'
            subheading='The layouted JSON scaffold is sent to Gemini NanoBanana to generate neural-network-level beautiful SVG.'
          />
          <Card
            heading='4. SVG Output'
            subheading='The final SVG is rendered in the browser with zoom controls, export to SVG/PNG, and clipboard copy.'
          />
        </div>
        <Button title='Try it now' class='w-fit self-end' href='/generate' variant='ahead' />
      </Section>

      {/* ===== Tech Stack ===== */}
      <Section title='Stack'>
        <p class='text-muted-foreground'>
          Built on proven open-source foundations with GitHub backing.
        </p>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='https://github.com/kieler/elkjs'
            heading='ELK.js'
            subheading='Eclipse Layout Kernel — constraint-based graph layout'
            imagePath='/src/assets/projects/1.avif'
          />
          <ProjectCard
            href='https://github.com/cworld1/astro-theme-pure'
            heading='Astro Pure'
            subheading='Beautiful Astro theme with extensive component library'
            imagePath='/src/assets/projects/2.avif'
          />
          <ProjectCard
            href='https://github.com/ResearAI/AutoFigure'
            heading='AutoFigure'
            subheading='LLM-driven academic figure generation research'
            imagePath='/src/assets/projects/3.avif'
          />
          <ProjectCard
            href='/generate'
            heading='Generate Now →'
            subheading='Create your first academic figure in seconds'
            imagePath='/src/assets/projects/4.avif'
          />
        </div>
      </Section>

      {/* ===== Blog Posts (降级到底部) ===== */}
      {
        allPostsByDate.length > 0 && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
