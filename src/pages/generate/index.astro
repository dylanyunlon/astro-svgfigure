---
/**
 * /generate — 核心 Pipeline 生成页
 *
 * 正向流程: Text → Topology → ELK Layout → NanoBanana SVG
 * 使用 astro-pure 组件 (Card, Button, Collapse, Label)
 * 使用 GenerateLayout 全宽布局
 *
 * GitHub 背书: withastro/astro, cworld1/astro-theme-pure, kieler/elkjs
 */
export const prerender = false

import { Button, Card, Collapse, Label } from 'astro-pure/user'
import GenerateLayout from '@/layouts/GenerateLayout.astro'
import TextInput from '@/components/pipeline/TextInput.astro'
import PipelineSteps from '@/components/pipeline/PipelineSteps.astro'
import SvgPreview from '@/components/pipeline/SvgPreview.astro'
import ExportPanel from '@/components/pipeline/ExportPanel.astro'
import ErrorDisplay from '@/components/pipeline/ErrorDisplay.astro'
import HealthCheck from '@/components/pipeline/HealthCheck.astro'
import ImageGenPanel from '@/components/pipeline/ImageGenPanel.astro'
---

<GenerateLayout meta={{ title: 'Generate Figure' }} highlightColor='#4F46E5'>
  <main class='flex w-full flex-col gap-y-6 py-6'>
    {/* Page header */}
    <div class='flex flex-col items-center gap-y-2 text-center'>
      <h1 class='text-2xl font-medium'>Generate Academic Figure</h1>
      <p class='text-sm text-muted-foreground max-w-xl'>
        Describe your paper method, and we'll generate a publication-quality SVG figure
        using ELK.js constraint layout + Gemini NanoBanana.
      </p>
      <HealthCheck />
    </div>

    {/* Main grid: 3 columns on desktop, stacked on mobile */}
    <div class='grid grid-cols-1 gap-4 lg:grid-cols-12'>

      {/* Left panel: Input + Controls */}
      <div class='flex flex-col gap-y-4 lg:col-span-3'>
        <Card heading='Input'>
          <TextInput />
        </Card>

        <Card heading='Pipeline'>
          <PipelineSteps />
        </Card>

        {/* Generate button */}
        <button
          id='generate-btn'
          class='group flex w-full items-center justify-center gap-x-2 rounded-xl border bg-primary px-4 py-2.5 text-sm font-medium text-white transition-all hover:opacity-90 disabled:opacity-40 disabled:cursor-not-allowed'
        >
          <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
            <polygon points='5 3 19 12 5 21 5 3' />
          </svg>
          <span id='generate-btn-text'>Generate Figure</span>
        </button>

        {/* Options */}
        <Collapse title='Advanced Options'>
          <div class='flex flex-col gap-y-3 pb-2'>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-model'>Model</label>
              <select id='opt-model' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='gemini-2.5-pro'>Gemini 2.5 Pro (strongest)</option>
                <option value='gemini-2.5-flash' selected>Gemini 2.5 Flash (fast)</option>
                <option value='gemini-2.0-flash'>Gemini 2.0 Flash</option>
                <option value='claude-sonnet-4-20250514'>Claude Sonnet 4</option>
                <option value='gpt-4o'>GPT-4o</option>
              </select>
            </div>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-preset'>Layout Preset</label>
              <select id='opt-preset' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='academic-paper'>Academic Paper</option>
                <option value='neural-network'>Neural Network</option>
                <option value='flowchart'>Flowchart</option>
              </select>
            </div>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-direction'>Direction</label>
              <select id='opt-direction' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='DOWN'>Top → Bottom</option>
                <option value='RIGHT'>Left → Right</option>
                <option value='UP'>Bottom → Top</option>
                <option value='LEFT'>Right → Left</option>
              </select>
            </div>
          </div>
        </Collapse>
      </div>

      {/* Center panel: SVG Preview (takes most space) */}
      <div class='flex flex-col gap-y-4 lg:col-span-6'>
        <ErrorDisplay />
        <SvgPreview />
      </div>

      {/* Right panel: Export + JSON preview */}
      <div class='flex flex-col gap-y-4 lg:col-span-3'>
        <Card heading='Export'>
          <ExportPanel />
        </Card>

        <Card heading='Step 5: Scientific Figure'>
          <ImageGenPanel />
        </Card>

        <Collapse title='Topology JSON'>
          <pre id='topology-json' class='overflow-auto rounded-lg bg-background p-3 text-xs text-muted-foreground' style='max-height: 200px;'>
            {/* Will be populated dynamically */}
            Waiting for generation...
          </pre>
        </Collapse>

        <Collapse title='ELK Layouted JSON'>
          <pre id='layouted-json' class='overflow-auto rounded-lg bg-background p-3 text-xs text-muted-foreground' style='max-height: 200px;'>
            Waiting for generation...
          </pre>
        </Collapse>
      </div>
    </div>
  </main>
</GenerateLayout>

<script>
  /**
   * Pipeline orchestrator — runs the 4-step forward pipeline
   *
   * Step 1: Text → Topology JSON (via /api/topology → Python backend)
   * Step 2: Topology → ELK Layout (via /api/layout → elkjs on server)
   * Step 3: Layouted → NanoBanana SVG (via /api/beautify → Python backend)
   * Step 4: Render SVG in preview
   */

  const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement
  const generateBtnText = document.getElementById('generate-btn-text') as HTMLSpanElement
  const textarea = document.getElementById('method-text') as HTMLTextAreaElement
  const statusText = document.getElementById('pipeline-status-text') as HTMLElement
  const elapsedEl = document.getElementById('pipeline-elapsed') as HTMLElement
  const topologyPre = document.getElementById('topology-json') as HTMLPreElement
  const layoutedPre = document.getElementById('layouted-json') as HTMLPreElement

  const steps = (window as any).__pipelineSteps
  const preview = (window as any).__svgPreview
  const exportPanel = (window as any).__exportPanel

  const errorDisplay = (window as any).__errorDisplay
  const imageGenPanel = (window as any).__imageGenPanel

  let running = false
  let startTime = 0
  let timerInterval: number | null = null

  function startTimer() {
    startTime = Date.now()
    timerInterval = window.setInterval(() => {
      const elapsed = ((Date.now() - startTime) / 1000).toFixed(1)
      if (elapsedEl) elapsedEl.textContent = `${elapsed}s`
    }, 100)
  }

  function stopTimer() {
    if (timerInterval) {
      clearInterval(timerInterval)
      timerInterval = null
    }
  }

  generateBtn?.addEventListener('click', async () => {
    if (running) return
    const text = textarea?.value?.trim()
    if (!text) {
      textarea?.focus()
      return
    }

    running = true
    generateBtn.disabled = true
    generateBtnText.textContent = 'Generating...'
    steps?.resetAll()
    preview?.clear()
    exportPanel?.disable()
    errorDisplay?.hide()
    imageGenPanel?.disable()
    startTimer()

    const model = (document.getElementById('opt-model') as HTMLSelectElement)?.value
    const preset = (document.getElementById('opt-preset') as HTMLSelectElement)?.value
    const direction = (document.getElementById('opt-direction') as HTMLSelectElement)?.value

    try {
      // === Step 1: Topology ===
      steps?.setStatus('step-topology', 'running')
      statusText.textContent = 'Step 1: Generating topology...'

      const topoRes = await fetch('/api/topology', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, model, direction }),
      })

      if (!topoRes.ok) {
        const err = await topoRes.json()
        throw new Error(`Topology: ${err.error || 'Failed'}`)
      }

      const topoData = await topoRes.json()
      const topology = topoData.topology || topoData.graph || topoData
      topologyPre.textContent = JSON.stringify(topology, null, 2)
      steps?.setStatus('step-topology', 'done')

      // === Step 2: ELK Layout ===
      steps?.setStatus('step-elk', 'running')
      statusText.textContent = 'Step 2: Computing ELK layout...'

      const layoutRes = await fetch('/api/layout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ graph: topology, preset, options: { direction } }),
      })

      if (!layoutRes.ok) {
        const err = await layoutRes.json()
        throw new Error(`Layout: ${err.error || 'Failed'}`)
      }

      const layoutData = await layoutRes.json()
      const layouted = layoutData.layouted
      const skeletonSvg = layoutData.skeletonSvg
      layoutedPre.textContent = JSON.stringify(layouted, null, 2)
      if (skeletonSvg) {
        preview?.showSkeleton(skeletonSvg)
      }
      steps?.setStatus('step-elk', 'done')

      // === Step 3: NanoBanana SVG ===
      steps?.setStatus('step-nanobanana', 'running')
      statusText.textContent = 'Step 3: NanoBanana generating SVG...'

      const beautyRes = await fetch('/api/beautify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ layouted, model }),
      })

      if (!beautyRes.ok) {
        const err = await beautyRes.json()
        throw new Error(`Beautify: ${err.error || 'Failed'}`)
      }

      const beautyData = await beautyRes.json()
      const svg = beautyData.svg || beautyData.content || ''
      steps?.setStatus('step-nanobanana', 'done')

      // === Step 4: Render ===
      steps?.setStatus('step-output', 'running')
      statusText.textContent = 'Step 4: Rendering SVG...'

      if (svg) {
        preview?.show(svg)
        exportPanel?.enable()
        // Enable Step 5: Scientific figure generation
        const methodText = textarea?.value?.trim() || ''
        imageGenPanel?.enable(svg, methodText)
      }

      steps?.setStatus('step-output', 'done')
      statusText.textContent = 'Done!'
    } catch (err: any) {
      // Mark current running step as error
      document.querySelectorAll('.pipeline-step[data-status="running"]').forEach((el) => {
        ;(el as HTMLElement).dataset.status = 'error'
      })
      // Parse error for structured display
      let errorMsg = err.message || 'Unknown error'
      let hint = ''
      let step = ''
      if (errorMsg.includes('Topology')) step = 'Step 1 (Topology)'
      else if (errorMsg.includes('Layout')) step = 'Step 2 (ELK Layout)'
      else if (errorMsg.includes('Beautify')) step = 'Step 3 (NanoBanana)'
      else step = 'Step 4 (Render)'

      if (errorMsg.includes('502') || errorMsg.includes('Failed to connect')) {
        hint = 'Make sure Python backend is running: python server.py'
      } else if (errorMsg.includes('ELK layout failed')) {
        hint = 'The topology JSON may have invalid format. Try a different model or simpler description.'
      } else if (errorMsg.includes('500') || errorMsg.includes('API_KEY')) {
        hint = 'Check GEMINI_API_KEY in .env file'
      } else if (errorMsg.includes('504') || errorMsg.includes('timed out')) {
        hint = 'Try a faster model like gemini-2.0-flash'
      } else if (errorMsg.includes('Beautify') || errorMsg.includes('NanoBanana')) {
        hint = 'NanoBanana SVG generation failed. The layout was successful — try regenerating.'
      } else if (errorMsg.includes('401') || errorMsg.includes('403')) {
        hint = 'API key is invalid or expired. Check your .env configuration.'
      }

      errorDisplay?.show({ title: 'Pipeline Error', message: errorMsg, hint, step })
      statusText.textContent = `Error: ${errorMsg}`
      statusText.style.color = 'var(--color-danger, #ef4444)'
      console.error('Pipeline error:', err)
    } finally {
      stopTimer()
      running = false
      generateBtn.disabled = false
      generateBtnText.textContent = 'Generate Figure'
    }
  })
</script>
