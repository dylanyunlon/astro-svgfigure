---
/**
 * /generate — 核心 Pipeline 生成页 (3-Step 重构版)
 *
 * 新流程:
 *   Step 1: Text → LLM 拓扑 → ELK.js 布局 → 骨架 SVG (用户确认组件无缺失)
 *   Step 2: Stylist 反推专业 prompt (从骨架 SVG + method text)
 *   Step 3: Gemini 3 Pro Image → 科研级图片 (4K PNG)
 *
 * 使用 astro-pure 组件 (Card, Button, Collapse, Label)
 * GitHub 背书: withastro/astro, cworld1/astro-theme-pure, kieler/elkjs
 */
export const prerender = false

import { Button, Card, Collapse, Label } from 'astro-pure/user'
import GenerateLayout from '@/layouts/GenerateLayout.astro'
import TextInput from '@/components/pipeline/TextInput.astro'
import PipelineSteps from '@/components/pipeline/PipelineSteps.astro'
import SvgPreview from '@/components/pipeline/SvgPreview.astro'
import SvgEditor from '@/components/pipeline/SvgEditor.astro'
import ExportPanel from '@/components/pipeline/ExportPanel.astro'
import ErrorDisplay from '@/components/pipeline/ErrorDisplay.astro'
import HealthCheck from '@/components/pipeline/HealthCheck.astro'
import PostGenPanel from '@/components/pipeline/PostGenPanel.astro'
---

<GenerateLayout meta={{ title: 'Generate Figure' }} highlightColor='#4F46E5'>
  <main class='flex w-full flex-col gap-y-6 py-6'>
    <div class='flex flex-col items-center gap-y-2 text-center'>
      <h1 class='text-2xl font-medium'>Generate Academic Figure</h1>
      <p class='text-sm text-muted-foreground max-w-xl'>
        Describe your paper method → Planner Agent generates layout draft →
        Stylist Agent refines the description → Visualizer produces publication-quality figure.
      </p>
      <HealthCheck />
    </div>

    <div class='grid grid-cols-1 gap-4 lg:grid-cols-12'>
      {/* Left panel */}
      <div class='flex flex-col gap-y-4 lg:col-span-3'>
        <Card heading='Input'>
          <TextInput />
        </Card>

        <Card heading='Pipeline'>
          <PipelineSteps />
        </Card>

        <button id='generate-btn'
          class='group flex w-full items-center justify-center gap-x-2 rounded-xl border bg-primary px-4 py-2.5 text-sm font-medium text-white transition-all hover:opacity-90 disabled:opacity-40 disabled:cursor-not-allowed'>
          <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
            <polygon points='5 3 19 12 5 21 5 3' />
          </svg>
          <span id='generate-btn-text'>Step 1: Generate Draft</span>
        </button>

        <button id='generate-figure-btn' disabled
          class='group flex w-full items-center justify-center gap-x-2 rounded-xl border bg-primary px-4 py-2.5 text-sm font-medium text-white transition-all hover:opacity-90 disabled:opacity-40 disabled:cursor-not-allowed'>
          <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
            <path d='M15 8h.01M3 6a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v12a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6z' />
            <path d='m3 16 5-5c.928-.893 2.072-.893 3 0l5 5' />
          </svg>
          <span id='generate-figure-text'>Step 2→3: Generate Figure</span>
        </button>

        <button id='generate-sprites-btn' disabled
          class='group flex w-full items-center justify-center gap-x-2 rounded-xl border border-primary/30 bg-primary/10 px-4 py-2 text-sm font-medium text-primary transition-all hover:bg-primary/20 disabled:opacity-40 disabled:cursor-not-allowed'>
          <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
            <rect x='3' y='3' width='7' height='7' rx='1' />
            <rect x='14' y='3' width='7' height='7' rx='1' />
            <rect x='3' y='14' width='7' height='7' rx='1' />
            <rect x='14' y='14' width='7' height='7' rx='1' />
          </svg>
          <span id='generate-sprites-text'>Generate Sprites (per-node AI)</span>
        </button>

        <button id='generate-enriched-figure-btn' disabled
          class='group flex w-full items-center justify-center gap-x-2 rounded-xl border border-purple-400/30 bg-purple-600 px-4 py-2.5 text-sm font-medium text-white transition-all hover:bg-purple-700 disabled:opacity-40 disabled:cursor-not-allowed'>
          <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
            <path d='M15 8h.01M3 6a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v12a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6z' />
            <path d='m3 16 5-5c.928-.893 2.072-.893 3 0l5 5' />
            <circle cx='18' cy='5' r='2' fill='currentColor' opacity='0.5' />
          </svg>
          <span id='generate-enriched-figure-text'>Step 2→3: Sprite-Enriched Figure</span>
        </button>

        <Collapse title='Advanced Options'>
          <div class='flex flex-col gap-y-3 pb-2'>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-preset'>Layout Preset</label>
              <select id='opt-preset' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='academic-paper'>Academic Paper</option>
                <option value='neural-network'>Neural Network</option>
                <option value='flowchart'>Flowchart</option>
              </select>
            </div>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-direction'>Direction</label>
              <select id='opt-direction' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='DOWN'>Top → Bottom</option>
                <option value='RIGHT'>Left → Right</option>
                <option value='UP'>Bottom → Top</option>
                <option value='LEFT'>Right → Left</option>
              </select>
            </div>
            <div class='flex flex-col gap-y-1'>
              <label class='text-xs text-muted-foreground' for='opt-aspect'>Image Aspect Ratio</label>
              <select id='opt-aspect' class='rounded-lg border bg-muted px-3 py-1.5 text-sm text-foreground'>
                <option value='16:9' selected>16:9 (Landscape)</option>
                <option value='4:3'>4:3</option>
                <option value='1:1'>1:1 (Square)</option>
              </select>
            </div>
          </div>
        </Collapse>

        <Collapse title='Stylist Prompt (Editable)'>
          <div class='flex flex-col gap-y-2 pb-2'>
            <textarea id='stylist-prompt-text' rows='6'
              class='w-full rounded-lg border bg-muted p-2 text-xs text-foreground placeholder:text-muted-foreground'
              placeholder='Waiting for Step 2... The Stylist Agent will auto-generate a refined description. You can then edit it before clicking Regenerate.'></textarea>
            <p id='stylist-prompt-hint' class='text-xs text-muted-foreground'>Run Step 2→3 to generate description. Edit to refine the final image.</p>
          </div>
        </Collapse>
      </div>

      {/* Center panel */}
      <div class='flex flex-col gap-y-4 lg:col-span-6'>
        <ErrorDisplay />
        <SvgEditor />
        <SvgPreview />

        <div id='final-image-section' class='hidden'>
          <div class='flex items-center justify-between mb-2'>
            <span class='text-sm font-medium'>Scientific Figure (Visualizer Output)</span>
            <div class='flex gap-x-2'>
              <button id='download-image-btn' class='rounded-lg border px-3 py-1 text-xs font-medium text-muted-foreground hover:bg-muted'>Download PNG</button>
              <button id='regenerate-btn' class='rounded-lg border bg-primary px-3 py-1 text-xs font-medium text-white hover:opacity-90'>Regenerate</button>
            </div>
          </div>
          <div class='overflow-hidden rounded-xl border'>
            <img id='final-image' class='h-auto w-full' alt='Generated scientific figure' />
          </div>
          <p id='final-image-info' class='mt-1 text-xs text-muted-foreground'></p>
        </div>

        {/* Post-Generation Pipeline: removebg → layers → edges → export */}
        <PostGenPanel />
      </div>

      {/* Right panel */}
      <div class='flex flex-col gap-y-4 lg:col-span-3'>
        <Card heading='Export SVG'>
          <ExportPanel />
        </Card>
        <Collapse title='Planner Output JSON'>
          <pre id='topology-json' class='overflow-auto rounded-lg bg-background p-3 text-xs text-muted-foreground' style='max-height: 200px;'>Waiting...</pre>
        </Collapse>
        <Collapse title='Structured Layout Data'>
          <pre id='layouted-json' class='overflow-auto rounded-lg bg-background p-3 text-xs text-muted-foreground' style='max-height: 200px;'>Waiting...</pre>
        </Collapse>
      </div>
    </div>
  </main>
</GenerateLayout>

<script>
  // === 3-Step Pipeline Orchestrator ===
  const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement
  const generateBtnText = document.getElementById('generate-btn-text') as HTMLSpanElement
  const generateFigureBtn = document.getElementById('generate-figure-btn') as HTMLButtonElement
  const generateFigureText = document.getElementById('generate-figure-text') as HTMLSpanElement
  const generateSpritesBtn = document.getElementById('generate-sprites-btn') as HTMLButtonElement
  const generateSpritesText = document.getElementById('generate-sprites-text') as HTMLSpanElement
  const generateEnrichedBtn = document.getElementById('generate-enriched-figure-btn') as HTMLButtonElement
  const generateEnrichedText = document.getElementById('generate-enriched-figure-text') as HTMLSpanElement
  const textarea = document.getElementById('method-text') as HTMLTextAreaElement
  const statusText = document.getElementById('pipeline-status-text') as HTMLElement
  const elapsedEl = document.getElementById('pipeline-elapsed') as HTMLElement
  const topologyPre = document.getElementById('topology-json') as HTMLPreElement
  const layoutedPre = document.getElementById('layouted-json') as HTMLPreElement
  const promptTextarea = document.getElementById('stylist-prompt-text') as HTMLTextAreaElement
  const finalImageSection = document.getElementById('final-image-section') as HTMLElement
  const finalImage = document.getElementById('final-image') as HTMLImageElement
  const finalImageInfo = document.getElementById('final-image-info') as HTMLElement
  const downloadBtn = document.getElementById('download-image-btn') as HTMLButtonElement
  const regenerateBtn = document.getElementById('regenerate-btn') as HTMLButtonElement
  const steps = (window as any).__pipelineSteps
  const preview = (window as any).__svgPreview
  const exportPanel = (window as any).__exportPanel
  const errorDisplay = (window as any).__errorDisplay

  let running = false, startTime = 0, timerInterval: number | null = null
  let currentSkeletonSvg = '', currentImageB64 = '', currentMimeType = 'image/png'
  let spriteCacheKey = ''  // Server-side sprite cache key from /api/sprite-generate

  function startTimer() {
    startTime = Date.now()
    timerInterval = window.setInterval(() => {
      if (elapsedEl) elapsedEl.textContent = `${((Date.now() - startTime) / 1000).toFixed(1)}s`
    }, 100)
  }
  function stopTimer() { if (timerInterval) { clearInterval(timerInterval); timerInterval = null } }
  function elapsed() { return ((Date.now() - startTime) / 1000).toFixed(1) }

  // ===== STEP 1: LLM Topology + ELK Layout → Skeleton SVG =====
  generateBtn?.addEventListener('click', async () => {
    if (running) return
    const text = textarea?.value?.trim()
    if (!text) { textarea?.focus(); return }

    running = true
    generateBtn.disabled = true
    generateFigureBtn.disabled = true
    generateBtnText.textContent = 'Generating...'
    steps?.resetAll()
    preview?.clear()
    exportPanel?.disable()
    errorDisplay?.hide()
    finalImageSection?.classList.add('hidden')
    promptTextarea.value = ''
    // Reset confirm button
    ;(window as any).__svgEditor?.resetConfirm()
    startTimer()

    const preset = (document.getElementById('opt-preset') as HTMLSelectElement)?.value
    const direction = (document.getElementById('opt-direction') as HTMLSelectElement)?.value

    try {
      steps?.setStatus('step-topology', 'running')
      statusText.textContent = 'Step 1: Planner analyzing structure...'

      const topoRes = await fetch('/api/topology', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, direction }),
      })
      if (!topoRes.ok) { const e = await topoRes.json(); throw new Error(`Topology: ${e.error || 'Failed'}`) }
      const topoData = await topoRes.json()
      const topology = topoData.topology || topoData.graph || topoData
      topologyPre.textContent = JSON.stringify(topology, null, 2)

      statusText.textContent = 'Step 1: Computing layout composition...'
      const layoutRes = await fetch('/api/layout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ graph: topology, preset, options: { direction } }),
      })
      if (!layoutRes.ok) { const e = await layoutRes.json(); throw new Error(`Layout: ${e.error || 'Failed'}`) }
      const layoutData = await layoutRes.json()
      layoutedPre.textContent = JSON.stringify(layoutData.layouted, null, 2)

      currentSkeletonSvg = layoutData.skeletonSvg || ''
      const currentIconSvg = layoutData.iconSvg || ''
      if (currentSkeletonSvg) {
        // Pass both SVG and layouted JSON — enables interactive editor
        preview?.showSkeleton(currentSkeletonSvg, layoutData.layouted)
        if (currentIconSvg) preview?.showIconSvg(currentIconSvg)
        preview?.show(currentSkeletonSvg)
        // Auto-switch to skeleton tab so user can verify components
        document.getElementById('tab-skeleton')?.click()
        exportPanel?.enable()
      } else if (layoutData.layouted) {
        // SVG generation failed but we have layouted data — try interactive rendering
        console.warn('skeletonSvg empty, falling back to interactive render from layouted JSON')
        preview?.showSkeleton('', layoutData.layouted)
        if (currentIconSvg) preview?.showIconSvg(currentIconSvg)
        document.getElementById('tab-skeleton')?.click()
        exportPanel?.enable()
      }

      steps?.setStatus('step-topology', 'done')
      steps?.setStatus('step-edit', 'running')
      statusText.textContent = `Step 1 done (${elapsed()}s) — Edit draft below, then click "Confirm Edit" → "Step 2→3"`
      statusText.style.color = ''
      // Step 2→3 stays disabled until user clicks "Confirm Edit"
      generateFigureBtn.disabled = true

    } catch (err: any) {
      document.querySelectorAll('.pipeline-step[data-status="running"]').forEach(el => {
        ;(el as HTMLElement).dataset.status = 'error'
      })
      const msg = err.message || 'Unknown error'
      let hint = ''
      if (msg.includes('502') || msg.includes('connect')) hint = 'Start backend: python server.py'
      else if (msg.includes('ELK')) hint = 'Try simpler description'
      else if (msg.includes('500')) hint = 'Check API keys in .env'
      errorDisplay?.show({ title: 'Step 1 Error', message: msg, hint, step: 'Step 1' })
      statusText.textContent = `Error: ${msg}`
      statusText.style.color = 'hsl(0 72.2% 50.6%)'
    } finally {
      stopTimer(); running = false
      generateBtn.disabled = false
      generateBtnText.textContent = 'Step 1: Generate Draft'
    }
  })

  // ===== STEP 2→3: Stylist prompt + Gemini 3 image =====
  generateFigureBtn?.addEventListener('click', () => runFigureGen())
  regenerateBtn?.addEventListener('click', () => runFigureGen(promptTextarea.value))

  async function runFigureGen(customPrompt?: string) {
    if (running || !currentSkeletonSvg) return
    const text = textarea?.value?.trim()
    if (!text) return

    running = true
    generateFigureBtn.disabled = true
    generateBtn.disabled = true
    generateFigureText.textContent = 'Generating...'
    errorDisplay?.hide()
    finalImageSection?.classList.add('hidden')
    ;(window as any).__postGenPanel?.hide()
    startTimer()

    const aspect = (document.getElementById('opt-aspect') as HTMLSelectElement)?.value

    // Create AbortController for fetch timeout management
    const controller = new AbortController()
    const timeoutId = setTimeout(() => controller.abort(), 300000) // 5 min timeout

    try {
      // Get latest SVG from interactive editor (user may have edited it)
      // ═══ FIX Break 2: use exportFullSvg() which serializes the LIVE DOM ═══
      // including <image> tags with sprite data: URIs + user-dragged positions.
      // Before this fix, we called getSkeletonSvg() → editor.toStaticSvg()
      // which was correct for basic export, but exportFullSvg() additionally
      // computes tight viewBox from actual node bounds and logs sprite stats.
      const editor = preview?.getEditor()
      if (editor) {
        // Use the sprite-rich DOM serialization, not elkToSvg() re-render
        currentSkeletonSvg = editor.exportFullSvg()
        // Debug: print state so developer can verify data at this breakpoint
        console.log('[runFigureGen] Editor state at generation time:')
        editor.debugDumpState()
      } else {
        const editorSvg = preview?.getSkeletonSvg()
        if (editorSvg) currentSkeletonSvg = editorSvg
        console.log('[runFigureGen] No interactive editor — using static SVG, length=' + currentSkeletonSvg.length)
      }

      // ═══ FIX Break 3: pass the FULL layouted JSON (nested children + spriteRef) ═══
      // editor.getGraph() returns InteractiveGraph (flat), which loses spriteRef/familyId.
      // preview.getLayoutedJson() returns the original ELK JSON with nested structure +
      // spriteRef URLs from inject_sprites. This is what the backend needs for classify_nodes.
      const elkGraph = preview?.getLayoutedJson() || (editor ? editor.getGraph() : null)

      // Debug: log what we're sending so developer can verify Break 3 is fixed
      const _elkChildren = elkGraph?.children?.length || 0
      const _elkEdges = elkGraph?.edges?.length || 0
      const _hasSprites = JSON.stringify(elkGraph || '').includes('spriteRef')
      console.log(
        `[runFigureGen] POST payload: svg_content=${currentSkeletonSvg.length} chars, ` +
        `elk_graph=${_elkChildren} children/${_elkEdges} edges, hasSprites=${_hasSprites}`
      )

      // Mark edit step as done
      steps?.setStatus('step-edit', 'done')

      // Step 2: Stylist prompt
      steps?.setStatus('step-stylist-prompt', 'running')
      if (!customPrompt) {
        statusText.textContent = 'Step 2: Stylist refining description...'
        const pRes = await fetch('/api/generate-prompt', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            method_text: text, svg_content: currentSkeletonSvg,
            elk_graph: elkGraph,
          }),
          signal: controller.signal,
        })
        if (!pRes.ok) { const e = await pRes.json(); throw new Error(`Stylist: ${e.error || 'Failed'}`) }
        const pData = await pRes.json()
        if (pData.success && pData.prompt) {
          promptTextarea.value = pData.prompt
          customPrompt = pData.prompt
          // Highlight prompt area to show it's editable
          promptTextarea.classList.add('ring-2', 'ring-primary')
          const hint = document.getElementById('stylist-prompt-hint')
          if (hint) hint.textContent = 'Prompt generated. Edit above and click Regenerate to refine.'
          setTimeout(() => promptTextarea.classList.remove('ring-2', 'ring-primary'), 3000)
        } else { throw new Error(`Stylist: ${pData.error || 'Empty prompt'}`) }
      }
      steps?.setStatus('step-stylist-prompt', 'done')

      // Step 3: Gemini 3 Image
      steps?.setStatus('step-gemini-image', 'running')
      statusText.textContent = 'Step 3: Visualizer generating figure...'
      const iRes = await fetch('/api/generate-image', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          svg_content: currentSkeletonSvg, method_text: text,
          custom_prompt: customPrompt, aspect_ratio: aspect || '16:9', image_size: '4K',
          elk_graph: elkGraph,
        }),
        signal: controller.signal,
      })
      // Guard: handle HTML error responses (Vercel 413 body too large, Astro 404, etc.)
      const _ct = iRes.headers.get('content-type') || ''
      if (!_ct.includes('application/json')) {
        const _body = await iRes.text()
        console.error('[runFigureGen] Non-JSON response:', iRes.status, _body.slice(0, 300))
        throw new Error(`Server returned ${iRes.status} (not JSON). Body may be too large or route missing.`)
      }
      if (!iRes.ok) { const e = await iRes.json(); throw new Error(`Gemini: ${e.error || 'Failed'}`) }
      const iData = await iRes.json()

      if (iData.success && iData.image_b64) {
        currentImageB64 = iData.image_b64
        currentMimeType = iData.mime_type || 'image/png'
        finalImage.src = `data:${currentMimeType};base64,${currentImageB64}`
        finalImageSection?.classList.remove('hidden')
        // Auto-switch to Final tab to show the generated image
        document.getElementById('tab-final')?.click()
        finalImageInfo.textContent = `Prompt: ${iData.prompt_model_used || '?'} → Image: ${iData.image_model_used || '?'} | ${elapsed()}s`
        steps?.setStatus('step-gemini-image', 'done')
        statusText.textContent = `Figure generated (${elapsed()}s) — Starting post-generation pipeline...`
        statusText.style.color = ''

        // === BRIDGE: Show PostGenPanel and auto-run pipeline ===
        const postGen = (window as any).__postGenPanel
        if (postGen) {
          postGen.show(currentImageB64, currentMimeType, elkGraph)
          // Auto-run the pipeline after a brief pause to let the UI update
          setTimeout(() => postGen.runPipeline(), 500)
        }
      } else { throw new Error(`Gemini: ${iData.error || 'No image'}`) }

    } catch (err: any) {
      document.querySelectorAll('.pipeline-step[data-status="running"]').forEach(el => {
        ;(el as HTMLElement).dataset.status = 'error'
      })
      let msg = err.message || 'Unknown error'
      // Handle AbortError (timeout)
      if (err.name === 'AbortError') {
        msg = 'Request timed out (5 min). The API may be slow or the input too complex.'
      }
      let hint = ''
      if (msg.includes('Stylist')) hint = 'Check API key for the Stylist Agent (uses OpenAI format)'
      else if (msg.includes('Gemini')) hint = 'Check API key for the Visualizer Agent.'
      else if (msg.includes('502')) hint = 'Start backend: python server.py'
      else if (msg.includes('timed out')) hint = 'Image gen can take ~2min. Try again.'
      errorDisplay?.show({ title: 'Figure Error', message: msg, hint, step: 'Step 2-3' })
      statusText.textContent = `Error: ${msg}`
      statusText.style.color = 'hsl(0 72.2% 50.6%)'
    } finally {
      clearTimeout(timeoutId)
      stopTimer(); running = false
      generateFigureBtn.disabled = false; generateBtn.disabled = false
      generateFigureText.textContent = 'Step 2→3: Generate Figure'
    }
  }

  downloadBtn?.addEventListener('click', () => {
    if (!currentImageB64) return
    const link = document.createElement('a')
    link.href = `data:${currentMimeType};base64,${currentImageB64}`
    link.download = `scientific-figure.${currentMimeType.split('/')[1] || 'png'}`
    link.click()
  })

  // ===== SVG Editor Toolbar Wiring =====
  const svgEditor = (window as any).__svgEditor

  // Re-Layout: send modified graph back to ELK
  document.getElementById('btn-relayout')?.addEventListener('click', async () => {
    const elkJson = preview?.getElkJson()
    if (!elkJson) return
    const preset = (document.getElementById('opt-preset') as HTMLSelectElement)?.value
    const direction = (document.getElementById('opt-direction') as HTMLSelectElement)?.value
    try {
      const res = await fetch('/api/layout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ graph: elkJson, preset, options: { direction } }),
      })
      if (!res.ok) throw new Error('Re-layout failed')
      const data = await res.json()
      if (data.layouted) {
        preview?.showSkeleton(data.skeletonSvg || '', data.layouted)
        if (data.iconSvg) preview?.showIconSvg(data.iconSvg)
        currentSkeletonSvg = data.skeletonSvg || preview?.getSkeletonSvg() || ''
        layoutedPre.textContent = JSON.stringify(data.layouted, null, 2)
      }
    } catch (err: any) {
      errorDisplay?.show({ title: 'Re-Layout Error', message: err.message, hint: '', step: 'Editor' })
    }
  })

  // Add Node
  document.getElementById('btn-add-node')?.addEventListener('click', () => {
    const editor = preview?.getEditor()
    if (editor) {
      const name = prompt('Node label:', 'New Node')
      if (name) editor.addNode(name)
    }
  })

  // Delete Node
  document.getElementById('btn-delete-node')?.addEventListener('click', () => {
    const editor = preview?.getEditor()
    if (editor) editor.removeSelectedNode()
  })

  // Fit View
  document.getElementById('btn-fit-view')?.addEventListener('click', () => {
    const editor = preview?.getEditor()
    if (editor) editor.fitView()
  })

  // Export SVG
  document.getElementById('btn-export-svg')?.addEventListener('click', () => {
    const svg = preview?.getSkeletonSvg() || preview?.getSvg()
    if (!svg) return
    const blob = new Blob([svg], { type: 'image/svg+xml' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a')
    a.href = url
    a.download = 'skeleton.svg'
    a.click()
    URL.revokeObjectURL(url)
  })

  // Export JSON
  document.getElementById('btn-export-json')?.addEventListener('click', () => {
    const json = preview?.getElkJson()
    if (!json) return
    const blob = new Blob([JSON.stringify(json, null, 2)], { type: 'application/json' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a')
    a.href = url
    a.download = 'layout.json'
    a.click()
    URL.revokeObjectURL(url)
  })

  // Snap to grid toggle
  document.getElementById('chk-snap-grid')?.addEventListener('change', (e) => {
    // Note: snap-to-grid is set at editor init time; toggle requires re-init
    // For now, this is a visual indicator only
  })

  // ===== CONFIRM EDIT =====
  document.getElementById('btn-confirm-edit')?.addEventListener('click', () => {
    // Try to get updated SVG from interactive editor or tldraw
    const editor = preview?.getEditor()
    const tldrawApi = (window as any).__tldrawEditor

    if (tldrawApi) {
      const g = tldrawApi.exportGraph()
      if (g) {
        import('@/lib/elk/to-svg').then(({ default: elkToSvg }) => {
          currentSkeletonSvg = elkToSvg(g) || currentSkeletonSvg
        })
      }
    } else if (editor) {
      editor.confirmEdit()
      currentSkeletonSvg = editor.toStaticSvg() || currentSkeletonSvg
    }
    // else: no editor, but currentSkeletonSvg from Step 1 is still valid

    // Visual feedback — always runs regardless of editor state
    const svgEditor = (window as any).__svgEditor
    svgEditor?.setConfirmed(true)
    steps?.setStatus('step-edit', 'done')
    generateFigureBtn.disabled = false
    generateSpritesBtn.disabled = false
    statusText.textContent = 'Draft confirmed! Click "Generate Sprites" → Gemini AI images will replace placeholders in the Editor tab.'
    statusText.style.color = ''
  })

  // ===== GENERATE SPRITES (per-node Gemini interleaved) =====
  generateSpritesBtn?.addEventListener('click', async () => {
    // Use the original ELK layouted JSON (nested children tree with renderMode etc),
    // NOT the interactive editor's flat graph — classify_nodes needs the nested structure.
    const elkGraph = preview?.getLayoutedJson() || preview?.getElkJson()
    if (!elkGraph) {
      statusText.textContent = 'No layout data — run Step 1 first'
      return
    }

    generateSpritesBtn.disabled = true
    generateSpritesText.textContent = 'Generating sprites...'
    statusText.textContent = 'Calling Gemini for per-node sprites...'

    try {
      const res = await fetch('/api/sprite-generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ elk_graph: elkGraph }),
      })
      const data = await res.json()

      if (data.success && data.elk_graph) {
        // ═══ ARCHITECTURE: sprites → Skeleton interactive editor (not tldraw) ═══
        // The sprite-enriched ELK graph goes to the existing InteractiveSvgEditor
        // in the Skeleton tab — same drag/resize/zoom UX, but with Gemini sprite
        // images rendered as <image> elements inside SVG nodes.
        // This preserves the clean ELK-native rendering (arrows, groups, labels)
        // that tldraw couldn't match.

        // 1. Generate static SVG (for export/fallback)
        const { elkToSvg } = await import('@/lib/elk/to-svg')
        const newSvg = elkToSvg(data.elk_graph)
        if (newSvg) {
          currentSkeletonSvg = newSvg
        }

        // 2. Load enriched graph into interactive editor (Skeleton tab)
        //    showSkeleton with layoutedData triggers initInteractiveEditor,
        //    which now renders sprite images via InteractiveNode.spriteUrl
        preview?.showSkeleton(newSvg || '', data.elk_graph)

        // 3. Switch to Skeleton tab — the primary editing surface
        document.getElementById('tab-skeleton')?.click()

        const diag = data.diagnostics || {}
        const injDiag = diag.injection || diag
        statusText.textContent = `Sprites done: ${injDiag.refs_stamped || 0} injected. Drag nodes to rearrange.`

        // Enable the "Sprite-Enriched Figure" button now that we have sprites
        if (generateEnrichedBtn) {
          generateEnrichedBtn.disabled = false
          // Store server-side sprite cache key — avoids re-sending 7+ MB through nginx
          spriteCacheKey = data.sprite_cache_key || ''
          console.log(
            `[Sprites] Enriched figure button enabled. ` +
            `refs_stamped=${injDiag.refs_stamped || 0}, ` +
            `elk_graph children=${data.elk_graph?.children?.length || 0}, ` +
            `sprite_cache_key=${spriteCacheKey}`
          )
        }
      } else {
        statusText.textContent = `Sprite error: ${data.error || 'Unknown'}`
      }
    } catch (err: any) {
      statusText.textContent = `Sprite error: ${err.message}`
    } finally {
      generateSpritesBtn.disabled = false
      generateSpritesText.textContent = 'Generate Sprites (per-node AI)'
    }
  })

  // ===== SPRITE-ENRICHED FIGURE (new button: Step 2→3 with sprite references) =====
  // This button does what "Step 2→3: Generate Figure" does, but additionally:
  //   1. Uses exportFullSvg() → Playwright rendering (Break 1 fix: sprites in PNG)
  //   2. Extracts per-node sprite images from elk_graph.children[].spriteRef.url
  //   3. Sends up to 13 sprite images + 1 skeleton PNG as separate inlineData parts
  //   4. Uses media_resolution: HIGH for skeleton, LOW for individual sprites
  //   5. Sends the full nested elk_graph (Break 3 fix: not null)
  generateEnrichedBtn?.addEventListener('click', async () => {
    if (running || !currentSkeletonSvg) return
    const text = textarea?.value?.trim()
    if (!text) return

    running = true
    generateEnrichedBtn.disabled = true
    generateEnrichedText.textContent = 'Generating enriched figure...'
    generateFigureBtn.disabled = true
    generateBtn.disabled = true
    errorDisplay?.hide()
    finalImageSection?.classList.add('hidden')
    ;(window as any).__postGenPanel?.hide()
    startTimer()

    const aspect = (document.getElementById('opt-aspect') as HTMLSelectElement)?.value
    const controller = new AbortController()
    const timeoutId = setTimeout(() => controller.abort(), 300000)

    try {
      // Step A: Get sprite-rich SVG from editor (Break 2 fix)
      const editor = preview?.getEditor()
      if (editor) {
        currentSkeletonSvg = editor.exportFullSvg()
        console.log('[EnrichedFigure] exportFullSvg() called:')
        editor.debugDumpState()
      }

      // Step B: Get nested ELK graph with spriteRef URLs
      const elkGraph = preview?.getLayoutedJson()

      // Step C: Build lightweight elk_graph — strip spriteRef.url base64
      // The server-side sprite cache (sprite_cache_key) has them.
      // This drops ~7 MB from the payload.
      function stripSpriteUrls(obj: any): any {
        if (obj === null || obj === undefined) return obj
        if (Array.isArray(obj)) return obj.map(stripSpriteUrls)
        if (typeof obj !== 'object') return obj
        const out: any = {}
        for (const [k, v] of Object.entries(obj)) {
          if (k === 'spriteRef' && v && typeof v === 'object') {
            // Keep spriteRef metadata but strip the huge base64 url
            const ref = { ...(v as any) }
            if (ref.url && typeof ref.url === 'string' && ref.url.length > 500) {
              ref.url = '__cached__'  // Placeholder — backend restores from cache
            }
            out[k] = ref
          } else {
            out[k] = stripSpriteUrls(v)
          }
        }
        return out
      }
      const lightElk = elkGraph ? stripSpriteUrls(elkGraph) : null

      // Count sprite nodes for display
      let spriteCount = 0
      function countSprites(nodes: any[]) {
        if (!Array.isArray(nodes)) return
        for (const n of nodes) {
          if (n.spriteRef?.url) spriteCount++
          if (Array.isArray(n.children)) countSprites(n.children)
        }
      }
      if (elkGraph?.children) countSprites(elkGraph.children)

      // Strip SVG inline base64 images too
      const svgForPayload = currentSkeletonSvg.replace(
        /<image[^>]*href="data:image\/[^"]{1000,}"[^>]*\/?\s*>/g,
        '<!-- sprite-stripped-for-payload -->'
      )

      console.log(
        `[EnrichedFigure] ${spriteCount} sprites. ` +
        `SVG: ${currentSkeletonSvg.length} → ${svgForPayload.length} chars. ` +
        `sprite_cache_key=${spriteCacheKey}`
      )

      steps?.setStatus('step-edit', 'done')

      // Step D: Generate stylist prompt (lightweight — no sprite data)
      steps?.setStatus('step-stylist-prompt', 'running')
      let customPrompt = promptTextarea.value?.trim() || ''
      if (!customPrompt) {
        statusText.textContent = 'Step 2: Stylist refining description...'
        const pRes = await fetch('/api/generate-prompt', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            method_text: text, svg_content: svgForPayload,
            elk_graph: lightElk,
          }),
          signal: controller.signal,
        })
        const pCT = pRes.headers.get('content-type') || ''
        if (!pCT.includes('application/json')) {
          throw new Error(`Stylist returned ${pRes.status} (not JSON). Payload may be too large.`)
        }
        if (!pRes.ok) { const e = await pRes.json(); throw new Error(`Stylist: ${e.error || 'Failed'}`) }
        const pData = await pRes.json()
        if (pData.success && pData.prompt) {
          promptTextarea.value = pData.prompt
          customPrompt = pData.prompt
        } else { throw new Error(`Stylist: ${pData.error || 'Empty prompt'}`) }
      }
      steps?.setStatus('step-stylist-prompt', 'done')

      // Step E: POST via Astro proxy → Python backend
      // Payload is ~30 KB (sprites stripped, cache_key only) — safe for nginx.
      // Python backend restores sprites from server-side cache.
      steps?.setStatus('step-gemini-image', 'running')
      statusText.textContent = `Step 3: Generating with ${spriteCount} sprite references...`

      const postBody = JSON.stringify({
        svg_content: svgForPayload,
        method_text: text,
        custom_prompt: customPrompt,
        aspect_ratio: aspect || '16:9',
        image_size: '4K',
        elk_graph: lightElk,
        sprite_cache_key: spriteCacheKey,
        skeleton_media_resolution: 'media_resolution_high',
        sprite_media_resolution: 'media_resolution_low',
      })

      console.log(
        `[EnrichedFigure] POST /api/generate-image-enriched: ` +
        `${(postBody.length / 1024).toFixed(0)} KB, sprite_cache_key=${spriteCacheKey}`
      )

      const iRes = await fetch('/api/generate-image-enriched', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: postBody,
        signal: controller.signal,
      })

      // Handle HTML error responses (Vercel 413, Astro 404, etc.)
      const contentType = iRes.headers.get('content-type') || ''
      if (!contentType.includes('application/json')) {
        const htmlBody = await iRes.text()
        console.error('[EnrichedFigure] Non-JSON response:', iRes.status, htmlBody.slice(0, 200))
        throw new Error(
          `Server returned ${iRes.status} (${contentType.split(';')[0] || 'unknown'}). ` +
          `POST body was ${(postBody.length / 1024).toFixed(0)} KB — may exceed size limit.`
        )
      }

      if (!iRes.ok) { const e = await iRes.json(); throw new Error(`Gemini: ${e.error || 'Failed'}`) }
      const iData = await iRes.json()

      if (iData.success && iData.image_b64) {
        currentImageB64 = iData.image_b64
        currentMimeType = iData.mime_type || 'image/png'
        finalImage.src = `data:${currentMimeType};base64,${currentImageB64}`
        finalImageSection?.classList.remove('hidden')
        document.getElementById('tab-final')?.click()
        finalImageInfo.textContent = `Enriched: ${spriteCount} sprites → ${iData.image_model_used || '?'} | ${elapsed()}s`
        steps?.setStatus('step-gemini-image', 'done')
        statusText.textContent = `Enriched figure generated (${elapsed()}s) with ${spriteCount} sprite references.`
        statusText.style.color = ''

        const postGen = (window as any).__postGenPanel
        if (postGen) {
          postGen.show(currentImageB64, currentMimeType, elkGraph)
          setTimeout(() => postGen.runPipeline(), 500)
        }
      } else { throw new Error(`Gemini: ${iData.error || 'No image'}`) }

    } catch (err: any) {
      document.querySelectorAll('.pipeline-step[data-status="running"]').forEach(el => {
        ;(el as HTMLElement).dataset.status = 'error'
      })
      let msg = err.name === 'AbortError' ? 'Timed out (5 min)' : (err.message || 'Unknown error')
      errorDisplay?.show({ title: 'Enriched Figure Error', message: msg, hint: '', step: 'Step 2-3 (Enriched)' })
      statusText.textContent = `Error: ${msg}`
      statusText.style.color = 'hsl(0 72.2% 50.6%)'
    } finally {
      clearTimeout(timeoutId); stopTimer(); running = false
      generateEnrichedBtn.disabled = false; generateFigureBtn.disabled = false; generateBtn.disabled = false
      generateEnrichedText.textContent = 'Step 2→3: Sprite-Enriched Figure'
    }
  })

  // Update currentSkeletonSvg from editor when Step 2 is about to run
  const origRunFigureGen = runFigureGen

</script>