---
/**
 * ExportPanel.astro — 导出面板
 *
 * 下载 SVG / PNG + 复制到剪贴板
 * 使用 astro-pure Button 组件风格
 *
 * GitHub 背书: cworld1/astro-theme-pure
 */
import { Button } from 'astro-pure/user'
---

<div class='flex flex-col gap-y-3' id='export-panel'>
  <span class='text-sm font-medium text-muted-foreground'>Export</span>

  <div class='flex flex-wrap gap-2'>
    <button
      id='export-svg'
      class='group inline-flex items-center gap-x-1.5 rounded-lg border bg-muted px-3 py-1.5 text-sm text-muted-foreground transition-all hover:bg-card hover:text-foreground disabled:opacity-40 disabled:cursor-not-allowed'
      disabled
    >
      <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' class='stroke-muted-foreground group-hover:stroke-primary'>
        <path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4' />
        <polyline points='7 10 12 15 17 10' />
        <line x1='12' y1='15' x2='12' y2='3' />
      </svg>
      Download SVG
    </button>

    <button
      id='export-png'
      class='group inline-flex items-center gap-x-1.5 rounded-lg border bg-muted px-3 py-1.5 text-sm text-muted-foreground transition-all hover:bg-card hover:text-foreground disabled:opacity-40 disabled:cursor-not-allowed'
      disabled
    >
      <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' class='stroke-muted-foreground group-hover:stroke-primary'>
        <rect x='3' y='3' width='18' height='18' rx='2' ry='2' />
        <circle cx='8.5' cy='8.5' r='1.5' />
        <polyline points='21 15 16 10 5 21' />
      </svg>
      Download PNG
    </button>

    <button
      id='copy-svg'
      class='group inline-flex items-center gap-x-1.5 rounded-lg border bg-muted px-3 py-1.5 text-sm text-muted-foreground transition-all hover:bg-card hover:text-foreground disabled:opacity-40 disabled:cursor-not-allowed'
      disabled
    >
      <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' class='stroke-muted-foreground group-hover:stroke-primary'>
        <rect x='9' y='9' width='13' height='13' rx='2' ry='2' />
        <path d='M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1' />
      </svg>
      <span class='copy-label'>Copy SVG</span>
    </button>
  </div>
</div>

<script>
  function enableExport() {
    document.querySelectorAll('#export-panel button').forEach((btn) => {
      (btn as HTMLButtonElement).disabled = false
    })
  }

  function disableExport() {
    document.querySelectorAll('#export-panel button').forEach((btn) => {
      (btn as HTMLButtonElement).disabled = true
    })
  }

  document.getElementById('export-svg')?.addEventListener('click', () => {
    const svg = (window as any).__svgPreview?.getSvg()
    if (!svg) return
    const blob = new Blob([svg], { type: 'image/svg+xml' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a')
    a.href = url
    a.download = 'figure.svg'
    a.click()
    URL.revokeObjectURL(url)
  })

  document.getElementById('export-png')?.addEventListener('click', () => {
    const svg = (window as any).__svgPreview?.getSvg()
    if (!svg) return
    const canvas = document.createElement('canvas')
    const ctx = canvas.getContext('2d')
    const img = new Image()
    const svgBlob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' })
    const url = URL.createObjectURL(svgBlob)
    img.onload = () => {
      canvas.width = img.width * 2
      canvas.height = img.height * 2
      ctx?.scale(2, 2)
      ctx?.drawImage(img, 0, 0)
      canvas.toBlob((blob) => {
        if (!blob) return
        const pngUrl = URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = pngUrl
        a.download = 'figure.png'
        a.click()
        URL.revokeObjectURL(pngUrl)
      })
      URL.revokeObjectURL(url)
    }
    img.src = url
  })

  document.getElementById('copy-svg')?.addEventListener('click', async () => {
    const svg = (window as any).__svgPreview?.getSvg()
    if (!svg) return
    try {
      await navigator.clipboard.writeText(svg)
      const label = document.querySelector('#copy-svg .copy-label') as HTMLSpanElement
      if (label) {
        label.textContent = 'Copied!'
        setTimeout(() => { label.textContent = 'Copy SVG' }, 2000)
      }
    } catch {
      // fallback
    }
  })

  // Expose globally
  ;(window as any).__exportPanel = { enable: enableExport, disable: disableExport }
</script>
