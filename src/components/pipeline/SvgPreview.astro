---
/**
 * SvgPreview.astro — SVG 预览面板
 *
 * 渲染生成的 SVG + 缩放控制 + 暗色/亮色背景切换
 * GitHub 背书: svgdotjs/svg.js, cworld1/astro-theme-pure
 * tldraw integration: ElkCanvas for drag-to-edit ELK nodes
 */
import TldrawEditor from './TldrawEditor.tsx'
---

<div class='flex flex-col gap-y-2' id='svg-preview-section'>
  {/* Toolbar */}
  <div class='flex items-center justify-between'>
    <div class='flex items-center gap-x-2'>
      <span class='text-sm font-medium text-muted-foreground'>SVG Preview</span>
      {/* Tab toggle: Skeleton vs Editor vs Icons vs Final */}
      <div class='flex items-center rounded-lg border bg-muted p-0.5'>
        <button id='tab-skeleton' class='preview-tab rounded-md px-2 py-0.5 text-xs font-medium bg-background text-foreground shadow-sm transition-all hover:text-foreground' data-tab='skeleton'>Skeleton</button>
        <button id='tab-editor' class='preview-tab rounded-md px-2 py-0.5 text-xs font-medium text-muted-foreground' data-tab='editor'>Editor</button>
        <button id='tab-icons' class='preview-tab rounded-md px-2 py-0.5 text-xs font-medium text-muted-foreground' data-tab='icons'>Icons</button>
        <button id='tab-final' class='preview-tab rounded-md px-2 py-0.5 text-xs font-medium text-muted-foreground' data-tab='final'>Final</button>
      </div>
    </div>
    <div class='flex items-center gap-x-1'>
      <button id='zoom-out' class='inline-flex items-center justify-center size-7 rounded-lg border bg-muted text-muted-foreground transition-all hover:bg-card hover:text-foreground' title='Zoom out'>
        <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><line x1='5' y1='12' x2='19' y2='12' /></svg>
      </button>
      <span id='zoom-level' class='text-xs text-muted-foreground w-10 text-center'>100%</span>
      <button id='zoom-in' class='inline-flex items-center justify-center size-7 rounded-lg border bg-muted text-muted-foreground transition-all hover:bg-card hover:text-foreground' title='Zoom in'>
        <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><line x1='12' y1='5' x2='12' y2='19' /><line x1='5' y1='12' x2='19' y2='12' /></svg>
      </button>
      <button id='zoom-fit' class='inline-flex items-center justify-center size-7 rounded-lg border bg-muted text-muted-foreground transition-all hover:bg-card hover:text-foreground' title='Fit to view'>
        <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7' /></svg>
      </button>
      <button id='toggle-bg' class='inline-flex items-center justify-center size-7 rounded-lg border bg-muted text-muted-foreground transition-all hover:bg-card hover:text-foreground' title='Toggle background'>
        <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='5' /><path d='M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42' /></svg>
      </button>
    </div>
  </div>

  {/* Preview container */}
  <div
    id='svg-canvas'
    class='relative flex items-center justify-center overflow-hidden rounded-xl border bg-muted'
    style='min-height: 420px; height: 65vh; background-image: linear-gradient(45deg, hsl(var(--border)) 25%, transparent 25%), linear-gradient(-45deg, hsl(var(--border)) 25%, transparent 25%), linear-gradient(45deg, transparent 75%, hsl(var(--border)) 75%), linear-gradient(-45deg, transparent 75%, hsl(var(--border)) 75%); background-size: 16px 16px; background-position: 0 0, 0 8px, 8px -8px, -8px 0px;'
  >
    {/* Empty state */}
    <div id='svg-empty' class='flex flex-col items-center gap-y-3 py-12 text-center'>
      <svg xmlns='http://www.w3.org/2000/svg' width='48' height='48' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1' class='text-muted-foreground opacity-40'>
        <rect x='3' y='3' width='18' height='18' rx='2' ry='2' />
        <circle cx='8.5' cy='8.5' r='1.5' />
        <polyline points='21 15 16 10 5 21' />
      </svg>
      <p class='text-sm text-muted-foreground'>Enter text and click Generate to create an academic figure</p>
    </div>

    {/* Loading state */}
    <div id='svg-loading' class='flex flex-col items-center gap-y-3 py-12 text-center' style='display:none'>
      <svg class='size-12 animate-spin text-primary opacity-60' xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24'>
        <circle class='opacity-25' cx='12' cy='12' r='10' stroke='currentColor' stroke-width='4' />
        <path class='opacity-75' fill='currentColor' d='M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z' />
      </svg>
      <p class='text-sm text-muted-foreground'>Generating your academic figure...</p>
    </div>

    {/* SVG render area — must fill container for interactive editor */}
    <div id='svg-render' class='absolute inset-0' style='display:none;'>
    </div>

    {/* tldraw editor — React island, shown when Editor tab is active */}
    <div id='tldraw-container' class='absolute inset-0' style='display:none; width:100%; height:100%;'>
      <TldrawEditor client:load />
    </div>
    </div>
  </div>
</div>

<script>
  import { InteractiveSvgEditor } from '@/lib/elk/interactive-svg'
  import type { InteractiveGraph } from '@/lib/elk/interactive-svg'
  import { elkToInteractive } from '@/lib/elk/elk-to-interactive'

  let currentZoom = 100
  const zoomIn = document.getElementById('zoom-in')
  const zoomOut = document.getElementById('zoom-out')
  const zoomFit = document.getElementById('zoom-fit')
  const toggleBg = document.getElementById('toggle-bg')
  const zoomLevel = document.getElementById('zoom-level')
  const svgRender = document.getElementById('svg-render')
  const svgCanvas = document.getElementById('svg-canvas')

  // Interactive editor instance
  let editor: InteractiveSvgEditor | null = null
  let skeletonSvg = ''
  let skeletonLayouted: any = null
  let finalSvg = ''
  let iconSvg = ''
  let activeTab = 'skeleton'

  function setZoom(val: number) {
    currentZoom = Math.max(25, Math.min(300, val))
    if (zoomLevel) zoomLevel.textContent = `${currentZoom}%`
    if (editor) {
      editor.setZoom(currentZoom / 100)
    } else if (svgRender) {
      svgRender.style.transform = `scale(${currentZoom / 100})`
    }
  }

  // ── M222: progressive sprite rendering + client-side fallback ──
  // The renderer (to-svg.ts, M214) draws sprite nodes as <image> data-URIs.
  // Should a sprite fail to decode/load (corrupt base64, oversized payload),
  // we don't want an empty hole: replace the broken <image> with a text label
  // of the node, mirroring the backend's never-leave-a-hole contract. We wire
  // an onerror on every sprite <image> right after the SVG lands in the DOM.
  function wireSpriteFallbacks(container: HTMLElement | null) {
    if (!container) return
    const images = container.querySelectorAll('image[data-sprite]')
    images.forEach((img) => {
      const el = img as SVGImageElement
      if ((el as any).__fallbackWired) return
      ;(el as any).__fallbackWired = true
      el.addEventListener('error', () => {
        try {
          const g = el.closest('g[data-node-id]') as SVGGElement | null
          const x = parseFloat(el.getAttribute('x') || '0')
          const y = parseFloat(el.getAttribute('y') || '0')
          const w = parseFloat(el.getAttribute('width') || '0')
          const h = parseFloat(el.getAttribute('height') || '0')
          const label = g?.getAttribute('data-node-id') || ''
          const ns = 'http://www.w3.org/2000/svg'
          // Draw a light box + the node label so the slot is never blank.
          const rect = document.createElementNS(ns, 'rect')
          rect.setAttribute('x', String(x)); rect.setAttribute('y', String(y))
          rect.setAttribute('width', String(w)); rect.setAttribute('height', String(h))
          rect.setAttribute('rx', '6'); rect.setAttribute('fill', '#FFFFFF')
          rect.setAttribute('stroke', '#4A4A4A'); rect.setAttribute('stroke-width', '0.8')
          const text = document.createElementNS(ns, 'text')
          text.setAttribute('x', String(x + w / 2))
          text.setAttribute('y', String(y + h / 2))
          text.setAttribute('text-anchor', 'middle')
          text.setAttribute('dominant-baseline', 'central')
          text.setAttribute('font-family', 'system-ui, sans-serif')
          text.setAttribute('font-size', '11'); text.setAttribute('fill', '#1A1A1A')
          text.textContent = label.length > 18 ? label.slice(0, 16) + '…' : label
          el.replaceWith(rect, text)
        } catch { /* best-effort fallback */ }
      })
    })
  }

  // Observe svg-render so any innerHTML SVG injection (skeleton/icons/final)
  // gets sprite fallbacks wired automatically, without touching every site.
  if (svgRender) {
    const mo = new MutationObserver(() => wireSpriteFallbacks(svgRender))
    mo.observe(svgRender, { childList: true, subtree: true })
  }

  zoomIn?.addEventListener('click', () => setZoom(currentZoom + 25))
  zoomOut?.addEventListener('click', () => setZoom(currentZoom - 25))
  zoomFit?.addEventListener('click', () => {
    setZoom(100)
    if (editor) editor.fitView()
  })

  let darkBg = false
  toggleBg?.addEventListener('click', () => {
    darkBg = !darkBg
    if (svgCanvas) {
      svgCanvas.style.backgroundColor = darkBg ? 'hsl(0 0% 10%)' : ''
    }
  })

  // Tab switching
  document.querySelectorAll('.preview-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const t = (tab as HTMLElement).dataset.tab || 'final'
      activeTab = t
      document.querySelectorAll('.preview-tab').forEach((btn) => {
        btn.classList.remove('bg-background', 'text-foreground', 'shadow-sm')
        btn.classList.add('text-muted-foreground')
      })
      tab.classList.add('bg-background', 'text-foreground', 'shadow-sm')
      tab.classList.remove('text-muted-foreground')

      if (t === 'skeleton') {
        // Hide tldraw if it was active
        const tldrawContainer = document.getElementById('tldraw-container')
        if (tldrawContainer) tldrawContainer.style.display = 'none'
        // Restore the interactive editor — DON'T re-init from original layouted
        if (editor && svgRender) {
          // Editor still alive (was just hidden), show its SVG element
          const editorSvg = svgRender.querySelector('svg')
          if (editorSvg) (editorSvg as HTMLElement).style.display = ''
          // Remove any final SVG static HTML that was injected
          const staticDiv = svgRender.querySelector('#static-final-svg')
          if (staticDiv) staticDiv.remove()
          const iconsDiv = svgRender.querySelector('#static-icons-svg')
          if (iconsDiv) iconsDiv.remove()
          svgRender.style.display = ''
          hideEmptyAndLoading()
          ;(window as any).__svgEditor?.show()
        } else if (skeletonLayouted && svgRender) {
          // No editor instance yet — create one
          initInteractiveEditor(skeletonLayouted)
          hideEmptyAndLoading()
          svgRender.style.display = ''
          ;(window as any).__svgEditor?.show()
        } else if (skeletonSvg && svgRender) {
          // Fallback to static SVG
          svgRender.style.display = ''
          svgRender.innerHTML = skeletonSvg
          svgRender.style.transformOrigin = 'center center'
          hideEmptyAndLoading()
          ;(window as any).__svgEditor?.show()
        } else {
          showEmptyState('Draft layout will appear after planning phase (Step 1)')
          ;(window as any).__svgEditor?.hide()
        }
      } else if (t === 'editor') {
        // tldraw Editor tab: show the drag-to-edit canvas
        ;(window as any).__svgEditor?.hide()
        if (svgRender) svgRender.style.display = 'none'
        const tldrawContainer = document.getElementById('tldraw-container')
        if (tldrawContainer) {
          tldrawContainer.style.display = ''
          // Load the current layouted graph into tldraw
          const tldrawApi = (window as any).__tldrawEditor
          if (tldrawApi && skeletonLayouted) {
            tldrawApi.loadGraph(skeletonLayouted)
          }
        }
        hideEmptyAndLoading()
      } else if (t === 'icons') {
        // Icons tab: show icon-enriched SVG (static, no editor)
        ;(window as any).__svgEditor?.hide()
        const tldrawContainer2 = document.getElementById('tldraw-container')
        if (tldrawContainer2) tldrawContainer2.style.display = 'none'

        if (editor && svgRender) {
          skeletonSvg = editor.toStaticSvg()
          const editorSvg = svgRender.querySelector('svg')
          if (editorSvg) (editorSvg as HTMLElement).style.display = 'none'
        }

        // Remove final div if present
        const finalDiv = svgRender?.querySelector('#static-final-svg')
        if (finalDiv) (finalDiv as HTMLElement).style.display = 'none'

        if (iconSvg && svgRender) {
          let iconsDiv = svgRender.querySelector('#static-icons-svg') as HTMLElement
          if (!iconsDiv) {
            iconsDiv = document.createElement('div')
            iconsDiv.id = 'static-icons-svg'
            svgRender.appendChild(iconsDiv)
          }
          iconsDiv.innerHTML = iconSvg
          iconsDiv.style.display = ''
          svgRender.style.display = ''
          svgRender.style.transformOrigin = 'center center'
          hideEmptyAndLoading()
        } else {
          if (!editor && svgRender) svgRender.style.display = 'none'
          showEmptyState('Icon-enriched SVG will appear after layout (Step 2)')
        }
      } else {
        // Final tab: hide the editor SVG (don't destroy!), show final static SVG
        ;(window as any).__svgEditor?.hide()
        const tldrawContainer3 = document.getElementById('tldraw-container')
        if (tldrawContainer3) tldrawContainer3.style.display = 'none'

        if (editor && svgRender) {
          // Save latest skeleton SVG from editor before hiding
          skeletonSvg = editor.toStaticSvg()
          // Hide editor's SVG element instead of destroying
          const editorSvg = svgRender.querySelector('svg')
          if (editorSvg) (editorSvg as HTMLElement).style.display = 'none'
        }

        if (finalSvg && svgRender) {
          // Inject final SVG in a wrapper div so we can remove it later
          let staticDiv = svgRender.querySelector('#static-final-svg') as HTMLElement
          if (!staticDiv) {
            staticDiv = document.createElement('div')
            staticDiv.id = 'static-final-svg'
            svgRender.appendChild(staticDiv)
          }
          staticDiv.innerHTML = finalSvg
          staticDiv.style.display = ''
          svgRender.style.display = ''
          svgRender.style.transformOrigin = 'center center'
          hideEmptyAndLoading()
        } else {
          // No editor to hide, just show empty
          if (!editor && svgRender) {
            svgRender.style.display = 'none'
          }
          showEmptyState('Final image will appear after Gemini 3 generation (Step 3)')
        }
      }
    })
  })

  function showEmptyState(message: string) {
    const empty = document.getElementById('svg-empty')
    if (empty) {
      empty.style.display = ''
      const p = empty.querySelector('p')
      if (p) { p.textContent = message; p.style.color = '' }
    }
    const loading = document.getElementById('svg-loading')
    if (loading) loading.style.display = 'none'
    if (svgRender) { svgRender.style.display = 'none'; svgRender.innerHTML = '' }
  }

  function hideEmptyAndLoading() {
    const empty = document.getElementById('svg-empty')
    if (empty) empty.style.display = 'none'
    const loading = document.getElementById('svg-loading')
    if (loading) loading.style.display = 'none'
  }

  function initInteractiveEditor(layouted: any) {
    if (!svgRender) return
    try {
      // Defensive: validate layouted has children
      if (!layouted || !layouted.children || !Array.isArray(layouted.children) || layouted.children.length === 0) {
        console.warn('[SvgPreview] layouted has no children, falling back to static SVG')
        if (skeletonSvg) {
          editor?.destroy()
          editor = null
          svgRender.innerHTML = skeletonSvg
          svgRender.style.display = ''
          hideEmptyAndLoading()
        } else {
          showEmptyState('Layout returned no nodes — try a different description')
        }
        return
      }

      const graph: InteractiveGraph = elkToInteractive(layouted)

      // Defensive: check graph has nodes
      if (!graph.nodes || graph.nodes.length === 0) {
        console.warn('[SvgPreview] elkToInteractive returned empty nodes')
        if (skeletonSvg) {
          editor?.destroy()
          editor = null
          svgRender.innerHTML = skeletonSvg
          svgRender.style.display = ''
          hideEmptyAndLoading()
        }
        return
      }

      editor?.destroy()
      svgRender.innerHTML = ''
      svgRender.style.transform = ''

      editor = new InteractiveSvgEditor(svgRender, graph, {
        snapToGrid: true,
        gridSize: 10,
        onGraphChange: (g: InteractiveGraph) => {
          // Update the stored skeleton SVG from editor
          if (editor) {
            skeletonSvg = editor.toStaticSvg()
          }
        },
      })
      svgRender.style.display = ''

      // Ensure empty/loading states are hidden
      hideEmptyAndLoading()
      { const _l = document.getElementById('svg-loading'); if (_l) _l.style.display = 'none' }

      // Auto fit-view after initialization
      requestAnimationFrame(() => {
        if (editor) editor.fitView()
      })
    } catch (err) {
      console.error('Failed to init interactive editor:', err)
      // Fallback to static SVG
      editor?.destroy()
      editor = null
      if (skeletonSvg) {
        svgRender.innerHTML = skeletonSvg
        svgRender.style.display = ''
        hideEmptyAndLoading()
        { const _l = document.getElementById('svg-loading'); if (_l) _l.style.display = 'none' }
      } else {
        showEmptyState(`Editor error: ${err instanceof Error ? err.message : 'Unknown'}`)
      }
    }
  }

  // Expose globally for Generate page
  ;(window as any).__svgPreview = {
    show(svgContent: string) {
      finalSvg = svgContent
      if (activeTab === 'final') {
        const empty = document.getElementById('svg-empty')
        const loading = document.getElementById('svg-loading')
        if (empty) empty.style.display = 'none'
        if (loading) loading.style.display = 'none'
        if (svgRender) {
          // Hide editor SVG if present
          if (editor) {
            const editorSvg = svgRender.querySelector('svg:not(#static-final-svg svg)')
            if (editorSvg) (editorSvg as HTMLElement).style.display = 'none'
          }
          // Insert final SVG in wrapper
          let staticDiv = svgRender.querySelector('#static-final-svg') as HTMLElement
          if (!staticDiv) {
            staticDiv = document.createElement('div')
            staticDiv.id = 'static-final-svg'
            svgRender.appendChild(staticDiv)
          }
          staticDiv.innerHTML = svgContent
          staticDiv.style.display = ''
          svgRender.style.display = ''
        }
      }
    },

    showSkeleton(svgContent: string, layoutedData?: any) {
      skeletonSvg = svgContent
      skeletonLayouted = layoutedData || null

      if (activeTab === 'skeleton' && svgRender) {
        const empty = document.getElementById('svg-empty')
        const loading = document.getElementById('svg-loading')
        if (empty) empty.style.display = 'none'
        if (loading) loading.style.display = 'none'

        if (layoutedData) {
          // Use interactive editor
          initInteractiveEditor(layoutedData)
        } else {
          // Fallback: static SVG
          editor?.destroy()
          editor = null
          svgRender.style.display = ''
          svgRender.innerHTML = svgContent
        }

        // Show editor toolbar
        ;(window as any).__svgEditor?.show()
      }
    },

    showIconSvg(svgContent: string) {
      iconSvg = svgContent
      if (activeTab === 'icons' && svgRender) {
        const empty = document.getElementById('svg-empty')
        const loading = document.getElementById('svg-loading')
        if (empty) empty.style.display = 'none'
        if (loading) loading.style.display = 'none'

        // Hide editor SVG if present
        if (editor) {
          const editorSvg = svgRender.querySelector('svg:not(#static-icons-svg svg)')
          if (editorSvg) (editorSvg as HTMLElement).style.display = 'none'
        }

        let iconsDiv = svgRender.querySelector('#static-icons-svg') as HTMLElement
        if (!iconsDiv) {
          iconsDiv = document.createElement('div')
          iconsDiv.id = 'static-icons-svg'
          svgRender.appendChild(iconsDiv)
        }
        iconsDiv.innerHTML = svgContent
        iconsDiv.style.display = ''
        svgRender.style.display = ''
      }
    },

    clear() {
      skeletonSvg = ''
      skeletonLayouted = null
      finalSvg = ''
      iconSvg = ''
      editor?.destroy()
      editor = null
      // Also remove any static final/icons SVG wrapper
      if (svgRender) {
        const staticDiv = svgRender.querySelector('#static-final-svg')
        if (staticDiv) staticDiv.remove()
        const iconsDiv = svgRender.querySelector('#static-icons-svg')
        if (iconsDiv) iconsDiv.remove()
      }
      showEmptyState('Enter text and click Generate to create an academic figure')
      ;(window as any).__svgEditor?.hide()
    },

    showLoading() {
      const empty = document.getElementById('svg-empty')
      const loading = document.getElementById('svg-loading')
      if (empty) empty.style.display = 'none'
      if (loading) loading.style.display = ''
      if (svgRender) svgRender.style.display = 'none'
    },

    showError(message: string) {
      showEmptyState(message)
      const empty = document.getElementById('svg-empty')
      if (empty) {
        const p = empty.querySelector('p')
        if (p) p.style.color = 'var(--color-danger, #ef4444)'
      }
    },

    getSvg(): string {
      if (editor && activeTab === 'skeleton') return editor.toStaticSvg()
      return finalSvg || svgRender?.innerHTML || ''
    },

    getSkeletonSvg(): string {
      if (editor) return editor.toStaticSvg()
      return skeletonSvg
    },

    getEditor(): InteractiveSvgEditor | null {
      return editor
    },

    getElkJson(): any {
      return editor?.getElkJson() || null
    },
  }
</script>