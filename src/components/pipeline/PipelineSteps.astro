---
/**
 * PipelineSteps.astro — 3-Step Pipeline 进度条 (重构版)
 *
 * Step 1: LLM 拓扑 + ELK 布局 → 骨架 SVG
 * Step 2: Grok 4 反推专业 prompt
 * Step 3: Gemini 3 Pro Image → 科研级图片
 *
 * GitHub 背书: cworld1/astro-theme-pure, kieler/elkjs
 */
---

<div class='flex flex-col gap-y-2' id='pipeline-steps'>
  <div class='flex items-center gap-x-2 text-sm font-medium text-muted-foreground'>
    Pipeline Progress
  </div>

  <div class='flex flex-col gap-y-1'>
    {[
      { id: 'step-topology', num: '1', label: 'Planner + Layout Composition', desc: 'Source Context → Planner Agent → Layout Draft', icon: '' },
      { id: 'step-edit', num: '✎', label: 'Edit Draft', desc: 'Drag nodes, edit labels, resize — then confirm', icon: '' },
      { id: 'step-grok-prompt', num: '2', label: 'Stylist Refinement', desc: 'Synthesize aesthetic guideline for illustration', icon: '' },
      { id: 'step-gemini-image', num: '3', label: 'Visualizer Output', desc: 'Generate publication-quality figure', icon: '' },
    ].map((step) => (
      <div
        id={step.id}
        class='pipeline-step flex items-center gap-x-3 rounded-xl border bg-muted px-3 py-2 transition-all'
        data-status='idle'
      >
        <div class='step-indicator flex size-7 shrink-0 items-center justify-center rounded-full border bg-background text-xs font-medium text-muted-foreground transition-colors'>
          {step.num}
        </div>
        <div class='flex flex-1 flex-col'>
          <span class='text-sm font-medium'>{step.label}</span>
          <span class='text-xs text-muted-foreground'>{step.desc}</span>
        </div>
        <div class='step-status'>
          <svg class='step-spinner hidden size-4 animate-spin text-primary' xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24'>
            <circle class='opacity-25' cx='12' cy='12' r='10' stroke='currentColor' stroke-width='4' />
            <path class='opacity-75' fill='currentColor' d='M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z' />
          </svg>
          <svg class='step-check hidden size-4 text-green-500' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5'>
            <polyline points='20 6 9 17 4 12' />
          </svg>
          <svg class='step-error hidden size-4 text-red-500' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5'>
            <line x1='18' y1='6' x2='6' y2='18' />
            <line x1='6' y1='6' x2='18' y2='18' />
          </svg>
        </div>
      </div>
    ))}
  </div>

  <div class='flex items-center justify-between text-xs text-muted-foreground'>
    <span id='pipeline-status-text'>Ready</span>
    <span id='pipeline-elapsed'>0.0s</span>
  </div>
</div>

<style>
  .pipeline-step[data-status='running'] {
    border-color: hsl(var(--primary) / 0.5);
    background-color: hsl(var(--primary) / 0.05);
  }
  .pipeline-step[data-status='running'] .step-indicator {
    background-color: hsl(var(--primary));
    color: white;
    border-color: hsl(var(--primary));
  }
  .pipeline-step[data-status='running'] .step-spinner { display: block; }
  .pipeline-step[data-status='done'] .step-indicator {
    background-color: hsl(142.1 76.2% 36.3%);
    color: white;
    border-color: hsl(142.1 76.2% 36.3%);
  }
  .pipeline-step[data-status='done'] .step-check { display: block; }
  .pipeline-step[data-status='error'] .step-indicator {
    background-color: hsl(0 72.2% 50.6%);
    color: white;
    border-color: hsl(0 72.2% 50.6%);
  }
  .pipeline-step[data-status='error'] .step-error { display: block; }
  .pipeline-step[data-status='error'] {
    border-color: hsl(0 72.2% 50.6% / 0.5);
    background-color: hsl(0 72.2% 50.6% / 0.05);
    animation: shake 0.4s ease-in-out;
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-4px); }
    40% { transform: translateX(4px); }
    60% { transform: translateX(-2px); }
    80% { transform: translateX(2px); }
  }
</style>

<script>
  ;(window as any).__pipelineSteps = {
    setStatus(stepId: string, status: 'idle' | 'running' | 'done' | 'error') {
      const el = document.getElementById(stepId)
      if (!el) return
      el.dataset.status = status
      el.querySelector('.step-spinner')?.classList.add('hidden')
      el.querySelector('.step-check')?.classList.add('hidden')
      el.querySelector('.step-error')?.classList.add('hidden')
    },
    resetAll() {
      document.querySelectorAll('.pipeline-step').forEach((el) => {
        ;(el as HTMLElement).dataset.status = 'idle'
      })
      const statusText = document.getElementById('pipeline-status-text')
      const elapsed = document.getElementById('pipeline-elapsed')
      if (statusText) { statusText.textContent = 'Ready'; statusText.style.color = '' }
      if (elapsed) elapsed.textContent = '0.0s'
    },
  }
</script>