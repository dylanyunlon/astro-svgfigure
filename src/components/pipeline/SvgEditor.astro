---
/**
 * SvgEditor.astro — SVG Editing Toolbar
 *
 * Provides controls for the interactive skeleton SVG editor:
 * - Re-Layout: send modified graph back to ELK
 * - Add / Delete nodes
 * - Export SVG / JSON
 * - Confirm → proceed to Step 2
 *
 * Uses astro-pure theme button/card styling only.
 * GitHub: kieler/elkjs, cworld1/astro-theme-pure
 */
---

<div id='svg-editor-toolbar' class='hidden flex flex-col gap-y-2'>
  <div class='flex items-center justify-between'>
    <span class='text-sm font-medium text-foreground'>Edit Skeleton</span>
    <span class='text-xs text-muted-foreground' id='editor-hint'>Drag nodes • Double-click to edit labels • Scroll to zoom</span>
  </div>

  <div class='flex flex-wrap items-center gap-2'>
    {/* Layout controls */}
    <button id='btn-relayout'
      class='inline-flex items-center gap-x-1.5 rounded-lg border bg-muted px-3 py-1.5 text-xs font-medium text-foreground transition-all hover:bg-card hover:shadow-sm'
      title='Re-run ELK layout with current nodes'>
      <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
        <polyline points='1 4 1 10 7 10' /><path d='M3.51 15a9 9 0 1 0 2.13-9.36L1 10' />
      </svg>
      Re-Layout
    </button>

    <div class='h-4 w-px bg-border'></div>

    {/* Node controls */}
    <button id='btn-add-node'
      class='inline-flex items-center gap-x-1.5 rounded-lg border bg-muted px-3 py-1.5 text-xs font-medium text-foreground transition-all hover:bg-card hover:shadow-sm'
      title='Add a new node'>
      <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
        <line x1='12' y1='5' x2='12' y2='19' /><line x1='5' y1='12' x2='19' y2='12' />
      </svg>
      Add Node
    </button>

    <button id='btn-delete-node'
      class='inline-flex items-center gap-x-1.5 rounded-lg border bg-muted px-3 py-1.5 text-xs font-medium text-muted-foreground transition-all hover:bg-card hover:text-foreground disabled:opacity-40'
      title='Delete selected node' disabled>
      <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
        <polyline points='3 6 5 6 21 6' /><path d='M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2' />
      </svg>
      Delete
    </button>

    <div class='h-4 w-px bg-border'></div>

    {/* View controls */}
    <button id='btn-fit-view'
      class='inline-flex items-center gap-x-1.5 rounded-lg border bg-muted px-3 py-1.5 text-xs font-medium text-foreground transition-all hover:bg-card hover:shadow-sm'
      title='Fit view to content'>
      <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
        <path d='M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7' />
      </svg>
      Fit
    </button>

    <label class='inline-flex items-center gap-x-1.5 text-xs text-muted-foreground'>
      <input id='chk-snap-grid' type='checkbox' checked class='rounded border'>
      Snap
    </label>

    <div class='h-4 w-px bg-border'></div>

    {/* Export controls */}
    <button id='btn-export-svg'
      class='inline-flex items-center gap-x-1.5 rounded-lg border bg-muted px-3 py-1.5 text-xs font-medium text-foreground transition-all hover:bg-card hover:shadow-sm'
      title='Export as SVG file'>
      <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
        <path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4' /><polyline points='7 10 12 15 17 10' /><line x1='12' y1='15' x2='12' y2='3' />
      </svg>
      SVG
    </button>

    <button id='btn-export-json'
      class='inline-flex items-center gap-x-1.5 rounded-lg border bg-muted px-3 py-1.5 text-xs font-medium text-foreground transition-all hover:bg-card hover:shadow-sm'
      title='Export layout as JSON'>
      { }
      JSON
    </button>
  </div>
</div>

<script>
  // SVG Editor Toolbar — exposed via window.__svgEditor
  ;(window as any).__svgEditor = {
    show() {
      document.getElementById('svg-editor-toolbar')?.classList.remove('hidden')
    },
    hide() {
      document.getElementById('svg-editor-toolbar')?.classList.add('hidden')
    },
    enableDelete() {
      const btn = document.getElementById('btn-delete-node') as HTMLButtonElement
      if (btn) btn.disabled = false
    },
    disableDelete() {
      const btn = document.getElementById('btn-delete-node') as HTMLButtonElement
      if (btn) btn.disabled = true
    },
  }
</script>
