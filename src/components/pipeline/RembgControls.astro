---
/**
 * RembgControls.astro — Background Removal Configuration Panel
 *
 * Provides UI controls for configuring the advanced background removal
 * pipeline. Lets users select the removal strategy and fine-tune
 * parameters for both chroma-key and rembg approaches.
 *
 * Pipeline Position: Controls for Step 4 (background removal)
 *   Renders inside the /playground page between frame generation
 *   and layer separation controls.
 *
 * Features:
 *   - Strategy selector (Auto / Chroma-Key / rembg ML / Hybrid)
 *   - HSV chroma-key parameter sliders (hue, saturation, value)
 *   - rembg model selector (u2net, silueta, birefnet, etc.)
 *   - Spill correction mode toggle
 *   - Quality threshold slider
 *   - Live preview of removal on a selected frame
 *   - Validation toggle with quality score display
 *
 * Uses astro-pure Card, Label, and Collapse components.
 * Exposes window.__rembgControls global for JS orchestration.
 *
 * Knuth-Level Critiques:
 * ──────────────────────
 * User Angle:
 *   - "Auto" strategy is the default and works well for ~90% of cases.
 *     Advanced users can switch to manual mode for fine control.
 *   - Sliders show numeric values live. The user doesn't need to guess
 *     what "halfway" means — they see the exact number.
 *   - The quality score badge updates after each removal attempt,
 *     using color coding: green ≥ 0.85, yellow ≥ 0.7, red < 0.7.
 *
 * System Angle:
 *   - Control values are stored in data attributes on the panel
 *     root element. JS reads them when building the API request.
 *   - The preview uses a single-frame API call to /api/advanced-rembg
 *     with only the selected frame, avoiding full-batch processing
 *     during parameter tuning.
 *   - Debouncing: slider changes trigger preview after 300ms idle,
 *     preventing API spam during rapid adjustments.
 */

import Card from 'astro-pure/user/Card.astro'

interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<div
  class:list={['rembg-controls', className]}
  id="rembg-controls-panel"
  data-strategy="auto"
  data-quality-threshold="0.7"
>
  <Card>
    <div class="rc-header">
      <h3 class="rc-title">
        <span class="rc-icon">🎨</span>
        Background Removal Settings
      </h3>
      <div class="rc-quality-badge" id="rc-quality-badge" data-score="0" hidden>
        <span class="rc-badge-label">Quality:</span>
        <span class="rc-badge-score" id="rc-quality-score">—</span>
      </div>
    </div>

    <!-- Strategy Selector -->
    <div class="rc-section">
      <label class="rc-label">Removal Strategy</label>
      <div class="rc-strategy-grid" id="rc-strategy-grid">
        <button class="rc-strategy-btn active" data-strategy="auto" type="button">
          <span class="rc-strategy-icon">⚡</span>
          <span class="rc-strategy-name">Auto</span>
          <span class="rc-strategy-desc">Best quality, automatic</span>
        </button>
        <button class="rc-strategy-btn" data-strategy="chroma" type="button">
          <span class="rc-strategy-icon">🟢</span>
          <span class="rc-strategy-name">Chroma-Key</span>
          <span class="rc-strategy-desc">Fast, green-screen only</span>
        </button>
        <button class="rc-strategy-btn" data-strategy="rembg" type="button">
          <span class="rc-strategy-icon">🧠</span>
          <span class="rc-strategy-name">AI (rembg)</span>
          <span class="rc-strategy-desc">ML-based, any background</span>
        </button>
        <button class="rc-strategy-btn" data-strategy="hybrid" type="button">
          <span class="rc-strategy-icon">🔬</span>
          <span class="rc-strategy-name">Hybrid</span>
          <span class="rc-strategy-desc">Chroma + AI cascade</span>
        </button>
      </div>
    </div>

    <!-- Chroma-Key Parameters (shown when strategy is chroma/hybrid/auto) -->
    <div class="rc-section rc-chroma-params" id="rc-chroma-section">
      <label class="rc-label">Chroma-Key Parameters</label>

      <div class="rc-slider-row">
        <span class="rc-slider-label">Hue Range</span>
        <input
          type="range" id="rc-hue-range" min="5" max="90" value="35" step="1"
          class="rc-slider"
        />
        <span class="rc-slider-value" id="rc-hue-range-val">35°</span>
      </div>

      <div class="rc-slider-row">
        <span class="rc-slider-label">Min Saturation</span>
        <input
          type="range" id="rc-sat-min" min="0" max="255" value="40" step="1"
          class="rc-slider"
        />
        <span class="rc-slider-value" id="rc-sat-min-val">40</span>
      </div>

      <div class="rc-slider-row">
        <span class="rc-slider-label">Min Value</span>
        <input
          type="range" id="rc-val-min" min="0" max="255" value="40" step="1"
          class="rc-slider"
        />
        <span class="rc-slider-value" id="rc-val-min-val">40</span>
      </div>

      <div class="rc-slider-row">
        <span class="rc-slider-label">Edge Feather</span>
        <input
          type="range" id="rc-feather" min="0" max="20" value="3" step="1"
          class="rc-slider"
        />
        <span class="rc-slider-value" id="rc-feather-val">3px</span>
      </div>

      <div class="rc-option-row">
        <span class="rc-option-label">Spill Correction</span>
        <select id="rc-spill-mode" class="rc-select">
          <option value="average" selected>Average (balanced)</option>
          <option value="max_rb">Max R/B (aggressive)</option>
          <option value="none">None</option>
        </select>
      </div>
    </div>

    <!-- rembg Parameters (shown when strategy is rembg/hybrid/auto) -->
    <div class="rc-section rc-rembg-params" id="rc-rembg-section">
      <label class="rc-label">AI Model Parameters</label>

      <div class="rc-option-row">
        <span class="rc-option-label">Model</span>
        <select id="rc-rembg-model" class="rc-select">
          <option value="u2net" selected>U²-Net (general)</option>
          <option value="u2netp">U²-Net-P (lightweight)</option>
          <option value="u2net_human_seg">U²-Net Human</option>
          <option value="silueta">Silueta (fast)</option>
          <option value="isnet-general-use">IS-Net (general)</option>
          <option value="isnet-anime">IS-Net Anime</option>
          <option value="birefnet-general">BiRefNet (high quality)</option>
        </select>
      </div>

      <div class="rc-option-row">
        <label class="rc-checkbox-label">
          <input type="checkbox" id="rc-alpha-matting" class="rc-checkbox" />
          <span>Alpha matting (better edges, slower)</span>
        </label>
      </div>
    </div>

    <!-- Quality Settings -->
    <div class="rc-section">
      <label class="rc-label">Quality</label>

      <div class="rc-slider-row">
        <span class="rc-slider-label">Min Quality</span>
        <input
          type="range" id="rc-quality-threshold" min="0" max="100" value="70" step="5"
          class="rc-slider"
        />
        <span class="rc-slider-value" id="rc-quality-val">0.70</span>
      </div>

      <div class="rc-option-row">
        <label class="rc-checkbox-label">
          <input type="checkbox" id="rc-validate" class="rc-checkbox" checked />
          <span>Run transparency validation</span>
        </label>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="rc-actions">
      <button class="rc-btn rc-btn-preview" id="rc-btn-preview" type="button">
        Preview on Frame
      </button>
      <button class="rc-btn rc-btn-apply" id="rc-btn-apply" type="button">
        Apply to All Frames
      </button>
    </div>

    <!-- Status -->
    <div class="rc-status" id="rc-status" hidden>
      <div class="rc-status-spinner"></div>
      <span class="rc-status-text" id="rc-status-text">Processing...</span>
    </div>
  </Card>
</div>

<style>
  .rembg-controls {
    width: 100%;
  }

  .rc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .rc-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-color, #1a1a1a);
  }

  .rc-icon {
    font-size: 1.2rem;
  }

  .rc-quality-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.6rem;
    border-radius: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    background: var(--bg-muted, #f0f0f0);
  }

  .rc-quality-badge[data-grade="excellent"] {
    background: #dcfce7;
    color: #166534;
  }

  .rc-quality-badge[data-grade="good"] {
    background: #fef9c3;
    color: #854d0e;
  }

  .rc-quality-badge[data-grade="poor"] {
    background: #fee2e2;
    color: #991b1b;
  }

  .rc-section {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color, #e5e7eb);
  }

  .rc-section:last-of-type {
    border-bottom: none;
  }

  .rc-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted, #6b7280);
    margin-bottom: 0.6rem;
  }

  .rc-strategy-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .rc-strategy-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.6rem 0.4rem;
    border: 2px solid var(--border-color, #e5e7eb);
    border-radius: 0.5rem;
    background: transparent;
    cursor: pointer;
    transition: all 0.15s ease;
    text-align: center;
  }

  .rc-strategy-btn:hover {
    border-color: var(--accent-color, #6366f1);
    background: var(--bg-hover, #f9fafb);
  }

  .rc-strategy-btn.active {
    border-color: var(--accent-color, #6366f1);
    background: var(--accent-bg, #eef2ff);
  }

  .rc-strategy-icon {
    font-size: 1.3rem;
  }

  .rc-strategy-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-color, #1a1a1a);
  }

  .rc-strategy-desc {
    font-size: 0.7rem;
    color: var(--text-muted, #9ca3af);
  }

  .rc-slider-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .rc-slider-label {
    flex: 0 0 110px;
    font-size: 0.85rem;
    color: var(--text-color, #374151);
  }

  .rc-slider {
    flex: 1;
    height: 6px;
    -webkit-appearance: none;
    appearance: none;
    border-radius: 3px;
    background: var(--border-color, #d1d5db);
    outline: none;
  }

  .rc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--accent-color, #6366f1);
    cursor: pointer;
  }

  .rc-slider-value {
    flex: 0 0 45px;
    text-align: right;
    font-size: 0.8rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--text-color, #374151);
  }

  .rc-option-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .rc-option-label {
    flex: 0 0 110px;
    font-size: 0.85rem;
    color: var(--text-color, #374151);
  }

  .rc-select {
    flex: 1;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--border-color, #d1d5db);
    border-radius: 0.375rem;
    font-size: 0.85rem;
    background: var(--bg-color, #fff);
    color: var(--text-color, #1a1a1a);
  }

  .rc-checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-color, #374151);
    cursor: pointer;
  }

  .rc-checkbox {
    width: 16px;
    height: 16px;
    accent-color: var(--accent-color, #6366f1);
  }

  .rc-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .rc-btn {
    flex: 1;
    padding: 0.6rem 1rem;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .rc-btn-preview {
    background: var(--bg-muted, #f3f4f6);
    color: var(--text-color, #374151);
  }

  .rc-btn-preview:hover {
    background: var(--border-color, #d1d5db);
  }

  .rc-btn-apply {
    background: var(--accent-color, #6366f1);
    color: #fff;
  }

  .rc-btn-apply:hover {
    opacity: 0.9;
  }

  .rc-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .rc-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    background: var(--bg-muted, #f3f4f6);
    font-size: 0.85rem;
    color: var(--text-muted, #6b7280);
  }

  .rc-status-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid var(--border-color, #d1d5db);
    border-top-color: var(--accent-color, #6366f1);
    border-radius: 50%;
    animation: rc-spin 0.6s linear infinite;
  }

  @keyframes rc-spin {
    to { transform: rotate(360deg); }
  }

  /* Hide sections based on strategy */
  .rembg-controls[data-strategy="rembg"] .rc-chroma-params {
    display: none;
  }

  .rembg-controls[data-strategy="chroma"] .rc-rembg-params {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const panel = document.getElementById('rembg-controls-panel') as HTMLDivElement
    if (!panel) return

    // ── Strategy Selector ────────────────────────────────────────────
    const strategyBtns = panel.querySelectorAll<HTMLButtonElement>('.rc-strategy-btn')
    strategyBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        strategyBtns.forEach(b => b.classList.remove('active'))
        btn.classList.add('active')
        const strategy = btn.dataset.strategy || 'auto'
        panel.dataset.strategy = strategy
      })
    })

    // ── Slider Value Displays ────────────────────────────────────────
    const sliderBindings: Array<[string, string, (v: number) => string]> = [
      ['rc-hue-range', 'rc-hue-range-val', v => `${v}°`],
      ['rc-sat-min', 'rc-sat-min-val', v => `${v}`],
      ['rc-val-min', 'rc-val-min-val', v => `${v}`],
      ['rc-feather', 'rc-feather-val', v => `${v}px`],
      ['rc-quality-threshold', 'rc-quality-val', v => (v / 100).toFixed(2)],
    ]

    for (const [sliderId, displayId, formatter] of sliderBindings) {
      const slider = document.getElementById(sliderId) as HTMLInputElement
      const display = document.getElementById(displayId) as HTMLSpanElement
      if (slider && display) {
        slider.addEventListener('input', () => {
          display.textContent = formatter(parseInt(slider.value, 10))
        })
      }
    }

    // ── Collect Current Config ───────────────────────────────────────
    function getConfig(): Record<string, unknown> {
      const activeBtn = panel.querySelector<HTMLButtonElement>('.rc-strategy-btn.active')
      return {
        strategy: activeBtn?.dataset.strategy || 'auto',
        hue_range: intVal('rc-hue-range'),
        saturation_min: intVal('rc-sat-min'),
        value_min: intVal('rc-val-min'),
        feather_radius: intVal('rc-feather'),
        spill_correction: selectVal('rc-spill-mode'),
        rembg_model: selectVal('rc-rembg-model'),
        alpha_matting: checkVal('rc-alpha-matting'),
        quality_threshold: intVal('rc-quality-threshold') / 100,
        validate: checkVal('rc-validate'),
      }
    }

    function intVal(id: string): number {
      return parseInt((document.getElementById(id) as HTMLInputElement)?.value || '0', 10)
    }

    function selectVal(id: string): string {
      return (document.getElementById(id) as HTMLSelectElement)?.value || ''
    }

    function checkVal(id: string): boolean {
      return (document.getElementById(id) as HTMLInputElement)?.checked ?? false
    }

    // ── Status ───────────────────────────────────────────────────────
    function showStatus(text: string) {
      const status = document.getElementById('rc-status') as HTMLDivElement
      const statusText = document.getElementById('rc-status-text') as HTMLSpanElement
      if (status && statusText) {
        statusText.textContent = text
        status.hidden = false
      }
    }

    function hideStatus() {
      const status = document.getElementById('rc-status') as HTMLDivElement
      if (status) status.hidden = true
    }

    function updateQualityBadge(score: number) {
      const badge = document.getElementById('rc-quality-badge') as HTMLDivElement
      const scoreEl = document.getElementById('rc-quality-score') as HTMLSpanElement
      if (badge && scoreEl) {
        scoreEl.textContent = score.toFixed(2)
        badge.dataset.score = String(score)
        badge.hidden = false
        if (score >= 0.85) badge.dataset.grade = 'excellent'
        else if (score >= 0.7) badge.dataset.grade = 'good'
        else badge.dataset.grade = 'poor'
      }
    }

    // ── Public API ───────────────────────────────────────────────────
    ;(window as any).__rembgControls = {
      getConfig,
      showStatus,
      hideStatus,
      updateQualityBadge,
    }
  })
</script>
