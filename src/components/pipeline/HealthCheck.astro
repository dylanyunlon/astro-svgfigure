---
/**
 * HealthCheck.astro — Backend connection status indicator
 *
 * Shows a small status dot + text indicating whether the Python backend
 * is reachable. Auto-checks on page load.
 *
 * GitHub 背书: cworld1/astro-theme-pure (component patterns)
 */
---

<div id="health-check" class="flex items-center gap-x-2 text-xs text-muted-foreground">
  <span
    id="health-dot"
    class="inline-block h-2 w-2 rounded-full bg-muted"
    title="Checking..."
  ></span>
  <span id="health-text">Checking backend...</span>
  <span id="health-keys" class="hidden text-muted-foreground"></span>
</div>

<script>
  ;(async () => {
    const dot = document.getElementById('health-dot') as HTMLElement
    const text = document.getElementById('health-text') as HTMLElement
    const keys = document.getElementById('health-keys') as HTMLElement
    const btn = document.getElementById('generate-btn') as HTMLButtonElement | null

    try {
      const res = await fetch('/api/health')
      const data = await res.json()

      if (data.backend) {
        dot.classList.remove('bg-muted')
        dot.classList.add('bg-green-500')
        dot.title = 'Backend connected'

        // Count available model providers
        const modelCount = data.models
          ? Object.values(data.models).flat().length
          : 0

        // Show pipeline info
        const parts: string[] = [`Backend OK`]
        if (modelCount > 0) parts.push(`${modelCount} model${modelCount !== 1 ? 's' : ''}`)
        text.textContent = parts.join(' · ')

        // Show pipeline steps availability
        if (data.pipelineReady) {
          keys.classList.remove('hidden')
          keys.textContent = '· Pipeline ready (Step 1→2→3)'
          keys.classList.add('text-green-600')
        }
      } else {
        dot.classList.remove('bg-muted')
        dot.classList.add('bg-red-500')
        dot.title = `Backend error: ${data.backendError || 'unreachable'}`
        text.textContent = 'Backend offline — run: python server.py'
        text.classList.add('text-red-500')

        // Disable generate button if backend is down
        if (btn) {
          btn.disabled = true
          btn.title = 'Python backend is not running'
        }
      }
    } catch {
      dot.classList.remove('bg-muted')
      dot.classList.add('bg-yellow-500')
      dot.title = 'Health check failed'
      text.textContent = 'Health check failed'
    }
  })()
</script>
