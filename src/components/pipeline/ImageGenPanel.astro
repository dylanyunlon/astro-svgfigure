---
/**
 * ImageGenPanel — Step 5: Generate Publication-Quality Image
 *
 * Flow:
 *   1. User confirms the ELK SVG rendering has all components
 *   2. (Optional) Grok 4 generates a detailed prompt
 *   3. User reviews/edits prompt
 *   4. Gemini 3 Pro Image generates the final scientific figure
 *
 * Uses astro-pure components: Button, Card, Collapse, Label
 * GitHub 背书: gemini-cli-extensions/nanobanana, ZeroLu/awesome-nanobanana-pro
 */
import { Button, Collapse, Label } from 'astro-pure/user'
---

<div id="image-gen-panel" class="flex flex-col gap-y-3">
  {/* Header */}
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-x-2">
      <div class="flex h-6 w-6 items-center justify-center rounded-full bg-purple-100 text-xs font-bold text-purple-700 dark:bg-purple-900 dark:text-purple-300">
        5
      </div>
      <span class="text-sm font-medium">Scientific Figure</span>
    </div>
    <Label id="image-gen-status" class="text-xs">Waiting for SVG</Label>
  </div>

  {/* Confirm SVG section */}
  <div id="image-gen-confirm" class="rounded-lg border border-dashed border-muted p-3">
    <p class="mb-2 text-xs text-muted-foreground">
      Review the SVG above. If all components are present, generate a
      publication-quality scientific figure using Gemini 3 Pro Image.
    </p>
    <button
      id="image-gen-confirm-btn"
      disabled
      class="flex w-full items-center justify-center gap-x-1.5 rounded-lg border bg-purple-600 px-3 py-1.5 text-xs font-medium text-white transition-all hover:bg-purple-700 disabled:opacity-40 disabled:cursor-not-allowed"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="17 8 12 3 7 8" />
        <line x1="12" y1="3" x2="12" y2="15" />
      </svg>
      <span id="image-gen-confirm-text">Generate Scientific Figure</span>
    </button>
  </div>

  {/* Options */}
  <Collapse title="Image Options">
    <div class="flex flex-col gap-y-2 pb-2">
      <div class="flex flex-col gap-y-1">
        <label class="text-xs text-muted-foreground" for="img-prompt-model">
          Prompt Model (Step a)
        </label>
        <select
          id="img-prompt-model"
          class="rounded-lg border bg-muted px-2 py-1 text-xs text-foreground"
        >
          <option value="grok-4" selected>Grok 4 (recommended)</option>
          <option value="claude-sonnet-4-5-20250929">Claude Opus 4.6</option>
          <option value="gemini-2.5-pro">Gemini 2.5 Pro</option>
        </select>
      </div>

      <div class="flex flex-col gap-y-1">
        <label class="text-xs text-muted-foreground" for="img-gen-model">
          Image Model (Step b)
        </label>
        <select
          id="img-gen-model"
          class="rounded-lg border bg-muted px-2 py-1 text-xs text-foreground"
        >
          <option value="gemini-3-pro-image-preview" selected>Gemini 3 Pro Image</option>
        </select>
      </div>

      <div class="flex flex-col gap-y-1">
        <label class="text-xs text-muted-foreground" for="img-aspect">
          Aspect Ratio
        </label>
        <select
          id="img-aspect"
          class="rounded-lg border bg-muted px-2 py-1 text-xs text-foreground"
        >
          <option value="16:9" selected>16:9 (Landscape)</option>
          <option value="4:3">4:3</option>
          <option value="1:1">1:1 (Square)</option>
          <option value="3:4">3:4 (Portrait)</option>
        </select>
      </div>

      <div class="flex flex-col gap-y-1">
        <label class="text-xs text-muted-foreground" for="img-size">
          Image Size
        </label>
        <select
          id="img-size"
          class="rounded-lg border bg-muted px-2 py-1 text-xs text-foreground"
        >
          <option value="4K" selected>4K</option>
          <option value="1080p">1080p</option>
        </select>
      </div>
    </div>
  </Collapse>

  {/* Prompt preview/edit */}
  <Collapse title="AI Prompt (Editable)">
    <div class="flex flex-col gap-y-2 pb-2">
      <textarea
        id="img-prompt-text"
        rows="6"
        class="w-full rounded-lg border bg-muted p-2 text-xs text-foreground placeholder:text-muted-foreground"
        placeholder="The prompt will be auto-generated by Grok 4. You can edit it before generating the image."
      ></textarea>
      <div class="flex gap-x-2">
        <button
          id="img-gen-prompt-btn"
          disabled
          class="flex-1 rounded-lg border px-2 py-1 text-xs font-medium text-muted-foreground transition-all hover:bg-muted disabled:opacity-40 disabled:cursor-not-allowed"
        >
          Generate Prompt Only
        </button>
        <button
          id="img-gen-with-prompt-btn"
          disabled
          class="flex-1 rounded-lg border bg-indigo-600 px-2 py-1 text-xs font-medium text-white transition-all hover:bg-indigo-700 disabled:opacity-40 disabled:cursor-not-allowed"
        >
          Generate Image with Prompt
        </button>
      </div>
    </div>
  </Collapse>

  {/* Image result */}
  <div id="image-gen-result" class="hidden">
    <div class="overflow-hidden rounded-lg border">
      <img
        id="image-gen-preview"
        class="h-auto w-full"
        alt="Generated scientific figure"
      />
    </div>
    <div class="mt-2 flex gap-x-2">
      <button
        id="image-gen-download"
        class="flex-1 rounded-lg border px-2 py-1 text-xs font-medium text-muted-foreground hover:bg-muted"
      >
        Download Image
      </button>
      <button
        id="image-gen-regenerate"
        class="flex-1 rounded-lg border px-2 py-1 text-xs font-medium text-muted-foreground hover:bg-muted"
      >
        Regenerate
      </button>
    </div>
    <p id="image-gen-info" class="mt-1 text-xs text-muted-foreground"></p>
  </div>

  {/* Loading indicator */}
  <div id="image-gen-loading" class="hidden flex flex-col items-center gap-y-2 py-4">
    <div class="h-8 w-8 animate-spin rounded-full border-2 border-purple-200 border-t-purple-600"></div>
    <p id="image-gen-loading-text" class="text-xs text-muted-foreground">
      Generating scientific figure...
    </p>
  </div>
</div>

<script>
  /**
   * ImageGenPanel client-side logic
   *
   * Manages the Step 5 flow:
   *   1. Enable confirm button when SVG is available
   *   2. Generate prompt via Grok 4
   *   3. Generate image via Gemini 3 Pro Image
   *   4. Display result with download option
   */

  const confirmBtn = document.getElementById('image-gen-confirm-btn') as HTMLButtonElement
  const confirmText = document.getElementById('image-gen-confirm-text') as HTMLSpanElement
  const statusLabel = document.getElementById('image-gen-status') as HTMLElement
  const promptTextarea = document.getElementById('img-prompt-text') as HTMLTextAreaElement
  const genPromptBtn = document.getElementById('img-gen-prompt-btn') as HTMLButtonElement
  const genWithPromptBtn = document.getElementById('img-gen-with-prompt-btn') as HTMLButtonElement
  const resultDiv = document.getElementById('image-gen-result') as HTMLElement
  const previewImg = document.getElementById('image-gen-preview') as HTMLImageElement
  const downloadBtn = document.getElementById('image-gen-download') as HTMLButtonElement
  const regenerateBtn = document.getElementById('image-gen-regenerate') as HTMLButtonElement
  const loadingDiv = document.getElementById('image-gen-loading') as HTMLElement
  const loadingText = document.getElementById('image-gen-loading-text') as HTMLElement
  const infoText = document.getElementById('image-gen-info') as HTMLElement

  // Store state
  let currentSvg = ''
  let currentMethodText = ''
  let currentElkGraph: any = null
  let currentImageB64 = ''
  let currentMimeType = 'image/png'

  // Expose enable/disable API for the pipeline orchestrator
  ;(window as any).__imageGenPanel = {
    enable(svg: string, methodText: string, elkGraph?: any) {
      currentSvg = svg
      currentMethodText = methodText
      currentElkGraph = elkGraph || null
      confirmBtn.disabled = false
      genPromptBtn.disabled = false
      genWithPromptBtn.disabled = false
      statusLabel.textContent = 'Ready'
      statusLabel.className = 'text-xs text-green-600 dark:text-green-400'
    },
    disable() {
      confirmBtn.disabled = true
      genPromptBtn.disabled = true
      genWithPromptBtn.disabled = true
      currentSvg = ''
      currentMethodText = ''
      currentElkGraph = null
      statusLabel.textContent = 'Waiting for SVG'
      statusLabel.className = 'text-xs'
      resultDiv.classList.add('hidden')
      loadingDiv.classList.add('hidden')
    },
  }

  function showLoading(text: string) {
    loadingDiv.classList.remove('hidden')
    loadingText.textContent = text
    resultDiv.classList.add('hidden')
  }

  function hideLoading() {
    loadingDiv.classList.add('hidden')
  }

  function getOptions() {
    return {
      prompt_model: (document.getElementById('img-prompt-model') as HTMLSelectElement)?.value,
      image_model: (document.getElementById('img-gen-model') as HTMLSelectElement)?.value,
      aspect_ratio: (document.getElementById('img-aspect') as HTMLSelectElement)?.value,
      image_size: (document.getElementById('img-size') as HTMLSelectElement)?.value,
    }
  }

  // Generate prompt only (Step a)
  genPromptBtn?.addEventListener('click', async () => {
    if (!currentSvg || !currentMethodText) return

    genPromptBtn.disabled = true
    genPromptBtn.textContent = 'Generating prompt...'

    try {
      const opts = getOptions()
      const res = await fetch('/api/generate-prompt', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          method_text: currentMethodText,
          svg_content: currentSvg,
          model: opts.prompt_model,
          elk_graph: currentElkGraph,
        }),
      })
      const data = await res.json()
      if (data.success && data.prompt) {
        promptTextarea.value = data.prompt
        statusLabel.textContent = `Prompt ready (${data.model_used || 'unknown'})`
      } else {
        promptTextarea.value = `Error: ${data.error || 'Failed to generate prompt'}`
      }
    } catch (err: any) {
      promptTextarea.value = `Error: ${err.message}`
    } finally {
      genPromptBtn.disabled = false
      genPromptBtn.textContent = 'Generate Prompt Only'
    }
  })

  // Full pipeline: Generate prompt + image (confirm button)
  confirmBtn?.addEventListener('click', () => generateImage())
  genWithPromptBtn?.addEventListener('click', () => generateImage(promptTextarea.value))
  regenerateBtn?.addEventListener('click', () => generateImage(promptTextarea.value))

  async function generateImage(customPrompt?: string) {
    if (!currentSvg || !currentMethodText) return

    confirmBtn.disabled = true
    genWithPromptBtn.disabled = true
    confirmText.textContent = 'Generating...'
    statusLabel.textContent = 'Generating image...'
    statusLabel.className = 'text-xs text-purple-600 dark:text-purple-400'

    const opts = getOptions()
    const startTime = Date.now()

    showLoading(
      customPrompt
        ? 'Step b: Gemini 3 Pro generating image...'
        : 'Step a: Grok 4 generating prompt... then Step b: Gemini 3 Pro Image...'
    )

    try {
      const res = await fetch('/api/generate-image', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          svg_content: currentSvg,
          method_text: currentMethodText,
          prompt_model: opts.prompt_model,
          image_model: opts.image_model,
          aspect_ratio: opts.aspect_ratio,
          image_size: opts.image_size,
          custom_prompt: customPrompt || null,
          elk_graph: currentElkGraph,
        }),
      })

      const data = await res.json()
      const elapsed = ((Date.now() - startTime) / 1000).toFixed(1)

      if (data.success && data.image_b64) {
        currentImageB64 = data.image_b64
        currentMimeType = data.mime_type || 'image/png'

        // Display image
        previewImg.src = `data:${currentMimeType};base64,${currentImageB64}`
        resultDiv.classList.remove('hidden')

        // Update prompt textarea with the used prompt
        if (data.prompt) {
          promptTextarea.value = data.prompt
        }

        statusLabel.textContent = `Done (${elapsed}s)`
        statusLabel.className = 'text-xs text-green-600 dark:text-green-400'
        infoText.textContent = `Prompt: ${data.prompt_model_used || '?'} → Image: ${data.image_model_used || '?'} | ${elapsed}s`
      } else {
        statusLabel.textContent = `Error: ${data.error || 'Failed'}`
        statusLabel.className = 'text-xs text-red-600 dark:text-red-400'
        infoText.textContent = data.error || 'Unknown error'
      }
    } catch (err: any) {
      statusLabel.textContent = `Error: ${err.message}`
      statusLabel.className = 'text-xs text-red-600 dark:text-red-400'
    } finally {
      hideLoading()
      confirmBtn.disabled = false
      genWithPromptBtn.disabled = false
      confirmText.textContent = 'Generate Scientific Figure'
    }
  }

  // Download image
  downloadBtn?.addEventListener('click', () => {
    if (!currentImageB64) return
    const ext = currentMimeType.split('/')[1] || 'png'
    const link = document.createElement('a')
    link.href = `data:${currentMimeType};base64,${currentImageB64}`
    link.download = `scientific-figure.${ext}`
    link.click()
  })
</script>
