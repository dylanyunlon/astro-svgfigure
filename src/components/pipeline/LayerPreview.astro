---
/**
 * LayerPreview.astro — Layer Separation Preview & Management Panel
 *
 * Displays separated layers from the green-screen pipeline with
 * interactive per-layer controls: thumbnails, visibility toggles,
 * reorder (drag), bounding-box overlay, and a composite preview
 * canvas that renders visible layers in z-order.
 *
 * Pipeline Position: Step 5 → Step 6 visualization
 *   Step 4: Background removal (transparent PNGs)
 * → Step 5: Layer separation (this component displays results)
 *   Step 6: Edge refinement (applied per-layer from here)
 *
 * Features:
 *   - Layer thumbnail grid with checkerboard transparency
 *   - Per-layer info: area, centroid, bounding box
 *   - Visibility toggle (eye icon) per layer
 *   - Drag-to-reorder layer z-order
 *   - Composite preview canvas showing all visible layers
 *   - "Refine Edges" button per layer → calls edge_refiner
 *   - Layer selection for downstream operations
 *   - Zoom/pan on composite canvas via mouse wheel + drag
 *
 * Uses astro-pure Card component wrapper.
 * Exposes window.__layerPreview global for JS orchestration.
 *
 * Knuth-Level Critiques:
 * ──────────────────────
 * User Angle:
 *   - Each layer thumbnail shows a checkerboard behind transparent
 *     areas (same as Photoshop convention). The user instantly sees
 *     what was extracted vs. what's empty.
 *   - The composite preview updates in real-time when toggling
 *     layer visibility. Layers render in their original position
 *     (using bbox offsets), so the composite looks correct.
 *   - Drag-to-reorder uses a subtle blue insertion line indicator.
 *     No spring animations — just a clean snap to final position.
 *
 * System Angle:
 *   - Layer images are stored as base64 PNG strings in a JS array.
 *     For 8 layers at 512×512 RGBA, this is ~8MB decoded — fine
 *     for typical use. We pre-create Image objects for canvas
 *     compositing to avoid repeated decode overhead.
 *   - The composite canvas uses globalCompositeOperation='source-over'
 *     (Porter-Duff "over") in z-order, bottom layer first. This
 *     matches the layer_separator.py output order.
 *   - Zoom is implemented via CSS transform on the canvas wrapper,
 *     not canvas re-render, so it's GPU-accelerated and smooth.
 *
 * GitHub 背书: cworld1/astro-theme-pure (Card component)
 */
import Card from 'astro-pure/user/Card.astro'

interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<div class:list={['layer-preview', className]} id="layer-preview-panel">
  <Card>
    <div class="lp-header">
      <h3 class="lp-title">
        <span class="lp-icon">📐</span>
        Separated Layers
      </h3>
      <div class="lp-summary" id="lp-summary" hidden>
        <span class="lp-count" id="lp-layer-count">0 layers</span>
      </div>
    </div>

    <!-- Placeholder (shown when no layers loaded) -->
    <div id="lp-placeholder" class="lp-placeholder">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <path d="M3 9h18" /><path d="M9 21V9" />
      </svg>
      <span class="lp-placeholder-text">Layers will appear after separation</span>
      <span class="lp-placeholder-hint">Run background removal first, then separate layers</span>
    </div>

    <!-- Layer List -->
    <div id="lp-layer-list" class="lp-layer-list" hidden>
    </div>

    <!-- Composite Preview -->
    <div id="lp-composite-section" class="lp-composite-section" hidden>
      <label class="lp-section-label">Composite Preview</label>
      <div class="lp-canvas-wrapper" id="lp-canvas-wrapper">
        <canvas id="lp-composite-canvas"></canvas>
      </div>
      <div class="lp-canvas-controls">
        <button type="button" class="lp-ctrl-btn" id="lp-zoom-in" title="Zoom in">+</button>
        <button type="button" class="lp-ctrl-btn" id="lp-zoom-out" title="Zoom out">−</button>
        <button type="button" class="lp-ctrl-btn" id="lp-zoom-reset" title="Reset view">⊙</button>
        <span class="lp-zoom-level" id="lp-zoom-level">100%</span>
      </div>
    </div>

    <!-- Actions -->
    <div id="lp-actions" class="lp-actions" hidden>
      <button type="button" class="lp-btn lp-btn-refine" id="lp-btn-refine-all">
        Refine All Edges
      </button>
      <button type="button" class="lp-btn lp-btn-export" id="lp-btn-export-layers">
        Export Layers
      </button>
    </div>
  </Card>
</div>

<style>
  .layer-preview {
    width: 100%;
  }

  .lp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .lp-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-color, #1a1a1a);
  }

  .lp-icon { font-size: 1.2rem; }

  .lp-summary {
    font-size: 0.85rem;
    color: var(--text-muted, #6b7280);
    font-weight: 500;
  }

  /* Placeholder */
  .lp-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem 1rem;
    color: var(--text-muted, #9ca3af);
    text-align: center;
  }

  .lp-placeholder-text {
    font-size: 0.9rem;
  }

  .lp-placeholder-hint {
    font-size: 0.75rem;
  }

  /* Layer List */
  .lp-layer-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
    max-height: 400px;
    overflow-y: auto;
  }

  .lp-section-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted, #6b7280);
    margin-bottom: 0.5rem;
  }

  /* Individual Layer Card */
  :global(.lp-layer-card) {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem;
    border: 1px solid var(--border-color, #e5e7eb);
    border-radius: 0.5rem;
    cursor: grab;
    transition: border-color 0.15s, background 0.15s;
    background: transparent;
  }

  :global(.lp-layer-card:hover) {
    border-color: var(--accent-color, #6366f1);
  }

  :global(.lp-layer-card.selected) {
    border-color: var(--accent-color, #6366f1);
    background: var(--accent-bg, #eef2ff);
  }

  :global(.lp-layer-card.dragging) {
    opacity: 0.5;
  }

  :global(.lp-layer-card.drag-over) {
    border-top: 2px solid var(--accent-color, #6366f1);
  }

  :global(.lp-layer-card[data-visible="false"]) {
    opacity: 0.5;
  }

  /* Layer Thumbnail */
  :global(.lp-thumb-wrap) {
    flex: 0 0 56px;
    width: 56px;
    height: 56px;
    border-radius: 0.375rem;
    overflow: hidden;
    background-image: repeating-conic-gradient(#e5e7eb 0% 25%, transparent 0% 50%);
    background-size: 10px 10px;
    position: relative;
  }

  :global(.lp-thumb-wrap img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Layer Info */
  :global(.lp-layer-info) {
    flex: 1;
    min-width: 0;
  }

  :global(.lp-layer-name) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-color, #1a1a1a);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.lp-layer-meta) {
    font-size: 0.7rem;
    color: var(--text-muted, #9ca3af);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.15rem;
  }

  /* Layer Action Buttons */
  :global(.lp-layer-actions) {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  :global(.lp-layer-action-btn) {
    width: 28px;
    height: 28px;
    border: none;
    border-radius: 0.375rem;
    background: transparent;
    cursor: pointer;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.1s;
    color: var(--text-muted, #6b7280);
  }

  :global(.lp-layer-action-btn:hover) {
    background: var(--bg-muted, #f3f4f6);
  }

  :global(.lp-layer-action-btn.active) {
    color: var(--accent-color, #6366f1);
  }

  /* Composite Canvas */
  .lp-composite-section {
    margin-bottom: 1rem;
  }

  .lp-canvas-wrapper {
    border: 1px solid var(--border-color, #e5e7eb);
    border-radius: 0.5rem;
    overflow: hidden;
    position: relative;
    min-height: 200px;
    background-image: repeating-conic-gradient(#e5e7eb 0% 25%, transparent 0% 50%);
    background-size: 20px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lp-canvas-wrapper canvas {
    max-width: 100%;
    max-height: 400px;
    display: block;
    transition: transform 0.1s ease;
  }

  .lp-canvas-controls {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.4rem;
  }

  .lp-ctrl-btn {
    width: 28px;
    height: 28px;
    border: 1px solid var(--border-color, #d1d5db);
    border-radius: 0.375rem;
    background: var(--bg-color, #fff);
    color: var(--text-color, #374151);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.1s;
  }

  .lp-ctrl-btn:hover {
    background: var(--bg-muted, #f3f4f6);
  }

  .lp-zoom-level {
    font-size: 0.75rem;
    color: var(--text-muted, #9ca3af);
    font-variant-numeric: tabular-nums;
    margin-left: 0.25rem;
  }

  /* Actions */
  .lp-actions {
    display: flex;
    gap: 0.5rem;
  }

  .lp-btn {
    flex: 1;
    padding: 0.6rem 1rem;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .lp-btn-refine {
    background: var(--bg-muted, #f3f4f6);
    color: var(--text-color, #374151);
  }

  .lp-btn-refine:hover {
    background: var(--border-color, #d1d5db);
  }

  .lp-btn-export {
    background: var(--accent-color, #6366f1);
    color: #fff;
  }

  .lp-btn-export:hover {
    opacity: 0.9;
  }

  .lp-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const panel = document.getElementById('layer-preview-panel') as HTMLDivElement
    if (!panel) return

    const placeholder = document.getElementById('lp-placeholder') as HTMLDivElement
    const layerList = document.getElementById('lp-layer-list') as HTMLDivElement
    const compositeSection = document.getElementById('lp-composite-section') as HTMLDivElement
    const compositeCanvas = document.getElementById('lp-composite-canvas') as HTMLCanvasElement
    const actionsDiv = document.getElementById('lp-actions') as HTMLDivElement
    const summaryDiv = document.getElementById('lp-summary') as HTMLDivElement
    const layerCountEl = document.getElementById('lp-layer-count') as HTMLSpanElement
    const zoomLevelEl = document.getElementById('lp-zoom-level') as HTMLSpanElement

    interface LayerData {
      id: string
      name: string
      image_b64: string
      bbox: { x: number; y: number; w: number; h: number }
      area: number
      centroid: { x: number; y: number }
      visible: boolean
      imgEl: HTMLImageElement | null
    }

    let layers: LayerData[] = []
    let selectedId: string | null = null
    let canvasWidth = 0
    let canvasHeight = 0
    let zoomLevel = 1.0

    // ── Load Layers ──────────────────────────────────────────────────
    function loadLayers(
      layerDataArray: Array<{
        image_b64: string
        bbox?: { x: number; y: number; w: number; h: number }
        area?: number
        centroid?: { x: number; y: number }
      }>,
      sourceWidth: number,
      sourceHeight: number,
    ) {
      canvasWidth = sourceWidth || 512
      canvasHeight = sourceHeight || 512
      layers = []

      for (let i = 0; i < layerDataArray.length; i++) {
        const ld = layerDataArray[i]
        const layer: LayerData = {
          id: `layer-${i}`,
          name: `Layer ${i + 1}`,
          image_b64: ld.image_b64,
          bbox: ld.bbox || { x: 0, y: 0, w: canvasWidth, h: canvasHeight },
          area: ld.area || 0,
          centroid: ld.centroid || { x: 0, y: 0 },
          visible: true,
          imgEl: null,
        }

        // Pre-decode image
        const img = new Image()
        img.src = `data:image/png;base64,${ld.image_b64}`
        layer.imgEl = img
        layers.push(layer)
      }

      renderLayerList()
      showLayerUI(true)
      // Wait for images to load before rendering composite
      Promise.all(
        layers.map(
          l =>
            new Promise<void>(resolve => {
              if (l.imgEl!.complete) return resolve()
              l.imgEl!.onload = () => resolve()
              l.imgEl!.onerror = () => resolve()
            }),
        ),
      ).then(() => renderComposite())
    }

    // ── Show/Hide UI ─────────────────────────────────────────────────
    function showLayerUI(show: boolean) {
      placeholder.hidden = show
      layerList.hidden = !show
      compositeSection.hidden = !show
      actionsDiv.hidden = !show
      summaryDiv.hidden = !show
      layerCountEl.textContent = `${layers.length} layer${layers.length !== 1 ? 's' : ''}`
    }

    // ── Render Layer List ────────────────────────────────────────────
    function renderLayerList() {
      layerList.innerHTML = ''

      for (let i = 0; i < layers.length; i++) {
        const layer = layers[i]
        const card = document.createElement('div')
        card.className = `lp-layer-card${selectedId === layer.id ? ' selected' : ''}`
        card.dataset.layerId = layer.id
        card.dataset.visible = String(layer.visible)
        card.draggable = true

        const thumb = document.createElement('div')
        thumb.className = 'lp-thumb-wrap'
        const thumbImg = document.createElement('img')
        thumbImg.src = `data:image/png;base64,${layer.image_b64}`
        thumbImg.alt = layer.name
        thumbImg.loading = 'lazy'
        thumb.appendChild(thumbImg)

        const info = document.createElement('div')
        info.className = 'lp-layer-info'
        const nameSpan = document.createElement('div')
        nameSpan.className = 'lp-layer-name'
        nameSpan.textContent = layer.name
        const metaSpan = document.createElement('div')
        metaSpan.className = 'lp-layer-meta'
        metaSpan.innerHTML = [
          `${layer.bbox.w}×${layer.bbox.h}`,
          `area: ${layer.area.toLocaleString()}px`,
          `pos: (${layer.bbox.x}, ${layer.bbox.y})`,
        ].join('<span style="opacity:0.4">·</span>')
        info.appendChild(nameSpan)
        info.appendChild(metaSpan)

        const actions = document.createElement('div')
        actions.className = 'lp-layer-actions'

        // Visibility toggle
        const visBtn = document.createElement('button')
        visBtn.type = 'button'
        visBtn.className = `lp-layer-action-btn${layer.visible ? ' active' : ''}`
        visBtn.title = layer.visible ? 'Hide layer' : 'Show layer'
        visBtn.textContent = layer.visible ? '👁' : '🚫'
        visBtn.addEventListener('click', e => {
          e.stopPropagation()
          layer.visible = !layer.visible
          renderLayerList()
          renderComposite()
        })

        // Refine button
        const refineBtn = document.createElement('button')
        refineBtn.type = 'button'
        refineBtn.className = 'lp-layer-action-btn'
        refineBtn.title = 'Refine edges'
        refineBtn.textContent = '✨'
        refineBtn.addEventListener('click', e => {
          e.stopPropagation()
          const event = new CustomEvent('layer-refine', {
            detail: { layerId: layer.id, index: i },
          })
          panel.dispatchEvent(event)
        })

        actions.appendChild(visBtn)
        actions.appendChild(refineBtn)

        card.appendChild(thumb)
        card.appendChild(info)
        card.appendChild(actions)

        // Selection
        card.addEventListener('click', () => {
          selectedId = selectedId === layer.id ? null : layer.id
          renderLayerList()
        })

        // Drag-to-reorder
        card.addEventListener('dragstart', e => {
          card.classList.add('dragging')
          e.dataTransfer!.setData('text/plain', String(i))
          e.dataTransfer!.effectAllowed = 'move'
        })
        card.addEventListener('dragend', () => card.classList.remove('dragging'))
        card.addEventListener('dragover', e => {
          e.preventDefault()
          e.dataTransfer!.dropEffect = 'move'
          card.classList.add('drag-over')
        })
        card.addEventListener('dragleave', () => card.classList.remove('drag-over'))
        card.addEventListener('drop', e => {
          e.preventDefault()
          card.classList.remove('drag-over')
          const fromIdx = parseInt(e.dataTransfer!.getData('text/plain'), 10)
          const toIdx = i
          if (fromIdx !== toIdx && !isNaN(fromIdx)) {
            const [moved] = layers.splice(fromIdx, 1)
            layers.splice(toIdx, 0, moved)
            renderLayerList()
            renderComposite()
          }
        })

        layerList.appendChild(card)
      }
    }

    // ── Render Composite Canvas ──────────────────────────────────────
    function renderComposite() {
      const ctx = compositeCanvas.getContext('2d')
      if (!ctx) return

      compositeCanvas.width = canvasWidth
      compositeCanvas.height = canvasHeight
      ctx.clearRect(0, 0, canvasWidth, canvasHeight)

      // Draw layers bottom-to-top (index 0 = bottom)
      for (const layer of layers) {
        if (!layer.visible || !layer.imgEl || !layer.imgEl.complete) continue
        ctx.globalCompositeOperation = 'source-over'
        ctx.drawImage(
          layer.imgEl,
          layer.bbox.x,
          layer.bbox.y,
          layer.bbox.w,
          layer.bbox.h,
        )
      }
    }

    // ── Zoom Controls ────────────────────────────────────────────────
    const canvasWrapper = document.getElementById('lp-canvas-wrapper') as HTMLDivElement

    function setZoom(level: number) {
      zoomLevel = Math.max(0.25, Math.min(4.0, level))
      compositeCanvas.style.transform = `scale(${zoomLevel})`
      zoomLevelEl.textContent = `${Math.round(zoomLevel * 100)}%`
    }

    document.getElementById('lp-zoom-in')?.addEventListener('click', () => setZoom(zoomLevel + 0.25))
    document.getElementById('lp-zoom-out')?.addEventListener('click', () => setZoom(zoomLevel - 0.25))
    document.getElementById('lp-zoom-reset')?.addEventListener('click', () => setZoom(1.0))

    canvasWrapper?.addEventListener('wheel', e => {
      e.preventDefault()
      setZoom(zoomLevel + (e.deltaY < 0 ? 0.1 : -0.1))
    }, { passive: false })

    // ── Get Layers Data ──────────────────────────────────────────────
    function getLayers(): LayerData[] {
      return [...layers]
    }

    function getVisibleLayers(): LayerData[] {
      return layers.filter(l => l.visible)
    }

    function getSelectedLayer(): LayerData | null {
      return layers.find(l => l.id === selectedId) || null
    }

    // ── Update a single layer image (e.g. after edge refinement) ────
    function updateLayerImage(index: number, newB64: string) {
      if (index < 0 || index >= layers.length) return
      layers[index].image_b64 = newB64
      const img = new Image()
      img.src = `data:image/png;base64,${newB64}`
      layers[index].imgEl = img
      img.onload = () => {
        renderLayerList()
        renderComposite()
      }
    }

    // ── Public API ───────────────────────────────────────────────────
    ;(window as any).__layerPreview = {
      loadLayers,
      getLayers,
      getVisibleLayers,
      getSelectedLayer,
      updateLayerImage,
      renderComposite,
    }
  })
</script>
